<script define:vars={{ SB_URL, SB_ANON }}>
  // Countdown posti gita: legge la vista aggregata v_posti_gita (solo numeri).
  (function () {
    const wrap = document.querySelector('[data-gita-countdown]');
    if (!wrap || !SB_URL || !SB_ANON) return;
    const testo = wrap.querySelector('[data-gita-testo]');
    const barra = wrap.querySelector('[data-gita-barra]');
    fetch(`${SB_URL}/rest/v1/v_posti_gita?select=posti_totali,posti_occupati`, {
      headers: { apikey: SB_ANON, Authorization: `Bearer ${SB_ANON}` },
    })
      .then((r) => (r.ok ? r.json() : []))
      .then((rows) => {
        const row = Array.isArray(rows) ? rows[0] : null;
        if (!row) return;
        const totali = Number(row.posti_totali) || 54;
        const occupati = Math.min(Number(row.posti_occupati) || 0, totali);
        const disponibili = Math.max(totali - occupati, 0);
        if (testo) testo.textContent = `${disponibili} di ${totali}`;
        if (barra) barra.style.width = `${Math.round((occupati / totali) * 100)}%`;
        if (disponibili <= 10 && disponibili > 0 && testo) {
          testo.textContent = `Ultimi ${disponibili} posti!`;
          testo.style.color = '#a33';
        } else if (disponibili === 0 && testo) {
          testo.textContent = 'Posti esauriti';
          testo.style.color = '#a33';
        }
      })
      .catch(() => {});
  })();
</script>

