---
/**
 * Home — El Brenz da le Val del Nos
 *
 * Hero identitario: titolo principale + motto in ladino + 2 CTA.
 * Niente articoli dinamici (saranno in M2).
 */

import Layout from '../layouts/Layout.astro';
import FirmaIstituzionale from '../components/FirmaIstituzionale.astro';

// M2.6-bis: box "Sostieni El Brenz" — esiste in pagina SOLO col flag
// go-live pagamenti attivo (build time, vedi src/lib/pagamenti.ts).
import { PAGAMENTI_LIVE } from '../lib/pagamenti';
import LightboxEmbed from '../components/LightboxEmbed.astro';
import { createClient } from '@supabase/supabase-js';
import fs from 'node:fs';

// M2.9 (deroga 8/7/2026): quando Cristian fornisce gli URL dei 3 post
// Instagram delle migole, inserirli qui: le celle diventano embed
// click-to-load (un click carica tutte e tre — il consenso vale per il
// provider). Finché è null restano le thumbnail statiche self-hosted.
function migoleUrls(): [string, string, string] | null {
  // M2.9-bis: reel PUBBLICI forniti da Cristian l'8/7/2026 (senza ?igsh=,
  // che è tracking di condivisione). Formato verticale → rapporto 9:16.
  return [
    'https://www.instagram.com/reel/DaK4JBVMQAE/',
    'https://www.instagram.com/reel/DZe6NM8MxxI/',
    'https://www.instagram.com/reel/DS5Vl-RjC84/',
  ];
}
const MIGOLE_POST_URLS = migoleUrls();

// M2.9-ter: copertine dei reel. Path FISSI — quando Cristian carica
// public/social/migole/migola-{1,2,3}.jpg basta una rebuild, zero
// modifiche al codice. Finché mancano, restano i placeholder brandizzati
// già esistenti (migola-0N.webp). Il check è a build time (SSG).
function copertinaMigola(n: number): string {
  return fs.existsSync(`public/social/migole/migola-${n}.jpg`)
    ? `/social/migole/migola-${n}.jpg`
    : `/social/migole/migola-0${n}.webp`;
}

// M2.9-ter (rifinitura): titoli VISIBILI sulle copertine (fascia alta).
const MIGOLE_ETICHETTE = ['Storia delle valli', 'Parlate ladine', 'Memoria e radici'];

// AGGIUNTA M2.4 (home ricca): blocco "Ultimi articoli".
// Riusa gli helper di lib/articoli e lo stesso filtro produzione di
// PaginaPilastro (!draft && !archivio). Ordinamento data desc, primi 4.
import { getCollection } from 'astro:content';
import { formatDataIT, nomePilastro } from '../lib/articoli';

const articoliProduzione = await getCollection(
  'articoli',
  ({ data }) => !data.draft && !data.archivio,
);
const ultimiArticoli = articoliProduzione
  .slice()
  .sort(
    (a, b) =>
      b.data.data_pubblicazione.getTime() - a.data.data_pubblicazione.getTime(),
  )
  .slice(0, 4);

/** Tronca l'excerpt a ~160 caratteri per la card, con ellissi. */
function troncaExcerpt(testo: string): string {
  return testo.length > 160 ? `${testo.slice(0, 157).trimEnd()}…` : testo;
}

// AGGIUNTA M2.4 — blocco "Prossimi eventi" dalla collection eventi:
// data >= oggi (mezzanotte del giorno di build, SSG), niente bozze né
// annullati, ordinati per data ascendente, max 3. Con collection vuota
// il template mostra il fallback testuale, la sezione non sparisce.
const oggi = new Date();
oggi.setHours(0, 0, 0, 0);

const eventiFuturi = (
  await getCollection('eventi', ({ data }) => !data.bozza && !data.annullato)
)
  .filter((e) => e.data.data.getTime() >= oggi.getTime())
  .sort((a, b) => a.data.data.getTime() - b.data.data.getTime())
  .slice(0, 3);

// Countdown posti gita: la barra è popolata a runtime (client) leggendo la
// vista pubblica aggregata v_posti_gita (solo conteggi, nessun dato personale).
const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'https://wacknihvdjxltiqvxtqr.supabase.co';
const SB_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '';

/** Data compatta per il riquadro della card evento, es. { giorno: "12", mese: "SET", anno: "2026" }. */
function dataCompattaEvento(data: Date): { giorno: string; mese: string; anno: string } {
  return {
    giorno: new Intl.DateTimeFormat('it-IT', { day: 'numeric' }).format(data),
    mese: new Intl.DateTimeFormat('it-IT', { month: 'short' })
      .format(data)
      .replace('.', '')
      .toUpperCase(),
    anno: String(data.getFullYear()),
  };
}

// M5.0 (10/7/2026) — marquee "Con noi nelle valli": loghi delle convenzioni
// ATTIVE letti a BUILD TIME dalla vista pubblica (i futuri loghi entrano da
// soli al rebuild). Per la striscia serve la variante orizzontale: derivata
// per convenzione di naming (-payoff/-vert -> -orizz, preferendo .webp);
// se il file ha un nome diverso resta il logo originale. Se 0 attive con
// logo, la sezione non si renderizza.
type ConvenzioneMarquee = { nome_attivita: string; logo_path: string | null };
let convenzionateMarquee: { nome: string; src: string }[] = [];
try {
  const sb = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL as string,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string,
    { auth: { persistSession: false } },
  );
  const { data } = await sb.from('convenzioni_pubbliche')
    .select('nome_attivita, logo_path')
    .order('nome_attivita', { ascending: true });
  convenzionateMarquee = ((data as ConvenzioneMarquee[]) ?? [])
    .filter((c) => c.logo_path)
    .map((c) => ({
      nome: c.nome_attivita,
      src: `${import.meta.env.PUBLIC_SUPABASE_URL}/storage/v1/object/public/assets-pubblici/${
        (c.logo_path as string).replace(/-(payoff|vert)\.(png|webp)$/, '-orizz.webp')
      }`,
    }));
} catch (e) {
  console.error('[home] marquee convenzioni: lettura fallita:', e);
  convenzionateMarquee = [];
}
// FIX mobile 10/7 (Safari iOS): niente lazy sulle immagini del nastro e
// width/height ESPLICITI (le img dentro un transform non vengono osservate
// dal lazy-load di Safari: restavano scariche e, senza dimensioni
// intrinseche, collassavano a larghezza zero -> striscia vuota).
// Dimensioni lette a BUILD TIME dagli header PNG/WebP dei loghi.
async function dimensioniLogo(url: string): Promise<{ w: number; h: number }> {
  try {
    const r = await fetch(url);
    const b = new Uint8Array(await r.arrayBuffer());
    const dv = new DataView(b.buffer);
    if (b[0] === 0x89 && b[1] === 0x50) {
      return { w: dv.getUint32(16), h: dv.getUint32(20) }; // PNG IHDR
    }
    if (b[8] === 0x57 && b[9] === 0x45) { // RIFF....WEBP
      const fourcc = String.fromCharCode(b[12], b[13], b[14], b[15]);
      if (fourcc === 'VP8X') {
        return { w: 1 + (b[24] | (b[25] << 8) | (b[26] << 16)), h: 1 + (b[27] | (b[28] << 8) | (b[29] << 16)) };
      }
      if (fourcc === 'VP8L') {
        const n = dv.getUint32(21, true);
        return { w: 1 + (n & 0x3fff), h: 1 + ((n >> 14) & 0x3fff) };
      }
      if (fourcc === 'VP8 ') {
        return { w: dv.getUint16(26, true) & 0x3fff, h: dv.getUint16(28, true) & 0x3fff };
      }
    }
  } catch (e) {
    console.error('[home] marquee: dimensioni logo non lette:', url, e);
  }
  return { w: 200, h: 64 }; // fallback prudente: evita comunque il collasso
}
const marqueeConDim = await Promise.all(
  convenzionateMarquee.map(async (c) => ({ ...c, ...(await dimensioniLogo(c.src)) })),
);

// Il singolo gruppo deve essere SEMPRE piu' largo del viewport (>=1440px di
// sicurezza, anche a 320px): ripetizioni calcolate sulla larghezza RESA
// (h mobile 64px + gap 96px). Con piu' convenzioni attive scenderanno da sole.
const larghezzaSet = marqueeConDim.reduce((t, c) => t + (c.w * 64) / c.h + 96, 0);
const nRipetizioni = Math.max(1, Math.ceil(1440 / Math.max(1, larghezzaSet)));
const filaMarquee = marqueeConDim.length > 0
  ? Array.from({ length: nRipetizioni }, () => marqueeConDim).flat()
  : [];
const marqueeRipetute = filaMarquee.slice(marqueeConDim.length);
// durata proporzionale alla lunghezza della fila (~5s per logo, rif. 40s/8)
const durataMarquee = `${filaMarquee.length * 5}s`;

// Guardiani de la lenga: card in home dietro flag (default OFF).
const GUARDIANI_LIVE = import.meta.env.GUARDIANI_LIVE === 'true';
---
<Layout ogImage="/og/og-home.jpg"
  title="El Brenz da le Val del Nos"
