---
/**
 * Home — El Brenz dle Val del Nos
 *
 * Hero identitario: titolo principale + motto in ladino + 2 CTA.
 * Niente articoli dinamici (saranno in M2).
 */

import Layout from '../layouts/Layout.astro';
import FirmaIstituzionale from '../components/FirmaIstituzionale.astro';

// M2.6-bis: box "Sostieni El Brenz" — esiste in pagina SOLO col flag
// go-live pagamenti attivo (build time, vedi src/lib/pagamenti.ts).
import { PAGAMENTI_LIVE } from '../lib/pagamenti';
import LightboxEmbed from '../components/LightboxEmbed.astro';
import fs from 'node:fs';

// M2.9 (deroga 8/7/2026): quando Cristian fornisce gli URL dei 3 post
// Instagram delle migole, inserirli qui: le celle diventano embed
// click-to-load (un click carica tutte e tre — il consenso vale per il
// provider). Finché è null restano le thumbnail statiche self-hosted.
function migoleUrls(): [string, string, string] | null {
  // M2.9-bis: reel PUBBLICI forniti da Cristian l'8/7/2026 (senza ?igsh=,
  // che è tracking di condivisione). Formato verticale → rapporto 9:16.
  return [
    'https://www.instagram.com/reel/DaK4JBVMQAE/',
    'https://www.instagram.com/reel/DZe6NM8MxxI/',
    'https://www.instagram.com/reel/DS5Vl-RjC84/',
  ];
}
const MIGOLE_POST_URLS = migoleUrls();

// M2.9-ter: copertine dei reel. Path FISSI — quando Cristian carica
// public/social/migole/migola-{1,2,3}.jpg basta una rebuild, zero
// modifiche al codice. Finché mancano, restano i placeholder brandizzati
// già esistenti (migola-0N.webp). Il check è a build time (SSG).
function copertinaMigola(n: number): string {
  return fs.existsSync(`public/social/migole/migola-${n}.jpg`)
    ? `/social/migole/migola-${n}.jpg`
    : `/social/migole/migola-0${n}.webp`;
}

// M2.9-ter (rifinitura): titoli VISIBILI sulle copertine (fascia alta).
const MIGOLE_ETICHETTE = ['Storia delle valli', 'Parlate ladine', 'Memoria e radici'];

// AGGIUNTA M2.4 (home ricca): blocco "Ultimi articoli".
// Riusa gli helper di lib/articoli e lo stesso filtro produzione di
// PaginaPilastro (!draft && !archivio). Ordinamento data desc, primi 4.
import { getCollection } from 'astro:content';
import { formatDataIT, nomePilastro } from '../lib/articoli';

const articoliProduzione = await getCollection(
  'articoli',
  ({ data }) => !data.draft && !data.archivio,
);
const ultimiArticoli = articoliProduzione
  .slice()
  .sort(
    (a, b) =>
      b.data.data_pubblicazione.getTime() - a.data.data_pubblicazione.getTime(),
  )
  .slice(0, 4);

/** Tronca l'excerpt a ~160 caratteri per la card, con ellissi. */
function troncaExcerpt(testo: string): string {
  return testo.length > 160 ? `${testo.slice(0, 157).trimEnd()}…` : testo;
}

// AGGIUNTA M2.4 — blocco "Prossimi eventi" dalla collection eventi:
// data >= oggi (mezzanotte del giorno di build, SSG), niente bozze né
// annullati, ordinati per data ascendente, max 3. Con collection vuota
// il template mostra il fallback testuale, la sezione non sparisce.
const oggi = new Date();
oggi.setHours(0, 0, 0, 0);

const eventiFuturi = (
  await getCollection('eventi', ({ data }) => !data.bozza && !data.annullato)
)
  .filter((e) => e.data.data.getTime() >= oggi.getTime())
  .sort((a, b) => a.data.data.getTime() - b.data.data.getTime())
  .slice(0, 3);

/** Data compatta per il riquadro della card evento, es. { giorno: "12", mese: "SET", anno: "2026" }. */
function dataCompattaEvento(data: Date): { giorno: string; mese: string; anno: string } {
  return {
    giorno: new Intl.DateTimeFormat('it-IT', { day: 'numeric' }).format(data),
    mese: new Intl.DateTimeFormat('it-IT', { month: 'short' })
      .format(data)
      .replace('.', '')
      .toUpperCase(),
    anno: String(data.getFullYear()),
  };
}
---
<Layout
  title="El Brenz dle Val del Nos"
  description="Associazione Storico Culturale Linguistica El Brenz delle Valli del Noce. Custodiamo la lingua ladino-anaunica e la storia di Val di Non, Val di Sole, Val di Rabbi e Val di Pejo."
>

  <section class="relative bg-[#1E2E26] text-[#F5EEDD] overflow-hidden">

    {/* AGGIUNTA hero foto (M2.5): lago alpino come sfondo, sotto un overlay
        verde brand a gradiente (più chiaro in alto, più scuro verso il basso)
        per leggibilità del testo avorio e degli accenti oro. Il bg-[#1E2E26]
        della section resta come fallback durante il caricamento. */}
    {/* WebP ottimizzate (mobile 828w ~137K, desktop 1600w ~387K) con
        fallback JPEG originale per i browser senza supporto WebP. */}
    <picture>
      <source media="(max-width: 767px)" srcset="/hero-lago-mobile.webp" type="image/webp" />
      <source srcset="/hero-lago.webp" type="image/webp" />
      <img
        src="/hero-lago.jpg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover pointer-events-none"
        width="2048"
        height="1536"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
    <div
      class="absolute inset-0 pointer-events-none bg-gradient-to-b from-[#1E2E26]/65 via-[#1E2E26]/75 to-[#1E2E26]/90"
      aria-hidden="true"
    ></div>

    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 400"
        preserveAspectRatio="none"
        class="absolute bottom-0 left-0 right-0 w-full h-2/3"
      >
        <path
          d="M0,400 L0,260 L140,180 L260,230 L380,120 L520,200 L680,100 L820,220 L960,150 L1100,260 L1200,200 L1200,400 Z"
          fill="#192821"
          opacity="0.7"
        />
        <path
          d="M0,400 L0,320 L200,260 L380,300 L560,220 L740,300 L920,240 L1100,320 L1200,280 L1200,400 Z"
          fill="#0F1D18"
          opacity="0.85"
        />
      </svg>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 py-28 md:py-40 text-center">

      <span
        class="inline-block bg-[#C8923E]/15 border border-[#C8923E] text-[#C8923E] px-4 py-1.5 text-[11px] font-medium tracking-[0.2em] uppercase mb-10"
        style="font-family: 'Inter', sans-serif;"
      >
        Associazione Storico Culturale Linguistica
      </span>

      <h1
        class="text-5xl md:text-7xl font-medium leading-[1.05] tracking-tight mb-10"
        style="font-family: 'Playfair Display', serif;"
      >
        Le radici del<br/>
        <em class="text-[#C8923E] not-italic-fix" style="font-style: italic;">ladino anaunico</em>.
      </h1>

      <p
        class="text-lg md:text-xl text-[#F5EEDD]/90 max-w-2xl mx-auto leading-relaxed mb-12"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Custodiamo, studiamo e divulghiamo la storia, la lingua e la cultura
        delle Valli del Noce: Val di Non, Val di Sole, Val di Rabbi, Val di Pejo.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mb-16" style="font-family: 'Inter', sans-serif;">
        <a href="/storia" class="inline-block bg-[#C8923E] text-[#1E2E26] px-7 py-3 text-sm font-medium tracking-wider uppercase no-underline hover:bg-[#D9A94E] transition-colors">Scopri El Brenz</a>
        <a href="/tesseramento" class="inline-block border border-[#F5EEDD]/40 text-[#F5EEDD] px-7 py-3 text-sm font-medium tracking-wider uppercase no-underline hover:border-[#C8923E] hover:text-[#C8923E] transition-colors">Diventa socio</a>
        {PAGAMENTI_LIVE && (
          <a
            href="/dona"
            class="inline-flex items-center gap-2 px-7 py-3 text-sm font-semibold tracking-wider uppercase no-underline text-[#1E2E26] rounded-full transition-all duration-150 hover:-translate-y-0.5 hover:shadow-xl"
            style="background: linear-gradient(135deg, #D9A94E 0%, #C8923E 55%, #b07f2f 100%); box-shadow: 0 4px 16px rgba(200, 146, 62, 0.4);"
          >
            <span aria-hidden="true" style="font-size: 15px;">♥</span> Sostienici
          </a>
        )}
      </div>

      <div class="pt-10 border-t border-[#F5EEDD]/15 max-w-md mx-auto">
        <p
          class="text-2xl md:text-3xl italic text-[#C8923E] mb-2"
          style="font-family: 'Playfair Display', serif;"
          lang="lld-anau"
        >
          Raìs fonde no le 'nglacia
        </p>
        <p
          class="text-xs tracking-[0.15em] uppercase text-[#F5EEDD]/55"
          style="font-family: 'Inter', sans-serif;"
        >
          Radici profonde non gelano
        </p>
      </div>

    </div>
  </section>

  <section class="bg-[#FDF9F0] py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2
        class="text-3xl md:text-5xl font-medium mb-8 leading-tight"
        style="font-family: 'Playfair Display', serif;"
      >
        Una comunità che custodisce la <em style="font-style: italic; color: #C8923E;">memoria</em>.
      </h2>
      <p
        class="text-lg text-[#0F0F0F]/80 leading-relaxed mb-4"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Fondata il 21 dicembre 2009, l'Associazione El Brenz raccoglie ricercatori,
        appassionati e abitanti delle Valli del Noce uniti dalla passione per la
        propria storia tirolese, le proprie radici linguistiche ladine, e la
        cultura materiale alpina.
      </p>
      <p
        class="text-lg text-[#0F0F0F]/80 leading-relaxed"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Pubblichiamo articoli di divulgazione storica, custodiamo archivi, organizziamo
        eventi culturali e sosteniamo il riconoscimento ufficiale del gruppo
        linguistico ladino-retico anaunico.
      </p>
    </div>
  </section>

  {/* AGGIUNTA M2.4 — blocco "Ultimi articoli": i 4 più recenti di produzione.
      Card sul pattern di ElencoArticoliPerAnno (bianche, bordo E5DFCF, hover
      oro) su sfondo avorio brand. Nessun link "tutti gli articoli": non esiste
      (ancora) una rotta indice unica — mai link rotti. */}
  <section class="bg-[#F5EEDD] py-24">
    <div class="max-w-7xl mx-auto px-6">
      <h2
        class="text-3xl md:text-5xl font-medium text-[#1E2E26] mb-12 text-center leading-tight"
        style="font-family: 'Playfair Display', serif;"
      >
        Ultimi articoli
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {ultimiArticoli.map((a) => (
          <a
            href={`/articoli/${a.id}`}
            class="group flex flex-col bg-white border border-[#E5DFCF] hover:border-[#C8923E] transition-colors p-6 no-underline"
          >
            <p
              class="text-[11px] tracking-[0.18em] uppercase text-[#C8923E] m-0 mb-2"
              style="font-family: 'Inter', sans-serif;"
            >
              <time datetime={a.data.data_pubblicazione.toISOString()}>
                {formatDataIT(a.data.data_pubblicazione)}
              </time>
              {nomePilastro(a.data.pilastro) && (
                <span class="text-[#1E2E26]/45"> · {nomePilastro(a.data.pilastro)}</span>
              )}
            </p>
            <h3
              class="text-xl text-[#1E2E26] font-medium leading-tight m-0 group-hover:text-[#C8923E] transition-colors"
              style="font-family: 'Playfair Display', serif;"
            >
              {a.data.title}
            </h3>
            {a.data.excerpt && (
              <p
                class="text-sm text-[#0F0F0F]/70 leading-relaxed m-0 mt-3"
                style="font-family: 'Source Serif 4', Georgia, serif;"
              >
                {troncaExcerpt(a.data.excerpt)}
              </p>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* AGGIUNTA M2.4 — blocco "Prossimi eventi": max 3 eventi futuri dalla
      collection eventi, con fallback testuale se non ce ne sono. */}
  <section class="bg-[#FDF9F0] py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2
        class="text-3xl md:text-5xl font-medium text-[#1E2E26] mb-12 text-center leading-tight"
        style="font-family: 'Playfair Display', serif;"
      >
        Prossimi eventi
      </h2>

      {eventiFuturi.length > 0 ? (
        <ul class="list-none m-0 p-0 flex flex-col gap-6">
          {eventiFuturi.map((e) => {
            const dc = dataCompattaEvento(e.data.data);
            return (
              <li class="flex items-stretch gap-6 bg-white border border-[#E5DFCF] p-6">
                <div
                  class="flex flex-col items-center justify-center flex-shrink-0 w-24 bg-[#C8923E]/10 border border-[#C8923E] text-[#C8923E] px-3 py-4"
                  style="font-family: 'Inter', sans-serif;"
                >
                  <time datetime={e.data.data.toISOString()} class="contents">
                    <span class="text-3xl font-semibold leading-none">{dc.giorno}</span>
                    <span class="text-xs tracking-[0.18em] mt-1.5">{dc.mese}</span>
                    <span class="text-[11px] text-[#C8923E]/75 mt-0.5">{dc.anno}</span>
                  </time>
                </div>
                <div class="min-w-0">
                  <h3
                    class="text-2xl text-[#1E2E26] font-medium leading-tight m-0"
                    style="font-family: 'Playfair Display', serif;"
                  >
                    {e.data.titolo}
                  </h3>
                  {(e.data.oraInizio || e.data.luogo) && (
                    <p
                      class="text-[12px] tracking-[0.14em] uppercase text-[#1E2E26]/55 m-0 mt-2"
                      style="font-family: 'Inter', sans-serif;"
                    >
                      {[e.data.oraInizio ? `ore ${e.data.oraInizio}` : '', e.data.luogo ?? '']
                        .filter(Boolean)
                        .join(' · ')}
                    </p>
                  )}
                  {e.data.descrizioneBreve && (
                    <p
                      class="text-[#0F0F0F]/75 leading-relaxed m-0 mt-3"
                      style="font-family: 'Source Serif 4', Georgia, serif;"
                    >
                      {e.data.descrizioneBreve}
                    </p>
                  )}
                  {e.data.link && (
                    <a
                      href={e.data.link}
                      target="_blank"
                      rel="noopener"
                      class="inline-block text-sm text-[#C8923E] no-underline hover:underline mt-3"
                      style="font-family: 'Inter', sans-serif;"
                    >
                      Maggiori informazioni →
                    </a>
                  )}
                </div>
              </li>
            );
          })}
        </ul>
      ) : (
        <div class="max-w-2xl mx-auto text-center bg-white border border-[#E5DFCF] px-8 py-12">
          <p
            class="text-lg text-[#0F0F0F]/75 leading-relaxed m-0"
            style="font-family: 'Source Serif 4', Georgia, serif;"
          >
            Nessun evento in programma al momento. Segui i nostri canali per
            gli aggiornamenti sulle prossime iniziative delle nostre valli.
          </p>
        </div>
      )}
    </div>
  </section>

  {/* AGGIUNTA 8/7/2026 — card rubrica "Una terra, cinque lingue" (UT24):
      banda identitaria che porta alla rubrica trilingue. Stessa veste
      dell'header di /una-terra-cinque-lingue (verde profondo + oro). */}
  <section class="bg-[#1E2E26] text-[#F5EEDD] py-16">
    <div class="max-w-5xl mx-auto px-6 md:flex md:items-center md:justify-between md:gap-12">
      <div class="max-w-2xl">
        <p
          class="text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium m-0 mb-4"
          style="font-family: 'Inter', sans-serif;"
        >
          Rubrica · Lingua e ladinità
        </p>
        <h2
          class="text-3xl md:text-4xl leading-tight m-0 mb-4"
          style="font-family: 'Playfair Display', serif; font-weight: 500;"
        >
          Una terra, <em class="text-[#C8923E]" style="font-style: italic;">cinque lingue</em>.
        </h2>
        <p
          class="text-base md:text-lg leading-relaxed text-[#F5EEDD]/85 m-0 mb-5"
          style="font-family: 'Source Serif 4', Georgia, serif;"
        >
          Ogni mese raccontiamo le nostre valli in <em lang="lld-anau">ladin
          anaunic</em>, italiano e tedesco — perché una terra plurilingue si
          capisce solo nelle sue lingue. In collaborazione con
          <strong>UT24 — Unser Tirol 24</strong>.
        </p>
        <p class="m-0 flex flex-wrap gap-2" style="font-family: 'Inter', sans-serif;">
          <span lang="lld-anau" class="text-[11px] tracking-[0.14em] uppercase border border-[#C8923E]/50 text-[#D9A94E] px-3 py-1">Ladin anaunic</span>
          <span lang="it" class="text-[11px] tracking-[0.14em] uppercase border border-[#F5EEDD]/25 text-[#F5EEDD]/75 px-3 py-1">Italiano</span>
          <span lang="de" class="text-[11px] tracking-[0.14em] uppercase border border-[#F5EEDD]/25 text-[#F5EEDD]/75 px-3 py-1">Deutsch</span>
        </p>
      </div>
      <div class="mt-8 md:mt-0 md:shrink-0">
        <a
          href="/una-terra-cinque-lingue"
          class="inline-block bg-[#C8923E] text-[#1E2E26] px-7 py-3 text-sm font-medium tracking-wider uppercase no-underline hover:bg-[#D9A94E] transition-colors focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C8923E]"
          style="font-family: 'Inter', sans-serif;"
        >
          Leggi la rubrica
        </a>
      </div>
    </div>
  </section>

  {/* M2.6-bis / redesign TASK 5 (8/7/2026) — card "Sostieni El Brenz":
      pannello verde su avorio con doppia cornice oro "ex libris", motto,
      tre pilastri SVG, bottone PayPal invariato su pedana avorio. Render
      SOLO a flag pagamenti attivo; porta al NOSTRO flusso /dona. */}
  {PAGAMENTI_LIVE && (
    <section class="bg-[#F5EEDD] py-16 md:py-20">
      <div class="max-w-[640px] mx-auto px-6">
        <div class="bg-[#1E2E26] border border-[#C8923E] rounded-[4px] p-[5px]">
          <div class="border border-[#C8923E]/60 rounded-[2px] px-8 py-12 md:px-12 text-center">
            <p
              class="text-lg md:text-xl italic text-[#C8923E] m-0 mb-1 leading-snug"
              style="font-family: 'Playfair Display', serif;"
              lang="lld-anau"
            >
              Raìs fonde no le 'nglacia
            </p>
            <p
              class="text-[11px] tracking-[0.18em] uppercase text-[#F5EEDD]/70 m-0 mb-7"
              style="font-family: 'Inter', sans-serif;"
            >
              Radici profonde non gelano
            </p>
            <h2
              class="text-3xl md:text-4xl font-medium text-[#F5EEDD] m-0 mb-5 leading-tight"
              style="font-family: 'Playfair Display', serif;"
            >
              Sostieni <em style="font-style: italic; color: #C8923E;">El Brenz</em>
            </h2>
            <p
              class="text-base text-[#F5EEDD]/85 leading-relaxed m-0 mb-9 max-w-md mx-auto"
              style="font-family: 'Source Serif 4', Georgia, serif;"
            >
              Ogni donazione dà forza alle ricerche, alle pubblicazioni e
              alla digitalizzazione della memoria delle nostre valli. Anche
              un piccolo gesto tiene vive le radici.
            </p>
            {/* Tre pilastri: SVG monocromi oro, etichette micro avorio. */}
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 mb-10" style="font-family: 'Inter', sans-serif;">
              <div class="flex flex-col items-center gap-2">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5.5C10.5 4.3 8.6 3.8 6.3 3.8c-1 0-1.9.1-2.8.4v14.6c.9-.3 1.8-.4 2.8-.4 2.3 0 4.2.5 5.7 1.7 1.5-1.2 3.4-1.7 5.7-1.7 1 0 1.9.1 2.8.4V4.2c-.9-.3-1.8-.4-2.8-.4-2.3 0-4.2.5-5.7 1.7Zm0 0v14.6" stroke="#C8923E" stroke-width="1.6" stroke-linejoin="round"/></svg>
                <span class="text-[11px] tracking-[0.12em] uppercase text-[#F5EEDD]/80">Ricerche e pubblicazioni</span>
              </div>
              <div class="flex flex-col items-center gap-2">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 19 9.2 8.4a1 1 0 0 1 1.7 0l2.4 4.1 1.9-2.9a1 1 0 0 1 1.7 0L21 19H3Z" stroke="#C8923E" stroke-width="1.6" stroke-linejoin="round"/><path d="m8 12.5 1.5 1.8 1.4-1.8" stroke="#C8923E" stroke-width="1.4" stroke-linejoin="round"/></svg>
                <span class="text-[11px] tracking-[0.12em] uppercase text-[#F5EEDD]/80">Memoria delle valli</span>
              </div>
              <div class="flex flex-col items-center gap-2">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v7a2.5 2.5 0 0 1-2.5 2.5H10l-4.4 3.6c-.6.5-1.6.1-1.6-.8V6.5Z" stroke="#C8923E" stroke-width="1.6"/><path d="M8 9h8M8 12h5" stroke="#C8923E" stroke-width="1.4" stroke-linecap="round"/></svg>
                <span class="text-[11px] tracking-[0.12em] uppercase text-[#F5EEDD]/80">Lingua ladina</span>
              </div>
            </div>
            {/* Pedana avorio: stacca il bottone PayPal (invariato, vincoli
                brand) dal pannello verde. */}
            <div class="inline-block bg-[#F5EEDD] rounded-[10px] px-4 sm:px-6 py-5">
              <a
                href="/dona"
                class="inline-flex items-center gap-2 whitespace-nowrap bg-[#FFC439] hover:bg-[#f2b636] transition-colors rounded-full px-5 sm:px-8 py-3.5 no-underline"
                style="font-family: 'Inter', sans-serif;"
              >
                <span class="text-base font-bold italic" aria-hidden="true">
                  <span style="color: #003087;">Pay</span><span style="color: #009cde;">Pal</span>
                </span>
                <span class="text-sm font-medium text-[#1E2E26]">Dona con PayPal o carta</span>
              </a>
            </div>
            <p class="m-0 mt-5" style="font-family: 'Inter', sans-serif;">
              <a href="/dona#bonifico" class="text-sm text-[#C8923E] no-underline hover:underline">oppure con bonifico</a>
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  {/* AGGIUNTA M2.4 — card "Community": blocco statico con CTA tesseramento.
      Nessun link alla futura app soci (non esiste ancora): solo menzione
      testuale dell'area soci in arrivo — mai link rotti o placeholder #. */}
  <section class="bg-[#1E2E26] text-[#F5EEDD] py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2
        class="text-3xl md:text-5xl font-medium mb-8 leading-tight"
        style="font-family: 'Playfair Display', serif;"
      >
        La nostra <em style="font-style: italic; color: #C8923E;">comunità</em>.
      </h2>
      <p
        class="text-lg text-[#F5EEDD]/90 leading-relaxed mb-4"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        El Brenz riunisce chi ama la storia, la lingua e la cultura delle
        nostre valli: ricercatori, appassionati e famiglie delle Valli del
        Noce, uniti dalle stesse radici.
      </p>
      <p
        class="text-lg text-[#F5EEDD]/90 leading-relaxed mb-10"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Diventando socio sostieni ricerche, pubblicazioni ed eventi che
        tengono viva la memoria dei nostri paesi. E presto arriverà anche
        un'area riservata ai soci, per ritrovarsi e partecipare online.
      </p>
      <a
        href="/tesseramento"
        class="inline-block bg-[#C8923E] text-[#1E2E26] px-8 py-3.5 text-sm font-medium tracking-wider uppercase no-underline hover:bg-[#D9A94E] transition-colors"
        style="font-family: 'Inter', sans-serif;"
      >
        Diventa socio
      </a>
      {/* AGGIUNTA go-live pagamenti (8/7/2026): link secondario /dona. */}
      {PAGAMENTI_LIVE && (
        <p class="text-sm text-[#F5EEDD]/70 m-0 mt-5" style="font-family: 'Inter', sans-serif;">
          Oppure <a href="/dona" class="text-[#C8923E] underline hover:text-[#D9A94E]">sostienici con una donazione libera</a> →
        </p>
      )}
    </div>
  </section>


  {/* M2.7/M2.9-ter — sezione "Seguici": card Migole de Storia (Instagram)
      + Facebook. Al page load NESSUNA richiesta a domini Meta: copertine
      self-hosted, l'iframe del reel vive SOLO nel lightbox (LightboxEmbed,
      consenso per categoria "embed" o cookie di sessione). Facebook =
      card interamente nostra, zero iframe (Opzione A). Copertine reali:
      caricare public/social/migole/migola-{1,2,3}.jpg e fare rebuild. */}
  <section class="bg-[#FDF9F0] py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2
        class="text-3xl md:text-5xl font-medium text-[#1E2E26] mb-4 text-center leading-tight"
        style="font-family: 'Playfair Display', serif;"
      >
        Seguici, <em style="font-style: italic; color: #C8923E;">restiamo vicini</em>.
      </h2>
      <p
        class="text-base text-[#0F0F0F]/70 text-center m-0 mb-12 max-w-xl mx-auto"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Ogni settimana la storia delle nostre valli passa anche dai social:
        piccole scoperte, foto d'archivio e appuntamenti.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white border border-[#E5DFCF] p-8 flex flex-col">
          <h3
            class="text-2xl text-[#1E2E26] font-medium leading-tight m-0 mb-2"
            style="font-family: 'Playfair Display', serif;"
          >
            Migole de Storia
          </h3>
          <p
            class="text-sm text-[#0F0F0F]/70 leading-relaxed m-0 mb-5"
            style="font-family: 'Source Serif 4', Georgia, serif;"
          >
            Briciole di storia delle nostre valli, ogni settimana su Instagram.
          </p>
          {/* M2.9-ter: copertine nostre + lightbox (gli EmbedConsenso
              inline rimossi su decisione Cristian 8/7/2026). Mobile:
              carosello orizzontale con snap; desktop: 3 colonne. */}
          {MIGOLE_POST_URLS ? (
            <div class="flex gap-3 overflow-x-auto snap-x snap-mandatory pb-2 sm:grid sm:grid-cols-3 sm:gap-3 sm:overflow-visible sm:pb-0 mb-5">
              {MIGOLE_POST_URLS.map((postUrl, i) => (
                <div class="w-[200px] min-w-[200px] snap-center sm:w-auto sm:min-w-0">
                  <LightboxEmbed
                    url={postUrl}
                    titolo={`Migola de Storia n. ${i + 1} (reel Instagram)`}
                    cover={copertinaMigola(i + 1)}
                    etichetta={MIGOLE_ETICHETTE[i]}
                    hashtag="#migoledestoria"
                  />
                </div>
              ))}
            </div>
          ) : (
            <div class="grid grid-cols-3 gap-2 mb-5">
              <img src="/social/migole/migola-01.webp" alt="Migola de Storia: la storia delle valli" width="400" height="400" loading="lazy" decoding="async" class="block w-full h-auto" />
              <img src="/social/migole/migola-02.webp" alt="Migola de Storia: le parlate ladine" width="400" height="400" loading="lazy" decoding="async" class="block w-full h-auto" />
              <img src="/social/migole/migola-03.webp" alt="Migola de Storia: memoria e radici" width="400" height="400" loading="lazy" decoding="async" class="block w-full h-auto" />
            </div>
          )}
          {/* M2.9-ter rifinitura: hashtag spostato SULLE copertine; bottoni
              delle due card gemelli (stile, altezza, focus oro, mt-auto). */}
          <a
            href="https://www.instagram.com/elbrenzass"
            target="_blank"
            rel="noopener"
            class="mt-auto inline-block self-start bg-[#C8923E] text-[#1E2E26] px-6 py-3 text-sm font-medium tracking-wider uppercase no-underline hover:bg-[#D9A94E] transition-colors focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C8923E]"
            style="font-family: 'Inter', sans-serif;"
          >
            Seguici su Instagram
          </a>
        </div>

        {/* M2.9-ter (Opzione A, decisione Cristian 8/7/2026): card
            interamente nostra, ZERO iframe/richieste verso Meta. Il Page
            Plugin è stato rimosso (rimozione esplicitamente autorizzata). */}
        <div class="bg-white border border-[#E5DFCF] p-8 flex flex-col">
          <div class="flex items-center gap-3 mb-3">
            <img
              src="/logo-eb-header.png"
              alt=""
              aria-hidden="true"
              width="40"
              height="40"
              loading="lazy"
              decoding="async"
              class="block w-10 h-10 object-contain"
            />
            <svg width="26" height="26" viewBox="0 0 24 24" aria-hidden="true" class="shrink-0">
              <path fill="#1E2E26" d="M24 12.073C24 5.446 18.627.073 12 .073S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073Z"/>
            </svg>
            <h3
              class="text-2xl text-[#1E2E26] font-medium leading-tight m-0"
              style="font-family: 'Playfair Display', serif;"
            >
              La comunità su Facebook
            </h3>
          </div>
          {/* Social proof statico — aggiornare periodicamente a mano. */}
          <p
            class="text-sm text-[#1E2E26] m-0 mb-3"
            style="font-family: 'Inter', sans-serif;"
          >
            <strong>Oltre 1.350 follower</strong>
          </p>
          <p
            class="text-sm text-[#0F0F0F]/70 leading-relaxed m-0 mb-5"
            style="font-family: 'Source Serif 4', Georgia, serif;"
          >
            Eventi, foto d'archivio e discussioni con chi ama la storia delle
            nostre valli: la piazza digitale della nosa Sociazion. Ogni
            settimana appuntamenti, ricordi dei paesi e piccole scoperte
            dagli archivi, insieme a chi le valli le vive.
          </p>
          {/* M2.9-ter rifinitura: micro-righe di sostanza (SVG sobri, niente
              emoji) per bilanciare la colonna. */}
          <ul class="list-none p-0 m-0 mb-6 flex flex-col gap-2.5" style="font-family: 'Inter', sans-serif;">
            <li class="flex items-center gap-2.5 text-sm text-[#1E2E26]/85">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0"><path d="M4 8a2 2 0 0 1 2-2h1.2l1-1.6A1 1 0 0 1 9.1 4h5.8a1 1 0 0 1 .9.4l1 1.6H18a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8Z" stroke="#C8923E" stroke-width="1.6"/><circle cx="12" cy="12.5" r="3.2" stroke="#C8923E" stroke-width="1.6"/></svg>
              Foto d'archivio dei nostri paesi
            </li>
            <li class="flex items-center gap-2.5 text-sm text-[#1E2E26]/85">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0"><rect x="4" y="5" width="16" height="15" rx="2" stroke="#C8923E" stroke-width="1.6"/><path d="M4 9.5h16M8.5 3.5v3M15.5 3.5v3" stroke="#C8923E" stroke-width="1.6"/></svg>
              Eventi e rievocazioni in valle
            </li>
            <li class="flex items-center gap-2.5 text-sm text-[#1E2E26]/85">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0"><path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v7a2.5 2.5 0 0 1-2.5 2.5H10l-4.4 3.6c-.6.5-1.6.1-1.6-.8V6.5Z" stroke="#C8923E" stroke-width="1.6"/></svg>
              Ricordi e discussioni con la comunità
            </li>
          </ul>
          <a
            href="https://www.facebook.com/ASSOCIAZIONELBRENZ"
            target="_blank"
            rel="noopener"
            class="mt-auto inline-block self-start bg-[#C8923E] text-[#1E2E26] px-6 py-3 text-sm font-medium tracking-wider uppercase no-underline hover:bg-[#D9A94E] transition-colors focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C8923E]"
            style="font-family: 'Inter', sans-serif;"
          >
            Seguici su Facebook
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>
