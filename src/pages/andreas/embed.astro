---
/**
 * /andreas/embed — chat Andreas MINIMALE, senza il Layout del sito (niente
 * header/footer/cookie banner), pensata per essere inglobata in un iframe
 * dall'app della community (AndreasPopup). Stessa origin elbrenz.eu → la edge
 * andreas-chat resta INTOCCABILE e la sua CORS non serve (chiamata same-origin).
 * Rende la chat brandizzata (avorio, bolle, benvenuto, input) che già esiste:
 * riusa AndreasChat compatto + andreas-chat.js/css, zero logica nuova.
 *
 * L'header (avatar + nome + X) lo mette il popup dell'app: qui c'è solo la chat.
 */
import AndreasChat from '../../components/andreas/AndreasChat.astro';
export const prerender = true;
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Andreas</title>
  <style is:global>
    :root { color-scheme: light; }
    html, body { margin: 0; padding: 0; height: 100%; background: #F5EEDD; }
    body { overflow: hidden; }
    /* La chat riempie il viewport dell'iframe: header assente, area messaggi
       flessibile e scrollabile, composer fisso in fondo (safe-area inclusa). */
    #andreas-embed {
      display: flex; flex-direction: column;
      height: 100dvh; min-height: 0;
      background: #F5EEDD;
      padding: 0 12px env(safe-area-inset-bottom);
      box-sizing: border-box;
    }
    #andreas-embed .andreas-chat {
      max-width: none; margin: 0; padding: 0;
      display: flex; flex-direction: column;
      flex: 1; height: 100%; min-height: 0;
    }
    #andreas-embed .andreas-chat__messages {
      flex: 1 1 0; min-height: 120px;
      overflow-y: auto; overscroll-behavior: contain;
      -webkit-overflow-scrolling: touch;
    }
    #andreas-embed .andreas-chat__hint-tasti { display: none; }
    #andreas-embed .andreas-chat__meta {
      display: flex; justify-content: space-between; align-items: baseline;
      gap: 8px; font-size: 11px;
    }
  </style>
</head>
<body>
  <div id="andreas-embed">
    <AndreasChat compatto />
  </div>
  <script src="/scripts/andreas-chat.js" type="module" is:inline></script>
</body>
</html>
