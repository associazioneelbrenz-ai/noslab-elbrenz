---
/**
 * /integrazione/{codice} — integrazione quota 2026 (10 → 20 €) per i soci
 * storici che hanno versato 10 € sui registri (delibera CD).
 *
 * SSR: il codice tessera (HMAC non enumerabile, stesso di /tessera/{codice},
 * nel PATH — mai query string) identifica il socio via RPC tessera_verifica.
 * L'importo di 10 € è FISSATO SERVER-SIDE in paypal-create-order (tipo
 * 'integrazione'): questa pagina non invia importi, solo il codice.
 */

import { createClient } from '@supabase/supabase-js';
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
const SUPABASE_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;
const CREATE_ORDER_URL = `${SUPABASE_URL}/functions/v1/paypal-create-order`;
const CAPTURE_ORDER_URL = `${SUPABASE_URL}/functions/v1/paypal-capture-order`;
// Client ID pubblico dell'app REST "El Brenz Tesseramento" (come /dona).
const PAYPAL_CLIENT_ID = 'AYz2660-eybOrnWhf2NleXBBE2FRM_eul8rOcWrU2UVVNoZl7fVvSJc1GPwUL2wgh64lSCKfaEkKZlaC';

Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');
Astro.response.headers.set('Cache-Control', 'no-store');

const codice = Astro.params.codice ?? '';
const codiceValido = /^\d{1,6}-\d{4}-[0-9a-f]{24}$/.test(codice);

type Tessera = { nome: string; numero_tessera: number; anno: number; stato: string };
let tessera: Tessera | null = null;
if (codiceValido) {
  try {
    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON, { auth: { persistSession: false } });
    const { data } = await supabase.rpc('tessera_verifica', { codice });
    tessera = (data && data.length > 0) ? (data[0] as Tessera) : null;
  } catch (e) {
    console.error('[integrazione] verifica fallita:', e);
  }
}
---

<Layout title="Integrazione quota 2026" description="Integrazione della quota sociale 2026 — Associazione El Brenz.">
  <section class="bg-[#F8F1E4] py-12 px-4 min-h-[70vh]">
    <div class="max-w-xl mx-auto">
      {tessera ? (
        <div
          class="bg-[#F5EEDD] rounded-md border border-[#C8923E]/50 p-8 md:p-10"
          id="integrazione-box"
          data-create-url={CREATE_ORDER_URL}
          data-capture-url={CAPTURE_ORDER_URL}
          data-paypal-client-id={PAYPAL_CLIENT_ID}
          data-codice={codice}
        >
          <p class="text-[#C8923E] uppercase tracking-[.2em] text-xs font-semibold mb-2 text-center">El Brenz · Tesseramento 2026</p>
          <h1 class="text-2xl md:text-3xl text-[#1E2E26] text-center m-0 mb-2" style="font-family: 'Playfair Display', serif; font-weight: 500;">
            Integrazione quota 2026
          </h1>
          <div class="w-14 h-[2px] bg-[#C8923E] mx-auto mb-6" aria-hidden="true"></div>
          <p class="text-[#1E2E26]/85 leading-relaxed mb-4" style="font-family: 'Source Serif 4', Georgia, serif;">
            Ciao <strong>{tessera.nome}</strong> (tessera n. {tessera.numero_tessera}): la quota
            sociale 2026 è passata da 10 a 20 € — un contributo necessario per
            coprire i costi delle nuove attività della <em>nosa Sociazion</em>:
            la piattaforma digitale, la tessera con verifica QR, le convenzioni
            per i soci e l'assistente storico Andreas.
          </p>
          <p class="text-[#1E2E26]/85 leading-relaxed mb-6" style="font-family: 'Source Serif 4', Georgia, serif;">
            Hai già versato 10 € per il 2026: qui puoi integrare i
            <strong>10 € mancanti</strong> in modo sicuro con PayPal o carta.
          </p>
          <div id="paypal-integrazione-buttons" class="max-w-sm mx-auto"></div>
          <div id="integrazione-esito" class="hidden mt-5 px-4 py-3 border-l-4 text-sm" style="font-family: 'Inter', sans-serif;"></div>
          <p class="text-xs text-[#1E2E26]/55 mt-6 text-center" style="font-family: 'Inter', sans-serif;">
            Preferisci il bonifico o hai domande? Scrivici a <a href="mailto:info@elbrenz.eu" class="underline">info@elbrenz.eu</a>.
          </p>
        </div>
      ) : (
        <div class="rounded-2xl bg-white border-t-4 border-[#C8923E] shadow-lg px-8 py-10 text-center">
          <p class="text-[#C8923E] uppercase tracking-[.18em] text-xs font-semibold mb-2">El Brenz · Tesseramento</p>
          <h1 class="font-serif text-2xl text-[#1E2E26] mb-3">Link non valido</h1>
          <p class="text-[#1E2E26]/70">Il codice non corrisponde ad alcuna tessera. Controlla il link ricevuto via email o scrivi a <a href="mailto:info@elbrenz.eu" class="underline">info@elbrenz.eu</a>.</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script is:inline>
  // Integrazione quota: l'importo NON parte da qui — la edge function lo
  // fissa a 10,00 € per il tipo 'integrazione'; il client invia solo il
  // codice tessera.
  (function () {
    const box = document.getElementById('integrazione-box');
    if (!box) return;
    const createUrl = box.dataset.createUrl;
    const captureUrl = box.dataset.captureUrl;
    const clientId = box.dataset.paypalClientId;
    const codice = box.dataset.codice;
    const esito = document.getElementById('integrazione-esito');

    function mostraEsito(msg, ok) {
      if (!esito) return;
      esito.classList.remove('hidden');
      esito.style.background = ok ? '#eaf3ee' : '#fbecec';
      esito.style.borderLeftColor = ok ? '#1d4d3a' : '#a33';
      esito.style.color = '#1E2E26';
      esito.textContent = msg;
    }

    const sdk = document.createElement('script');
    sdk.src = 'https://www.paypal.com/sdk/js?client-id=' + encodeURIComponent(clientId) +
      '&currency=EUR&intent=capture&components=buttons&enable-funding=card&locale=it_IT';
    sdk.onload = () => {
      if (!window.paypal) return;
      window.paypal.Buttons({
        createOrder: async () => {
          const resp = await fetch(createUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ tipo: 'integrazione', codice: codice }),
          });
          const data = await resp.json();
          if (!resp.ok || !data.id) {
            mostraEsito(data.error || 'Errore nella preparazione del pagamento.', false);
            throw new Error(data.error || 'createOrder failed');
          }
          return data.id;
        },
        onApprove: async (data) => {
          const resp = await fetch(captureUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderID: data.orderID }),
          });
          const out = await resp.json();
          if (resp.ok && out.success) {
            mostraEsito('Integrazione ricevuta, grazie! La tua quota 2026 è ora completa. Raìs fonde no le \'nglacia.', true);
          } else {
            mostraEsito(out.error || 'Il pagamento non risulta completato. Scrivici a info@elbrenz.eu.', false);
          }
        },
        onError: () => {
          mostraEsito('Si è verificato un errore col pagamento. Riprova, oppure scrivici a info@elbrenz.eu.', false);
        },
      }).render('#paypal-integrazione-buttons');
    };
    document.head.appendChild(sdk);
  })();
</script>
