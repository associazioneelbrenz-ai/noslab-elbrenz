---
/**
 * Tesseramento — Pagina pubblica per diventare socio
 *
 * Struttura:
 *   - Hero identitario
 *   - Sezione "Cosa offre la nosa Sociazion al socio"
 *   - Sezione bonifico bancario (IBAN evidenziato)
 *   - Form contatto (passa per /functions/v1/contact-form)
 *
 * Form anti-abuse:
 *   - Honeypot field nascosto via CSS
 *   - _ts timestamp di apertura (server respinge se < 3s)
 *   - Validazione client + server
 *   - Feedback inline
 *
 * M.A.2.5
 */

import Layout from '../layouts/Layout.astro';
import { PAGAMENTI_LIVE } from '../lib/pagamenti';

// URL edge function — letta da env per dev/prod
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'https://wacknihvdjxltiqvxtqr.supabase.co';
const CONTACT_FORM_URL = `${SUPABASE_URL}/functions/v1/contact-form`;

// M2.6 — pagamento quota con PayPal (SDK caricato SOLO su questa pagina).
// Client ID pubblico per design (app REST "El Brenz Tesseramento",
// verificato contro l'SDK il 7/7/2026). L'importo della quota è fissato
// LATO SERVER dalla edge function: il client non decide mai la cifra.
const PAYPAL_CREATE_URL = `${SUPABASE_URL}/functions/v1/paypal-create-order`;
const PAYPAL_CAPTURE_URL = `${SUPABASE_URL}/functions/v1/paypal-capture-order`;
const PAYPAL_CLIENT_ID = 'AYz2660-eybOrnWhf2NleXBBE2FRM_eul8rOcWrU2UVVNoZl7fVvSJc1GPwUL2wgh64lSCKfaEkKZlaC';

// M2.6-bis: URL edge fn ricevute (upload + OCR, stato in_verifica).
const RICEVUTA_URL = `${SUPABASE_URL}/functions/v1/ricevuta-ocr`;
---
<Layout
  title="Diventa socio"
  description="Diventa socio dell'Associazione El Brenz. Quota sociale annuale 20€. Sostieni la salvaguardia della lingua ladino-anaunica e della storia delle Valli del Noce."
>

  <section class="bg-[#1E2E26] text-[#F5EEDD] py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <span
        class="inline-block bg-[#C8923E]/15 border border-[#C8923E] text-[#C8923E] px-4 py-1.5 text-[11px] font-medium tracking-[0.2em] uppercase mb-8"
        style="font-family: 'Inter', sans-serif;"
      >
        Tesseramento
      </span>
      <h1
        class="text-4xl md:text-6xl font-medium leading-[1.1] tracking-tight mb-8"
        style="font-family: 'Playfair Display', serif;"
      >
        Diventa socio della <em class="text-[#C8923E]" style="font-style: italic;">nosa Sociazion</em>.
      </h1>
      <p
        class="text-lg md:text-xl text-[#F5EEDD]/90 max-w-2xl mx-auto leading-relaxed"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Sostieni la custodia della lingua ladino-anaunica, della storia tirolese
        delle Valli del Noce e della cultura materiale alpina.
      </p>
    </div>
  </section>

  <section class="bg-[#FDF9F0] py-20">
    <div class="max-w-4xl mx-auto px-6">
      <h2
        class="text-3xl md:text-4xl font-medium mb-12 leading-tight text-center"
        style="font-family: 'Playfair Display', serif;"
      >
        Cosa significa essere <em style="font-style: italic; color: #C8923E;">socio</em>.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div>
          <h3 class="text-[11px] tracking-[0.22em] uppercase text-[#C8923E] font-medium mb-3" style="font-family: 'Inter', sans-serif;">Ricerca e divulgazione</h3>
          <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
            Sostieni gli articoli, gli archivi digitali e gli studi sulla parlata
            <em>noneso</em>, <em>solander</em>, <em>rabies</em> e <em>pegaes</em>.
          </p>
        </div>

        <div>
          <h3 class="text-[11px] tracking-[0.22em] uppercase text-[#C8923E] font-medium mb-3" style="font-family: 'Inter', sans-serif;">Eventi e rievocazioni</h3>
          <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
            Partecipi alle gite sociali, alle serate storiche, ai concorsi
            culturali e alle commemorazioni delle ricorrenze tirolesi.
          </p>
        </div>

        <div>
          <h3 class="text-[11px] tracking-[0.22em] uppercase text-[#C8923E] font-medium mb-3" style="font-family: 'Inter', sans-serif;">Lunari e pubblicazioni</h3>
          <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
            Ricevi i lunari annuali, le pubblicazioni dell'Associazione e
            l'invito agli eventi riservati ai soci.
          </p>
        </div>

        <div>
          <h3 class="text-[11px] tracking-[0.22em] uppercase text-[#C8923E] font-medium mb-3" style="font-family: 'Inter', sans-serif;">Una comunità</h3>
          <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
            Diventi parte di una rete di ricercatori, appassionati e abitanti
            delle Valli uniti dalla cura per <em>la nosa storia</em>.
          </p>
        </div>

        {/* AGGIUNTA M5.0 v2 — rimando alle convenzioni soci. */}
        <div>
          <h3 class="text-[11px] tracking-[0.22em] uppercase text-[#C8923E] font-medium mb-3" style="font-family: 'Inter', sans-serif;">Convenzioni</h3>
          <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
            Accedi alle <a href="/convenzioni" class="text-[#C8923E] no-underline hover:underline">convenzioni riservate ai soci</a>:
            vantaggi presso rifugi, locali e realtà delle valli, su presentazione
            della tessera.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* M2.R (redesign chiarezza, eccezione autorizzata da Cristian): quota
      20€ ben evidente + percorso in 3 passi numerati. Solo copy/struttura/
      layout: la logica di invio del modulo è INVARIATA. */}
  <section class="bg-[#F8F1E4] py-20">
    <div class="max-w-3xl mx-auto px-6">
      <h2
        class="text-3xl md:text-4xl font-medium mb-10 leading-tight text-center"
        style="font-family: 'Playfair Display', serif;"
      >
        Come diventare socio
      </h2>

      <div class="bg-[#1E2E26] text-center px-8 py-10 mb-14">
        <p class="text-[12px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium m-0 mb-3" style="font-family: 'Inter', sans-serif;">
          Quota sociale annuale
        </p>
        <p class="text-5xl md:text-6xl text-[#F5EEDD] font-medium m-0" style="font-family: 'Playfair Display', serif;">
          20 <span class="text-[#C8923E]">€</span>
        </p>
        <p class="text-sm text-[#F5EEDD]/70 m-0 mt-3" style="font-family: 'Inter', sans-serif;">
          Vale per tutto l'anno solare. Bastano tre minuti in tutto.
        </p>
      </div>

      <ol class="list-none m-0 p-0 space-y-8">

        <li class="bg-white border border-[#E5DFCF] p-8 md:p-10">
          <div class="flex items-start gap-5">
            <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-[#C8923E] text-[#1E2E26] text-2xl font-semibold rounded-full" style="font-family: 'Playfair Display', serif;" aria-hidden="true">1</span>
            <div>
              <h3 class="text-xl md:text-2xl text-[#1E2E26] font-medium m-0 mb-3" style="font-family: 'Playfair Display', serif;">
                Compila il modulo qui sotto
              </h3>
              <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0 mb-4" style="font-family: 'Source Serif 4', Georgia, serif;">
                Ti chiediamo solo i dati che servono per la domanda di
                iscrizione: nome, email e pochi dati anagrafici. Due minuti,
                niente di complicato.
              </p>
              <a href="#modulo" class="inline-block text-sm font-medium text-[#C8923E] no-underline hover:underline" style="font-family: 'Inter', sans-serif;">
                Vai al modulo ↓
              </a>
            </div>
          </div>
        </li>

        <li class="bg-white border border-[#E5DFCF] p-8 md:p-10">
          <div class="flex items-start gap-5">
            <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-[#C8923E] text-[#1E2E26] text-2xl font-semibold rounded-full" style="font-family: 'Playfair Display', serif;" aria-hidden="true">2</span>
            <div class="min-w-0 flex-1">
              <h3 class="text-xl md:text-2xl text-[#1E2E26] font-medium m-0 mb-3" style="font-family: 'Playfair Display', serif;">
                Versa la quota di 20 €
              </h3>
              <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0 mb-6" style="font-family: 'Source Serif 4', Georgia, serif;">
                Con un bonifico bancario dal tuo home banking o allo sportello:
              </p>

              <div class="bg-[#FDF9F0] border-l-4 border-[#C8923E] p-5 mb-4" style="font-family: 'Inter', sans-serif;">
                <p class="text-[11px] tracking-[0.15em] uppercase text-[#0F0F0F]/55 font-medium m-0 mb-2">IBAN</p>
                <p class="font-mono text-sm md:text-base text-[#1E2E26] m-0 tracking-wider break-all">IT84U0816335010000190116255</p>
                <p class="text-sm text-[#1E2E26]/80 m-0 mt-3 leading-relaxed">
                  Cassa Rurale Val di Sole, filiale Mezzana<br/>
                  intestato ad <strong>Associazione El Brenz</strong>
                </p>
              </div>

              <div class="bg-[#FDF9F0] border-l-4 border-[#C8923E] p-5 mb-6" style="font-family: 'Inter', sans-serif;">
                <p class="text-[11px] tracking-[0.15em] uppercase text-[#0F0F0F]/55 font-medium m-0 mb-2">Causale (scrivila così)</p>
                <p class="text-sm md:text-base text-[#1E2E26] m-0"><em>Quota sociale 2026 – Nome Cognome</em></p>
              </div>

              <p id="paypal-quota-presto" class="text-sm text-[#0F0F0F]/60 leading-relaxed m-0" style="font-family: 'Inter', sans-serif;">
                Presto potrai pagare qui anche con <strong>PayPal o carta di
                credito/debito</strong> (senza bisogno di un conto PayPal):
                stiamo attivando il servizio.
              </p>

              {/* M2.6: pagamento quota con PayPal/carta. Nascosto finché
                  Cristian non completa il test reale: si attiva SOLO con
                  ?paypal=1 nell'URL (vedi script in fondo). Al go-live basta
                  mettere PAGAMENTI_LIVE a true in src/lib/pagamenti.ts. */}
              <div
                id="paypal-quota-box"
                class="hidden border-t border-[#E5DFCF] mt-6 pt-6"
                data-create-url={PAYPAL_CREATE_URL}
                data-capture-url={PAYPAL_CAPTURE_URL}
                data-paypal-client-id={PAYPAL_CLIENT_ID}
                data-live={PAGAMENTI_LIVE ? '1' : '0'}
              >
                <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0 mb-4" style="font-family: 'Source Serif 4', Georgia, serif;">
                  Oppure paga subito qui i 20 € con <strong>PayPal o carta di
                  credito/debito</strong> — non serve avere un conto PayPal:
                </p>
                <div id="paypal-quota-buttons"></div>
                <div
                  id="paypal-quota-esito"
                  class="hidden mt-4 p-4 text-sm border-l-4"
                  role="status"
                  aria-live="polite"
                  style="font-family: 'Inter', sans-serif;"
                ></div>
              </div>
            </div>
          </div>
        </li>

        <li class="bg-white border border-[#E5DFCF] p-8 md:p-10">
          <div class="flex items-start gap-5">
            <span class="flex-shrink-0 w-12 h-12 flex items-center justify-center bg-[#C8923E] text-[#1E2E26] text-2xl font-semibold rounded-full" style="font-family: 'Playfair Display', serif;" aria-hidden="true">3</span>
            <div>
              <h3 class="text-xl md:text-2xl text-[#1E2E26] font-medium m-0 mb-3" style="font-family: 'Playfair Display', serif;">
                Cosa succede dopo
              </h3>
              <p class="text-base text-[#0F0F0F]/80 leading-relaxed m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
                La tua domanda viene esaminata dal Consiglio Direttivo, come
                previsto dallo <a href="/statuto" class="text-[#C8923E] no-underline hover:underline">Statuto</a>.
                Riceverai la conferma via email da
                <strong>info@elbrenz.eu</strong> — non devi fare altro.
              </p>
              {/* AGGIUNTA go-live pagamenti (8/7/2026): link a /dona. */}
              {PAGAMENTI_LIVE && (
                <p class="text-sm text-[#0F0F0F]/70 leading-relaxed m-0 mt-4" style="font-family: 'Inter', sans-serif;">
                  Vuoi fare qualcosa in più per le nostre valli? Oltre alla
                  quota puoi <a href="/dona" class="text-[#C8923E] no-underline hover:underline">sostenerci con una donazione libera</a>.
                </p>
              )}
            </div>
          </div>
        </li>

      </ol>
    </div>
  </section>

  <section id="modulo" class="bg-[#1E2E26] text-[#F5EEDD] py-20">
    <div class="max-w-2xl mx-auto px-6">
      <h2
        class="text-3xl md:text-4xl font-medium mb-3 leading-tight text-center"
        style="font-family: 'Playfair Display', serif;"
      >
        Il modulo di <em class="text-[#C8923E]" style="font-style: italic;">iscrizione.</em>
      </h2>
      <p
        class="text-base text-[#F5EEDD]/75 text-center mb-3"
        style="font-family: 'Inter', sans-serif;"
      >
        È il <strong>passo 1</strong>: compila e invia. Ti rispondiamo da <strong>info@elbrenz.eu</strong>.
      </p>
      <p
        class="text-sm text-[#F5EEDD]/60 text-center mb-12"
        style="font-family: 'Inter', sans-serif;"
      >
        Tutti i campi sono obbligatori. Se qualcosa non è chiaro, in fondo
        alla pagina trovi come contattarci.
      </p>

      <form
        id="contact-form"
        class="bg-[#0F1D18] p-8 md:p-10"
        novalidate
        data-endpoint={CONTACT_FORM_URL}
      >
        <div class="mb-6">
          <label for="cf-nome" class="block text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-2" style="font-family: 'Inter', sans-serif;">Nome e cognome</label>
          <input
            type="text"
            id="cf-nome"
            name="nome"
            required
            minlength="2"
            maxlength="100"
            autocomplete="name"
            class="w-full bg-[#1E2E26] border border-[#F5EEDD]/20 text-[#F5EEDD] px-4 py-3 text-base focus:outline-none focus:border-[#C8923E] transition-colors"
            style="font-family: 'Inter', sans-serif;"
          />
        </div>

        <div class="mb-6">
          <label for="cf-email" class="block text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-2" style="font-family: 'Inter', sans-serif;">Email</label>
          <input
            type="email"
            id="cf-email"
            name="email"
            required
            maxlength="200"
            autocomplete="email"
            class="w-full bg-[#1E2E26] border border-[#F5EEDD]/20 text-[#F5EEDD] px-4 py-3 text-base focus:outline-none focus:border-[#C8923E] transition-colors"
            style="font-family: 'Inter', sans-serif;"
          />
        </div>

        <div class="mb-6">
          <label for="cf-messaggio" class="block text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-2" style="font-family: 'Inter', sans-serif;">Il tuo messaggio</label>
          <p class="text-xs text-[#F5EEDD]/60 mb-2 mt-0" style="font-family: 'Inter', sans-serif;">
            Ad esempio: "Vorrei diventare socio per il 2026". Va bene anche una
            domanda o due righe su di te.
          </p>
          <textarea
            id="cf-messaggio"
            name="messaggio"
            required
            minlength="10"
            maxlength="2000"
            rows="5"
            class="w-full bg-[#1E2E26] border border-[#F5EEDD]/20 text-[#F5EEDD] px-4 py-3 text-base focus:outline-none focus:border-[#C8923E] transition-colors resize-y"
            style="font-family: 'Inter', sans-serif;"
          ></textarea>
        </div>

        <!-- Sezione Dati Anagrafici (utili per pre-compilare la futura iscrizione formale) -->
        <div class="border-t border-[#F5EEDD]/15 mt-8 pt-8 mb-2">
          <h3 class="text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-2" style="font-family: 'Inter', sans-serif;">Dati anagrafici</h3>
          <p class="text-xs text-[#F5EEDD]/60 mb-6 leading-relaxed" style="font-family: 'Inter', sans-serif;">
            Ci aiutano a pre-compilare la tua futura iscrizione formale.
          </p>
        </div>

        <div class="mb-6">
          <label for="cf-data-nascita" class="block text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-2" style="font-family: 'Inter', sans-serif;">Data di nascita (giorno/mese/anno)</label>
          <input
            type="date"
            id="cf-data-nascita"
            name="data_nascita"
            required
            min="1900-01-01"
            class="w-full bg-[#1E2E26] border border-[#F5EEDD]/20 text-[#F5EEDD] px-4 py-3 text-base focus:outline-none focus:border-[#C8923E] transition-colors"
            style="font-family: 'Inter', sans-serif; color-scheme: dark;"
          />
        </div>

        <div class="mb-6">
          <label for="cf-comune-nascita" class="block text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-2" style="font-family: 'Inter', sans-serif;">Comune di nascita</label>
          <input
            type="text"
            id="cf-comune-nascita"
            name="comune_nascita"
            required
            minlength="2"
            maxlength="100"
            placeholder="Es. Cles, Malé, Pejo"
            class="w-full bg-[#1E2E26] border border-[#F5EEDD]/20 text-[#F5EEDD] px-4 py-3 text-base focus:outline-none focus:border-[#C8923E] transition-colors placeholder:text-[#F5EEDD]/30"
            style="font-family: 'Inter', sans-serif;"
          />
          <p class="text-xs text-[#F5EEDD]/45 mt-2" style="font-family: 'Inter', sans-serif;">Se nato all'estero, scrivi nome dello stato</p>
        </div>

        <div class="mb-8">
          <span class="block text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium mb-3" style="font-family: 'Inter', sans-serif;">Sesso</span>
          <div class="flex gap-6" style="font-family: 'Inter', sans-serif;">
            <label class="flex items-center gap-2 cursor-pointer text-[#F5EEDD]">
              <input type="radio" name="sesso" value="M" required class="w-4 h-4 accent-[#C8923E]" />
              <span class="text-sm">Maschile</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer text-[#F5EEDD]">
              <input type="radio" name="sesso" value="F" required class="w-4 h-4 accent-[#C8923E]" />
              <span class="text-sm">Femminile</span>
            </label>
          </div>
        </div>

        <!-- GDPR: informativa inline + checkbox consenso -->
        <div class="bg-[#0F1D18] border border-[#F5EEDD]/10 p-5 mb-6">
          <p class="text-xs text-[#F5EEDD]/70 leading-relaxed mb-4 m-0" style="font-family: 'Inter', sans-serif;">
            I dati raccolti (nome, email, data e luogo di nascita, sesso, messaggio) saranno trattati dall'Associazione El Brenz al solo scopo di rispondere alla tua richiesta e pre-compilare la tua futura iscrizione formale. Conserviamo i dati su email criptata fino a registrazione formale o cancellazione su richiesta. Se scegli il bonifico e carichi la ricevuta, il documento (che può riportare dati bancari) è conservato in un archivio privato al solo scopo di verificare il pagamento, fino alla conferma e comunque non oltre 12 mesi; cancellazione anticipata su richiesta. Per cancellare i dati scrivi a <a href="mailto:info@elbrenz.eu" class="text-[#D9A94E] no-underline hover:underline">info@elbrenz.eu</a>. <a href="/privacy" target="_blank" rel="noopener" class="text-[#D9A94E] no-underline hover:underline">Informativa privacy completa →</a>
          </p>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="cf-gdpr" name="gdpr" required class="mt-0.5 w-4 h-4 accent-[#C8923E] flex-shrink-0" />
            <span class="text-sm text-[#F5EEDD] leading-relaxed" style="font-family: 'Inter', sans-serif;">
              Ho letto e accetto l'informativa privacy
            </span>
          </label>
        </div>

        <!-- Honeypot: nascosto via CSS, deve restare vuoto -->
        <div aria-hidden="true" style="position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden;">
          <label for="cf-website">Website (lascia vuoto)</label>
          <input type="text" id="cf-website" name="_honeypot" tabindex="-1" autocomplete="off" />
        </div>

        <button
          type="submit"
          id="cf-submit"
          class="w-full bg-[#C8923E] text-[#1E2E26] px-6 py-3.5 text-sm font-medium tracking-wider uppercase hover:bg-[#D9A94E] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          style="font-family: 'Inter', sans-serif;"
        >
          Invia la domanda — passo 1 di 3
        </button>

        <div
          id="cf-feedback"
          class="hidden mt-6 p-4 text-sm"
          role="status"
          aria-live="polite"
          style="font-family: 'Inter', sans-serif;"
        ></div>
      </form>


      {/* M2.6-bis: selettore metodo di pagamento — compare dopo l'invio
          riuscito del modulo (PASSO 2 come scelta guidata). Il bonifico è
          SEMPRE attivo e indipendente dal ramo PayPal; PayPal si attiva col
          flag go-live (o ?paypal=1 per i test); Satispay è un placeholder
          disattivato (fase 2, dipende dall'account Business). */}
      <div id="scelta-pagamento" class="hidden mt-10" data-ricevuta-url={RICEVUTA_URL}>
        <h3
          class="text-2xl text-[#F5EEDD] font-medium leading-tight m-0 mb-2 text-center"
          style="font-family: 'Playfair Display', serif;"
        >
          Passo 2 — versa la quota di 20 €
        </h3>
        <p class="text-sm text-[#F5EEDD]/70 text-center m-0 mb-6" style="font-family: 'Inter', sans-serif;">
          Scegli come preferisci pagare:
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6" style="font-family: 'Inter', sans-serif;">
          <button
