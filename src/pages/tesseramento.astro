  {/* M2.6: script pagamento quota PayPal — gate di attivazione.
      PAGAMENTI_LIVE (src/lib/pagamenti.ts) spento finché Cristian non completa il test reale:
      il blocco compare SOLO con ?paypal=1 nell'URL. Al go-live: true. */}
  <script is:inline>
    (function () {
      const box = document.getElementById('paypal-quota-box');
      const presto = document.getElementById('paypal-quota-presto');
      if (!box) return;
      // Flag condiviso (src/lib/pagamenti.ts, build time) via data attribute;
      // ?paypal=1 resta come gate di test pre go-live.
      const gate = box.dataset.live === '1' ||
        new URLSearchParams(window.location.search).get('paypal') === '1';
      if (!gate) return;

      box.classList.remove('hidden');
      if (presto) presto.style.display = 'none';

      const esito = document.getElementById('paypal-quota-esito');
      function mostraEsito(msg, ok) {
        if (!esito) return;
        esito.classList.remove('hidden');
        esito.style.background = ok ? '#eaf3ee' : '#fbecec';
        esito.style.borderLeftColor = ok ? '#1d4d3a' : '#a33';
        esito.style.color = '#1E2E26';
        esito.textContent = msg;
      }

      // Il ramo PayPal è VOLUTAMENTE isolato: qualunque errore dell'SDK non
      // deve mai impedire il feedback del modulo né le istruzioni bonifico
      // (che stanno fuori da questo script). try/catch difensivo (M2.6 fix).
      const sdk = document.createElement('script');
      sdk.src = 'https://www.paypal.com/sdk/js?client-id=' +
        encodeURIComponent(box.dataset.paypalClientId) +
        '&currency=EUR&intent=capture&components=buttons&enable-funding=card&locale=it_IT';
      sdk.onerror = () => {
        mostraEsito('Il pagamento con carta non è al momento disponibile: usa il bonifico qui sopra.', false);
      };
      sdk.onload = () => {
        try {
        if (!window.paypal) return;
        window.paypal.Buttons({
          createOrder: async () => {
            // tipo 'quota': l'importo (20.00 EUR) lo fissa il server.
            // Nome/email: dai campi se compilati, altrimenti dal dataset del
            // selettore (il form si resetta dopo l'invio) — servono per
            // agganciare il pagamento alla domanda (M2.6-ter).
            const nomeCampo = document.getElementById('cf-nome');
            const emailCampo = document.getElementById('cf-email');
            const scelta = document.getElementById('scelta-pagamento');
            const resp = await fetch(box.dataset.createUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                tipo: 'quota',
                nome: (nomeCampo && nomeCampo.value) || (scelta && scelta.dataset.nome) || '',
                email: (emailCampo && emailCampo.value) || (scelta && scelta.dataset.email) || '',
              }),
            });
            const data = await resp.json();
            if (!resp.ok || !data.id) {
              mostraEsito(data.error || 'Errore nella preparazione del pagamento.', false);
              throw new Error(data.error || 'createOrder failed');
            }
            return data.id;
          },
          onApprove: async (data) => {
            const resp = await fetch(box.dataset.captureUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ orderID: data.orderID }),
            });
            const out = await resp.json();
            if (resp.ok && out.success) {
              mostraEsito('Quota ricevuta, grazie! Riceverai conferma dal Direttivo via email. Ricorda anche il passo 1: se non l\'hai già fatto, compila il modulo qui sotto.', true);
            } else {
              mostraEsito(out.error || 'Il pagamento non risulta completato. Scrivici a info@elbrenz.eu.', false);
            }
          },
          onError: () => {
            mostraEsito('Si è verificato un errore col pagamento. Riprova, oppure usa il bonifico qui sopra.', false);
          },
        }).render('#paypal-quota-buttons');
        } catch (err) {
          console.error('[paypal-quota] SDK render fallito:', err);
          mostraEsito('Il pagamento con carta non è al momento disponibile: usa il bonifico qui sopra.', false);
        }
      };
      document.head.appendChild(sdk);
    })();
  </script>

  <script is:inline>
    (function () {
      const scelta = document.getElementById('scelta-pagamento');
      if (!scelta) return;
      const btnPaypal = document.getElementById('sp-paypal');
      const btnBonifico = document.getElementById('sp-bonifico');
      const pannelloBonifico = document.getElementById('sp-pannello-bonifico');
      const boxPaypal = document.getElementById('paypal-quota-box');
      const notaPaypal = document.getElementById('sp-paypal-nota');

      function setAttivo(btn, attivo) {
        btn.classList.toggle('border-[#C8923E]', attivo);
        btn.classList.toggle('border-[#F5EEDD]/25', !attivo);
        btn.setAttribute('aria-pressed', attivo ? 'true' : 'false');
      }

      if (btnBonifico && pannelloBonifico) {
        btnBonifico.addEventListener('click', () => {
          pannelloBonifico.classList.remove('hidden');
          setAttivo(btnBonifico, true);
          if (btnPaypal) setAttivo(btnPaypal, false);
          pannelloBonifico.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      }

      if (btnPaypal) {
        btnPaypal.addEventListener('click', () => {
          const gate = (boxPaypal && boxPaypal.dataset.live === '1') ||
            new URLSearchParams(window.location.search).get('paypal') === '1';
          if (gate && boxPaypal) {
            // I bottoni PayPal vivono nel PASSO 2 in alto: mostralo e vacci.
            boxPaypal.classList.remove('hidden');
            setAttivo(btnPaypal, true);
            if (btnBonifico) setAttivo(btnBonifico, false);
            boxPaypal.scrollIntoView({ behavior: 'smooth', block: 'center' });
          } else if (notaPaypal) {
            notaPaypal.textContent = 'in attivazione — intanto usa il bonifico';
          }
        });
      }

      // Upload ricevuta → edge fn ricevuta-ocr (verifica sempre manuale).
      const fileInput = document.getElementById('ricevuta-file');
      const invia = document.getElementById('ricevuta-invia');
      const esito = document.getElementById('ricevuta-esito');
      function mostraRicevutaEsito(msg, ok) {
        if (!esito) return;
        esito.classList.remove('hidden');
        esito.style.background = ok ? '#1d4d3a' : '#5a1f1f';
        esito.style.borderLeftColor = ok ? '#C8923E' : '#d97a7a';
        esito.style.color = '#F5EEDD';
        esito.textContent = msg;
        esito.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      if (invia && fileInput) {
        invia.addEventListener('click', async () => {
          const file = fileInput.files && fileInput.files[0];
          if (!file) {
            mostraRicevutaEsito('Scegli prima il file della ricevuta.', false);
            return;
          }
          if (file.size > 10 * 1024 * 1024) {
            mostraRicevutaEsito('Il file supera i 10 MB: riprova con una foto o un PDF più leggero.', false);
            return;
          }
          invia.disabled = true;
          invia.textContent = 'Caricamento…';
          try {
            const fd = new FormData();
            fd.append('file', file);
            fd.append('tipo', 'quota');
            fd.append('nome', scelta.dataset.nome || '');
            fd.append('email', scelta.dataset.email || '');
            const resp = await fetch(scelta.dataset.ricevutaUrl, { method: 'POST', body: fd });
            const out = await resp.json().catch(() => ({}));
            if (resp.ok && out.success) {
              mostraRicevutaEsito('Ricevuta caricata! La verificheremo e riceverai conferma via email.', true);
            } else {
              mostraRicevutaEsito(out.error || 'Caricamento non riuscito. Riprova, o invia la ricevuta a info@elbrenz.eu.', false);
            }
          } catch {
            mostraRicevutaEsito('Errore di connessione. Riprova, o invia la ricevuta a info@elbrenz.eu.', false);
          } finally {
            invia.disabled = false;
            invia.textContent = 'Carica la ricevuta';
          }
        });
      }
    })();
  </script>

