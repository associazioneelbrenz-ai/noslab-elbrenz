<script>
  // Form contatto: gestione submit con feedback inline.
  // M.A.2.5 — protezione client + server (honeypot, time-trap, validazione)

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const feedback = document.getElementById('cf-feedback') as HTMLDivElement | null;

  if (form && submit && feedback) {
    const endpoint = form.dataset.endpoint;
    if (!endpoint) {
      console.error('[contact-form] endpoint non configurato');
    }

    // Timestamp apertura form: serve come time-trap server-side
    const formOpenedAt = Date.now();

    function showFeedback(message: string, type: 'success' | 'error') {
      if (!feedback) return;
      feedback.classList.remove('hidden');
      feedback.style.background = type === 'success' ? '#1d4d3a' : '#5a1f1f';
      feedback.style.color = '#F5EEDD';
      feedback.style.borderLeft = `3px solid ${type === 'success' ? '#C8923E' : '#d97a7a'}`;
      feedback.style.padding = '14px 18px';
      feedback.textContent = message;
    }

    function hideFeedback() {
      if (!feedback) return;
      feedback.classList.add('hidden');
      feedback.textContent = '';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideFeedback();

      if (!endpoint) {
        showFeedback('Configurazione mancante. Scrivi a info@elbrenz.eu.', 'error');
        return;
      }

      const formData = new FormData(form);
      const payload = {
        nome: (formData.get('nome') as string || '').trim(),
        email: (formData.get('email') as string || '').trim(),
        messaggio: (formData.get('messaggio') as string || '').trim(),
        data_nascita: (formData.get('data_nascita') as string || '').trim(),
        comune_nascita: (formData.get('comune_nascita') as string || '').trim(),
        sesso: (formData.get('sesso') as string || '').trim(),
        gdpr: formData.get('gdpr') === 'on',
        _honeypot: (formData.get('_honeypot') as string || ''),
        _ts: formOpenedAt,
      };

      // Validazione client minima (server è autoritativo)
      if (payload.nome.length < 2) {
        showFeedback('Inserisci il tuo nome.', 'error');
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email)) {
        showFeedback('Indirizzo email non valido.', 'error');
        return;
      }
      if (payload.messaggio.length < 10) {
        showFeedback('Il messaggio è troppo breve (minimo 10 caratteri).', 'error');
        return;
      }
      if (!/^\d{4}-\d{2}-\d{2}$/.test(payload.data_nascita)) {
        showFeedback('Inserisci una data di nascita valida.', 'error');
        return;
      }
      if (payload.comune_nascita.length < 2) {
        showFeedback('Inserisci il comune di nascita.', 'error');
        return;
      }
      if (payload.sesso !== 'M' && payload.sesso !== 'F') {
        showFeedback('Seleziona il sesso.', 'error');
        return;
      }
      if (!payload.gdpr) {
        showFeedback('Devi accettare l\'informativa privacy per procedere.', 'error');
        return;
      }

      submit.disabled = true;
      submit.textContent = 'Invio in corso…';

      try {
        const resp = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await resp.json().catch(() => ({}));

        if (resp.ok && data.success) {
          showFeedback('Domanda inviata, grazie! ORA IL PASSO 2: versa la quota di 20 € con bonifico all\'IBAN IT84U0816335010000190116255 (Cassa Rurale Val di Sole), causale "Quota sociale 2026 – Nome Cognome". Poi il Direttivo esaminerà la domanda e riceverai conferma via email da info@elbrenz.eu.', 'success');
          form.reset();
        } else if (resp.status === 429) {
          showFeedback(data.error || 'Hai inviato troppe richieste. Riprova più tardi.', 'error');
        } else {
          showFeedback(data.error || 'Si è verificato un errore. Riprova o scrivi direttamente a info@elbrenz.eu.', 'error');
        }
      } catch (err) {
        console.error('[contact-form] network error:', err);
        showFeedback('Errore di connessione. Riprova o scrivi direttamente a info@elbrenz.eu.', 'error');
      } finally {
        submit.disabled = false;
        submit.textContent = 'Invia la domanda — passo 1 di 3';
      }
    });
  }
</script>
