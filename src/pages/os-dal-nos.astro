---
/**
 * /os-dal-nos — pagina progetto "Os dal Nos" (M2.6).
 *
 * Le pagine WP del concorso (concorso-os-dal-nos, wp_id 3401 e le 6 pagine
 * edizione 2014-2019) erano vuote o contenevano solo shortcode di gallerie
 * NextGEN: nessun testo da migrare. Questa pagina presenta il concorso con
 * le informazioni verificate presenti nelle altre pagine WP (Chi siamo,
 * Lunari dal Nos); le gallerie delle edizioni arriveranno con la
 * ricostruzione della Photogallery (materiali già scaricati via FTP).
 */

import PaginaIstituzionale from '../components/PaginaIstituzionale.astro';

const edizioni = [2014, 2015, 2016, 2017, 2018, 2019];
---
<PaginaIstituzionale ogImage="/og/og-os-dal-nos.jpg"
  occhiello="Progetti"
  titolo="Os dal Nos"
  intro="Il concorso poetico e musicale che dà voce alle parlate retoromanze delle Valli del Noce: componimenti in nones, solander, rabies e pegaes."
  metaDescription="Os dal Nos, il concorso poetico e musicale dell'Associazione El Brenz per le parlate ladino-anauniche delle Valli del Noce, dalla prima edizione del 2014."
>
  <div class="prosa-istituzionale">
    <h2>La voce del Noce</h2>
    <p>
      <strong>Os dal Nos</strong> (la <em>voce del Noce</em>) è il concorso
      poetico e musicale con cui, fin dalla prima edizione del 2014, abbiamo
      stimolato artisti e poeti a creare componimenti in <em>ladino
      anaunico</em>, unendo le diverse varianti linguistiche delle nostre
      valli: il <em>nones</em>, il <em>solander</em>, il <em>rabies</em> e il
      <em>pegaes</em>. Un vero e proprio inno alla bellezza e all'identità
      delle nostre parole.
    </p>
    <p>
      I componimenti che hanno partecipato alle edizioni del concorso non
      restano chiusi in un cassetto: sono diventati l'anima del
      <a href="/lunari-dal-nos">Lunari dal Nos</a>, il calendario
      dell'associazione che li porta ogni anno nelle case e nelle scuole delle
      valli.
    </p>

    <h2>Le edizioni</h2>
    <p>
      Il concorso si è svolto in sei edizioni, dal 2014 al 2019:
    </p>
  </div>

  <ul class="list-none m-0 mt-6 p-0 flex flex-wrap gap-3" style="font-family: 'Inter', sans-serif;">
    {edizioni.map((anno) => (
      <li class="bg-white border border-[#E5DFCF] text-[#1E2E26] px-5 py-2.5 text-sm tracking-wider">
        {anno}
      </li>
    ))}
  </ul>

  <div class="bg-white border border-[#E5DFCF] p-8 md:p-10 mt-10">
    <span
      class="inline-block text-[11px] tracking-[0.18em] uppercase text-[#C8923E] border border-[#C8923E] px-3 py-1.5 mb-5"
      style="font-family: 'Inter', sans-serif;"
    >
      In arrivo
    </span>
    <p
      class="text-[#0F0F0F]/75 leading-relaxed m-0"
      style="font-family: 'Source Serif 4', Georgia, serif;"
    >
      Stiamo digitalizzando i materiali delle sei edizioni — foto delle
      premiazioni, componimenti vincitori, locandine — che confluiranno qui e
      nella photogallery del sito. Un pezzo alla volta, con la cura che questi
      ricordi meritano.
    </p>
  </div>
</PaginaIstituzionale>
