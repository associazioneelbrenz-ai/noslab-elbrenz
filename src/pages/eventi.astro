---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Eventi — El Brenz">
  <section class="bg-gradient-to-b from-amber-50 to-white py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-amber-700 uppercase tracking-widest text-sm mb-4">Calendario · Eventi</p>
      <h1 class="font-serif text-4xl md:text-5xl text-stone-900 mb-6">Eventi</h1>
      <p class="text-lg text-stone-700">
        Le prossime occasioni per ritrovarsi: presentazioni, gite, conferenze,
        serate storiche, ricorrenze tirolesi.
      </p>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto bg-white rounded-2xl border border-amber-200 shadow-sm p-8 md:p-12">
      <div class="text-center">
        <span class="inline-block bg-amber-100 text-amber-800 text-xs uppercase tracking-wider px-3 py-1 rounded-full mb-6">
          Sezione in lavorazione
        </span>
        <h2 class="font-serif text-2xl text-stone-900 mb-4">Stiamo costruendo il calendario</h2>
        <p class="text-stone-600 mb-8">
          Il nuovo calendario eventi arriverà presto, con date, locandine, partner e modulo
          di iscrizione. Nel frattempo, per restare aggiornati seguiteci sui nostri canali.
        </p>
      </div>
      <div class="border-t border-stone-200 pt-8">
        <p class="text-sm uppercase tracking-wider text-stone-500 mb-4">Cosa troverai qui:</p>
        <ul class="space-y-2 text-stone-700">
          <li>· Date e luoghi dei prossimi eventi</li>
          <li>· Locandine e materiali di comunicazione</li>
          <li>· Iscrizioni online a gite e attività</li>
          <li>· Partner e collaborazioni istituzionali</li>
          <li>· Ricorrenze tirolesi e civiche</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-12 px-6 bg-stone-50">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm uppercase tracking-wider text-stone-500 mb-4 text-center">Seguici nel frattempo</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="https://facebook.com/ASSOCIAZIONELBRENZ" target="_blank" rel="noopener noreferrer"
           class="inline-block bg-stone-800 text-white px-6 py-3 rounded-lg hover:bg-stone-900 transition">
          Facebook
        </a>
        <a href="https://www.instagram.com/elbrenzass" target="_blank" rel="noopener noreferrer"
           class="inline-block bg-stone-800 text-white px-6 py-3 rounded-lg hover:bg-stone-900 transition">
          Instagram
        </a>
        <a href="/rievocazioni" class="inline-block border-2 border-stone-800 text-stone-800 px-6 py-3 rounded-lg hover:bg-stone-100 transition">
          Eventi passati
        </a>
        <a href="/tesseramento" class="inline-block bg-amber-500 text-white px-6 py-3 rounded-lg hover:bg-amber-600 transition">
          Diventa socio
        </a>
      </div>
    </div>
  </section>

  <section class="py-10 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-serif italic text-stone-500 text-lg">«Radici profonde non gelano.»</p>
      <p class="text-stone-400 text-sm mt-1"><em>Rais fonde no le 'nglacia.</em></p>
    </div>
  </section>
</Layout>
