---
/**
 * /lingua — pagina-indice del pilastro "Lingua e ladinità".
 *
 * M2.2 (display layer): da placeholder "in lavorazione" a indice degli
 * articoli del pilastro, raggruppati per anno. Logica in PaginaPilastro.astro.
 */

import PaginaPilastro from '../components/PaginaPilastro.astro';
---
<PaginaPilastro ogImage="/og/og-lingua.jpg"
  pilastro="2_lingua_ladinita"
  titolo="Lingua e ladinità"
  intro="Le parlate ladino-anauniche delle nostre valli · noneso, solander, rabies, pegaes · raccontate, studiate, custodite: etimologie, proverbi, poesie e le voci di «Os dal Nos»."
  metaDescription="Lingua ladino-anaunica delle Valli del Noce: etimologie, proverbi, poesie e il progetto «Os dal Nos». Gli articoli dell'Associazione El Brenz, anno per anno."
  vuotoTitolo="Stiamo costruendo questa sezione"
  anticipazioni={[
    'Glossari delle quattro parlate (<em>noneso</em>, <em>solander</em>, <em>rabies</em>, <em>pegaes</em>)',
    'Etimologie e curiosità linguistiche',
    'Proverbi, modi di dire, poesie',
    'Registrazioni audio del progetto <em>Os dal Nos</em>',
    'Materiali didattici per scuole e curiosi',
  ]}
/>
