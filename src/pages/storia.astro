---
/**
 * /storia — pagina-indice del pilastro "Storia delle Valli".
 *
 * M2.2 (display layer): da pagina-placeholder con singolo saggio statico a
 * indice degli articoli del pilastro, raggruppati per anno (recente in alto).
 * Il vecchio saggio-placeholder "Le Valli del Noce nel Tirolo storico" resta
 * nello storico git (commit M1.6) e potrà rientrare come articolo vero.
 *
 * Logica di filtro e rendering centralizzati in PaginaPilastro.astro.
 */

import PaginaPilastro from '../components/PaginaPilastro.astro';
---
<PaginaPilastro ogImage="/og/og-storia.jpg"
  pilastro="1_storia_valli"
  titolo="Storia delle Valli"
  intro="Thun, Spaur e Nanno; le Guerre Rustiche e la Grande Guerra; il Tirolo asburgico e il catasto tavolare. Cinque secoli delle nostre valli, raccontati con rigore sulle fonti e passione divulgativa."
  metaDescription="Storia delle Valli del Noce: Tirolo asburgico, Guerre Rustiche, Grande Guerra, catasto tavolare. Gli articoli dell'Associazione El Brenz, anno per anno."
/>
