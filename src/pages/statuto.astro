<PaginaIstituzionale
  occhiello="L'Associazione"
  titolo="Lo Statuto"
  intro="Lo statuto dell'Associazione Storico Culturale Linguistica El Brenz, modificato ed approvato dall'Assemblea dei Soci il 30 gennaio 2014."
  metaDescription="Lo Statuto dell'Associazione El Brenz: costituzione e scopi, organi sociali, patrimonio e disposizioni finali. Approvato dall'Assemblea dei Soci il 30 gennaio 2014."
>
  <div class="prosa-istituzionale">
    {titoli.map((t) => (
      <section>
        <h2>
          {t.nome} — {t.tema}
        </h2>
        {t.articoli.map((a) => (
          <article class="mb-8">
            <h3>Art. {a.n}</h3>
            {a.testo.map((p) => (
              <p>{p}</p>
            ))}
            {a.lista && (
              <ul>
                {a.lista.map((v) => (
                  <li>{v}</li>
                ))}
              </ul>
            )}
            {a.coda && a.coda.map((p) => <p>{p}</p>)}
          </article>
        ))}
      </section>
    ))}

    <p class="mt-12 pt-6 border-t border-[#E5DFCF] text-sm text-[#0F0F0F]/60">
      <em>Statuto modificato ed approvato dall'Assemblea dei Soci in data 30
      gennaio 2014.</em>
    </p>
  </div>
</PaginaIstituzionale>
