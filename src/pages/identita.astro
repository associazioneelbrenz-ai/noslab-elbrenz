 * raggruppati per anno. Logica in PaginaPilastro.astro.
 */

import PaginaPilastro from '../components/PaginaPilastro.astro';
---
<PaginaPilastro ogImage="/og/og-identita.jpg"
  pilastro="5_identita_appartenenza"
  titolo="Identità e appartenenza"
