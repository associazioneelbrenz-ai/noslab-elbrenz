  metaDescription="Identità e appartenenza delle Valli del Noce: il ponte con catalani, occitani e ladini dolomitici. Gli articoli dell'Associazione El Brenz, anno per anno."
  vuotoTitolo="Stiamo costruendo questa sezione"
  anticipazioni={[
    'Il ponte con catalani, occitani e ladini dolomitici',
    'Radici, appartenenza e senso di comunità',
    'Minoranze linguistiche e culturali a confronto',
    'Testimonianze e voci dalle valli',
  ]}
/>
