                    {c.beneficio}
                  </p>
                  {c.dettagli && (
                    <p class="text-sm text-[#1E2E26]/75 m-0 mb-3 leading-relaxed" style="font-family: 'Source Serif 4', Georgia, serif;">
                      {c.dettagli}
