---
/**
 * /convenzioni — Convenzioni Soci (M5.0 v2).
 *
 * SSR (prerender=false): la griglia legge la vista pubblica
 * `convenzioni_pubbliche` (solo stato='attiva', mai dati del referente).
 * Chiunque può PROPORRE dal form → edge fn `convenzioni-proposta` → nulla
 * diventa pubblico senza approvazione HMAC del Direttivo via email.
 * Pilastro editoriale di riferimento: Vita associativa.
 */

import { createClient } from '@supabase/supabase-js';
import Layout from '../layouts/Layout.astro';

export const prerender = false;

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
const SUPABASE_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;
const PROPOSTA_ENDPOINT = `${SUPABASE_URL}/functions/v1/convenzioni-proposta`;

type ConvenzionePubblica = {
  id: string;
  nome_attivita: string;
  categoria: string;
  localita: string | null;
  beneficio: string;
  dettagli: string | null;
  url: string | null;
  logo_path: string | null;
};

// URL pubblica del logo su Storage (bucket assets-pubblici); i loghi sono
// brand asset di terzi: si usano intatti, nessuna rielaborazione.
const logoUrl = (path: string) =>
  `${SUPABASE_URL}/storage/v1/object/public/assets-pubblici/${path}`;

// Etichette e ordine di visualizzazione delle categorie.
const CATEGORIE: { key: string; label: string }[] = [
  { key: 'rifugi', label: 'Rifugi e ospitalità' },
  { key: 'locali', label: 'Locali e ristorazione' },
  { key: 'servizi', label: 'Servizi' },
  { key: 'cultura', label: 'Cultura' },
  { key: 'benessere', label: 'Sport e benessere' },
  { key: 'altro', label: 'Altro' },
];
const LABEL = Object.fromEntries(CATEGORIE.map((c) => [c.key, c.label]));

let attive: ConvenzionePubblica[] = [];
try {
  const supabase = createClient(SUPABASE_URL, SUPABASE_ANON, {
    auth: { persistSession: false },
  });
  const { data } = await supabase
    .from('convenzioni_pubbliche')
    .select('id, nome_attivita, categoria, localita, beneficio, dettagli, url, logo_path')
    .order('nome_attivita', { ascending: true });
  attive = (data as ConvenzionePubblica[]) ?? [];
} catch (e) {
  console.error('[convenzioni] lettura vista fallita:', e);
  attive = [];
}

// Raggruppa per categoria, nell'ordine di CATEGORIE.
const perCategoria = CATEGORIE
  .map((c) => ({ ...c, items: attive.filter((a) => a.categoria === c.key) }))
  .filter((g) => g.items.length > 0);
---

<Layout ogImage="/og/og-convenzioni.jpg"
  title="Convenzioni Soci"
  description="Le convenzioni riservate ai soci dell'Associazione El Brenz: sconti e vantaggi presso rifugi, locali, servizi e realtà culturali delle Valli del Noce. Basta la tessera a vista, nessuna registrazione."
>
  <!-- HERO -->
  <header class="bg-[#1E2E26] text-[#F5EEDD]">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
      <p
        class="text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium m-0 mb-5"
        style="font-family: 'Inter', sans-serif;"
      >
        Vita associativa
      </p>
      {/* Sigillo: SVG portale-con-tag, gia' icona della card home (spostato
          qui 11/7 con la variante fotografica; regola ferrea: non si butta). */}
      <svg viewBox="0 0 120 80" fill="none" class="w-20 h-auto mb-4" aria-hidden="true" role="presentation">
        <g stroke="#C8923E" stroke-linecap="round" stroke-linejoin="round">
          <g stroke-width="2.5">
            <path d="M28 74 V47 C28 28, 42 15, 60 15 C78 15, 92 28, 92 47 V74" />
            <path d="M36.5 74 V47 C36.5 33, 46 23.5, 60 23.5 C74 23.5, 83.5 33, 83.5 47 V74" />
          </g>
          <g stroke-width="1.7">
            <path d="M63.3 23.7 L64.5 15.3" /><path d="M68.0 24.9 L70.9 16.9" /><path d="M75.1 29.0 L80.6 22.5" /><path d="M80.4 35.2 L87.7 31.0" />
            <path d="M56.7 23.7 L55.5 15.3" /><path d="M52.0 24.9 L49.1 16.9" /><path d="M44.9 29.0 L39.4 22.5" /><path d="M39.6 35.2 L32.3 31.0" />
          </g>
          <g stroke-width="2"><path d="M25 47 H39.5" /><path d="M80.5 47 H95" /></g>
          <g stroke-width="1.7"><path d="M28 56 H36.5" /><path d="M28 65 H36.5" /><path d="M83.5 56 H92" /><path d="M83.5 65 H92" /></g>
          <g stroke-width="2.5"><path d="M23 74 H41.5" /><path d="M78.5 74 H97" /></g>
        </g>
        <path d="M60 23.5 C60.5 31, 63.5 41, 66.2 47.2" stroke="#F5EEDD" stroke-width="1.7" stroke-linecap="round" />
        <g transform="rotate(9 59 48)">
          <path d="M51 38.5 L67 38.5 L73.5 48 L67 57.5 L51 57.5 Z" fill="none" stroke="#F5EEDD" stroke-width="2.2" stroke-linejoin="round" />
          <circle cx="66.5" cy="48" r="1.9" fill="none" stroke="#F5EEDD" stroke-width="1.6" />
          <path d="M55 45 H62" stroke="#C8923E" stroke-width="2.2" stroke-linecap="round" />
          <path d="M55 51 H60" stroke="#C8923E" stroke-width="2.2" stroke-linecap="round" />
        </g>
      </svg>
      <h1
        class="text-4xl md:text-5xl leading-tight m-0 mb-6"
        style="font-family: 'Playfair Display', serif; font-weight: 500;"
      >
        Convenzioni <em class="text-[#C8923E]" style="font-style: italic;">Soci</em>
      </h1>
      <p
        class="text-lg leading-relaxed text-[#F5EEDD]/85 m-0 max-w-2xl"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Essere soci del Brenz conviene anche fuori dalle nostre attività: rifugi,
        locali, servizi e realtà culturali delle valli riservano vantaggi a chi
        porta con sé la tessera. <strong>Nessuna registrazione, nessun dato:</strong>
        basta mostrare la tessera del socio.
      </p>
      <p class="m-0 mt-5">
        <a href="/mappa?tipo=convenzioni" class="text-sm text-[#D9A94E] underline underline-offset-2 hover:text-[#C8923E]" style="font-family: 'Inter', sans-serif;">
          Vedile sulla mappa delle Valli →
        </a>
      </p>
    </div>
  </header>

  <!-- COME FUNZIONA -->
  <section class="bg-[#F8F1E4]">
    <div class="max-w-4xl mx-auto px-6 py-12 grid gap-6 md:grid-cols-3" style="font-family: 'Inter', sans-serif;">
      <div>
        <p class="text-[#C8923E] text-2xl m-0 mb-2" style="font-family: 'Playfair Display', serif;">1</p>
        <p class="text-sm text-[#1E2E26]/80 m-0 leading-relaxed">Tesserati al Brenz per l'anno in corso.</p>
      </div>
      <div>
        <p class="text-[#C8923E] text-2xl m-0 mb-2" style="font-family: 'Playfair Display', serif;">2</p>
        <p class="text-sm text-[#1E2E26]/80 m-0 leading-relaxed">Presso l'attività convenzionata, mostra la tua tessera.</p>
      </div>
      <div>
        <p class="text-[#C8923E] text-2xl m-0 mb-2" style="font-family: 'Playfair Display', serif;">3</p>
        <p class="text-sm text-[#1E2E26]/80 m-0 leading-relaxed">Ricevi il vantaggio riservato ai soci. Tutto qui.</p>
      </div>
    </div>
  </section>

  {perCategoria.length > 0 && (
    <section class="bg-[#F8F1E4]">
      <div class="max-w-5xl mx-auto px-6 pb-16">
        {perCategoria.map((gruppo) => (
          <div class="mb-12">
            <h2
              class="text-[11px] tracking-[0.2em] uppercase text-[#8a6215] font-medium mb-5 pb-2 border-b border-[#C8923E]/30"
              style="font-family: 'Inter', sans-serif;"
            >
              {gruppo.label}
            </h2>
            <div class="grid gap-5 md:grid-cols-2">
              {gruppo.items.map((c) => (
                <article class="bg-[#F5EEDD] rounded-md border border-[#C8923E]/50 hover:border-[#C8923E] transition-colors p-6">
                  {/* area logo ad altezza fissa: regge proporzioni molto diverse
                      (NosLab largo, Punto Riflesso verticale), logo centrato */}
                  <div class="h-[88px] md:h-[112px] flex items-center justify-center mb-4">
                    {c.logo_path ? (
                      <img
                        src={logoUrl(c.logo_path)}
                        alt={`Logo ${c.nome_attivita}`}
                        class="max-h-[72px] md:max-h-[96px] max-w-full object-contain"
