---
/**
 * /portale-memoria — pagina progetto "Portale Memoria" (M2.6).
 *
 * Contenuto: pagina WP "Portale Memoria" (wp_id 2964, publish) da
 * docs/pagine_wp_contenuti/pages_md/portale-memoria.md, testo integrale.
 * Immagine hotlinkata dal vecchio WP omessa (cutover); resta il link al
 * portale esterno www.portalememoria.it.
 */

import PaginaIstituzionale from '../components/PaginaIstituzionale.astro';
---
<PaginaIstituzionale
  occhiello="Progetti"
  titolo="Portale Memoria"
  intro="Un portale web che raccoglie documenti, video, audio e fotografie del territorio delle Valli del Noce, dalla preistoria ai giorni nostri."
  metaDescription="Portale Memoria: il progetto promosso da El Brenz con il Centro Studi per la Val di Sole e l'associazione Molino Ruatti per la memoria digitale delle Valli del Noce."
>
  <div class="prosa-istituzionale">
    <p>
      L'associazione è promotrice del progetto
      <a href="https://www.portalememoria.it" target="_blank" rel="noopener"><strong><em>Portale Memoria</em></strong></a>
      in collaborazione con il <strong>Centro Studi per la Val di Sole</strong>
      (capofila) e l'<strong>associazione Molino Ruatti</strong>, finanziato
      dal G.A.L. Val di Sole. L'obiettivo è la realizzazione di un portale web
      che raccolga in modo dinamico documenti, video, audio e fotografie
      relative al territorio delle Valli del Noce partendo dalla preistoria per
      arrivare ai giorni nostri.
    </p>
    <p>
      Filo conduttore tra le varie sezioni del sito è l'aspetto linguistico
      locale. In futuro il portale potrà essere integrato con documenti
      provenienti da altre realtà del territorio (musei, associazioni etc.) e
      sarà consultabile nelle principali lingue straniere.
    </p>
  </div>

  <div class="mt-12 pt-8 border-t border-[#E5DFCF]" style="font-family: 'Inter', sans-serif;">
    <a
      href="https://www.portalememoria.it"
      target="_blank"
      rel="noopener"
      class="inline-block bg-[#C8923E] text-[#1E2E26] px-7 py-3 text-sm font-medium tracking-wider uppercase no-underline hover:bg-[#D9A94E] transition-colors"
    >
      Visita portalememoria.it →
    </a>
  </div>
</PaginaIstituzionale>
