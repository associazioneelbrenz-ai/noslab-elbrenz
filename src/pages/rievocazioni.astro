---
/**
 * /rievocazioni — pagina-indice del pilastro "Rievocazioni ed eventi".
 *
 * M2.2 (display layer): consolidamento della vecchia duplicazione con /eventi.
 *   - /rievocazioni → memoria delle attività passate (questo pilastro). Oggi
 *     gli articoli rievocativi sono tutti in archivio storico (archivio:true),
 *     quindi lo stato sobrio rimanda lì invece di lasciare un vicolo cieco.
 *   - /eventi → calendario delle prossime occasioni (resta pagina a sé).
 * Appena un articolo del pilastro avrà archivio:false comparirà qui in automatico.
 */

import PaginaPilastro from '../components/PaginaPilastro.astro';
---
<PaginaPilastro
  pilastro="4_rievocazioni_eventi"
  titolo="Rievocazioni ed eventi"
  intro="Anni di gite sociali, serate storiche, presentazioni e concorsi: la memoria delle nostre attività, raccontata con foto, video e testimonianze. I prossimi appuntamenti sono sul calendario eventi."
  metaDescription="Rievocazioni ed eventi dell'Associazione El Brenz: gite sociali, serate storiche, concorsi e ricorrenze tirolesi delle Valli del Noce."
  vuotoTitolo="La memoria delle nostre attività"
  vuotoTesto="I resoconti delle nostre rievocazioni, gite e serate sono raccolti e digitalizzati nell’archivio storico, anno per anno. Per i prossimi appuntamenti, invece, fai riferimento al calendario eventi."
  anticipazioni={[
    'Archivio fotografico delle gite sociali',
    'Resoconti delle serate storiche e culturali',
    'Documentazione di rievocazioni e ricorrenze tirolesi',
    'Concorsi: bandi, vincitori, opere',
    'Video e materiali delle presentazioni di libri e ricerche',
  ]}
/>
