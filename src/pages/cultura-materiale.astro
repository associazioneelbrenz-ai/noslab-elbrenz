---
/**
 * /cultura-materiale — pagina-indice del pilastro "Cultura materiale".
 *
 * M2.2 (display layer): nessun articolo in produzione su questo pilastro al
 * momento, quindi PaginaPilastro rende lo stato sobrio "in lavorazione" con le
 * anticipazioni e il rimando all'archivio storico — niente vicolo cieco.
 * Appena un articolo del pilastro avrà archivio:false comparirà qui in automatico.
 */

import PaginaPilastro from '../components/PaginaPilastro.astro';
---
<PaginaPilastro ogImage="/og/og-cultura-materiale.jpg"
  pilastro="3_cultura_materiale"
  titolo="Cultura materiale"
  intro="Gli oggetti, gli edifici, i mestieri delle nostre valli: quello che le nostre genti hanno costruito con le mani, di generazione in generazione."
  metaDescription="Cultura materiale delle Valli del Noce: la stua, mulini e fucine, utensili e architettura alpina. Sezione in costruzione dell'Associazione El Brenz."
  vuotoTitolo="Stiamo costruendo questa sezione"
  anticipazioni={[
    'La <em>stua</em>: la stanza-cuore della casa alpina',
    'Mulini, fucine e segherie ad acqua',
    'Utensili di lavoro, di campo e di stalla',
    'Architettura alpina: case, masi, fienili, baite',
    'Schede tecniche con foto, video e testimonianze',
  ]}
/>
