---
/**
 * /non-e-sole-grande-guerra — Museo digitale della Grande Guerra.
 * Archivio AUTONOMO (tabella museo_gg_pezzo), staccato dai Custodi.
 * SSR: legge i pezzi con stato='pubblicato' (policy di lettura pubblica) e ne
 * rende una galleria da museo; ogni pezzo apre il suo "cartellino" (fonte,
 * elaborazione, donatore). Immagine d'apertura con didascalia/crediti d'archivio.
 * Fase B: upload/pubblicazione solo admin via /museo-gg-curatela.
 * Referente: Michele Corradini · Supervisione: Cristian Bresadola.
 */
import Layout from '../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

export const prerender = false;

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL as string;
const SUPABASE_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY as string;

const TITOLO = 'Non e Sole Grande Guerra - Erster Weltkrieg Rayon II - storia e cultura';
const IMG = '/img/home/grande-guerra-card.webp';
const IMG_ALT = 'Soldati in divisa austro-ungarica salutano dai vagoni di un treno affollato mentre la folla li accompagna, stazione ferroviaria, 1914.';
const DIDASCALIA = 'Partenza per il fronte della Galizia, 1914. Foto d’epoca, Tiroler Landesarchiv (Landesarchiv Innsbruck). Elaborazione digitale di Michele Corradini.';

type Pezzo = {
  id: string; titolo: string; descrizione: string | null; tipo: string;
  anno: number | null; periodo: string | null; luogo: string | null; valle: string | null;
  fonte: string; elaborazione: string | null; donatore: string | null; immagini_urls: string[];
};
let pezzi: Pezzo[] = [];
try {
  const sb = createClient(SUPABASE_URL, SUPABASE_ANON, { auth: { persistSession: false } });
  // Solo colonne pubbliche del cartellino; niente caricato_da/validato_da.
  const { data } = await sb.from('museo_gg_pezzo')
    .select('id, titolo, descrizione, tipo, anno, periodo, luogo, valle, fonte, elaborazione, donatore, immagini_urls')
    .eq('stato', 'pubblicato')
    .order('ordine', { ascending: true }).order('anno', { ascending: true });
  pezzi = (data as Pezzo[]) ?? [];
} catch (e) {
  console.error('[museo-gg] lettura pezzi fallita:', e);
}

const VALLE: Record<string, string> = {
  val_di_non: 'Val di Non', val_di_sole: 'Val di Sole', val_di_rabbi: 'Val di Rabbi',
  val_di_pejo: 'Val di Pejo', piu_valli: 'Più valli',
};
const TIPO: Record<string, string> = {
  foto: 'Fotografia', fotografia: 'Fotografia', cartolina: 'Cartolina',
  lettera: 'Lettera', documento: 'Documento', oggetto: 'Oggetto',
};
const etichettaTipo = (t: string) => TIPO[t] ?? t;
const etichettaValle = (v: string | null) => (v && VALLE[v]) ? VALLE[v] : (v ?? '');
// Opzioni filtro presenti fra i pezzi pubblicati.
const tipiPresenti = [...new Set(pezzi.map((p) => p.tipo).filter(Boolean))];
const valliPresenti = [...new Set(pezzi.map((p) => p.valle).filter((v): v is string => !!v))];
---

<Layout title={`${TITOLO} · El Brenz`} description="La Grande Guerra vissuta nelle Valli del Noce: soldati trentini nell'esercito austro-ungarico, il fronte della Galizia dal 1914, i profughi, le famiglie. Sezione a cura di Michele Corradini." ogImage="/og/og-grande-guerra.jpg">
  <main class="bg-[#F8F1E4] min-h-screen">
    <div class="max-w-3xl mx-auto px-6 py-10 md:py-14">
      <p class="text-[11px] tracking-[0.22em] uppercase text-[#8a6215] font-semibold m-0 mb-3" style="font-family: 'Inter', sans-serif;">Una sezione di El Brenz</p>
      <h1 class="text-2xl md:text-3xl leading-tight text-[#1E2E26] m-0 mb-6" style="font-family: 'Playfair Display', serif; font-weight: 500;">{TITOLO}</h1>

      <figure class="m-0 mb-8">
        <img src={IMG} alt={IMG_ALT} width="1648" height="927" class="w-full h-auto rounded-md" loading="eager" decoding="async" />
        <figcaption class="text-[12px] text-[#1E2E26]/60 mt-2 leading-relaxed" style="font-family: 'Inter', sans-serif;">{DIDASCALIA}</figcaption>
      </figure>

      <div class="prose-eb text-[#1E2E26]/85 leading-relaxed space-y-4" style="font-family: 'Source Serif 4', Georgia, serif;">
        <h2 class="text-xl md:text-2xl leading-tight text-[#1E2E26] m-0 mb-2" style="font-family: 'Playfair Display', serif; font-weight: 500;">Le nose valli nella Grande Guerra</h2>
        <p>
          Quando l'Europa precipitò nella guerra, nell'estate del 1914, le Valli del Noce erano terra
          d'Austria. Da oltre un secolo il Trentino apparteneva all'Impero asburgico, e i nostri uomini
          partirono in divisa austro-ungarica, richiamati come tanti altri sudditi dell'Imperatore. La
          prima destinazione non furono le montagne di casa, ma il fronte orientale: nel 1914 i
          reggimenti tirolesi salirono sui treni diretti in Galizia, a combattere la Russia in una guerra
          lontanissima, da cui molti non fecero ritorno. È quella partenza che racconta la fotografia qui
          sopra, la folla sulle rotaie e i soldati che salutano dai vagoni, quando ancora nessuno
          immaginava cosa li attendeva.
        </p>
        <p>
          Nel maggio del 1915 la guerra tornò a casa. L'Italia dichiarò guerra all'Austria-Ungheria e il
          fronte si aprì proprio sulle nostre montagne. Il passo del Tonale, l'Adamello, la Presanella, il
          Cevedale, l'Ortles: le cime tra Val di Sole, Val di Rabbi e Val di Pejo diventarono trincee di
          ghiaccio, teatro di quella guerra bianca combattuta a quote impossibili, tra valanghe, gelo e
          granate. A presidiare i passi furono chiamati anche gli Standschützen, la milizia territoriale
          fatta di uomini troppo giovani o troppo anziani per la leva. La linea del fuoco passava sopra i
          paesi, e i paesi si ritrovarono in prima linea senza averlo chiesto.
        </p>
        <p>
          Per la gente delle valli fu anche l'esilio. Migliaia di civili furono evacuati: alcuni verso i
          campi profughi dell'interno dell'Austria, altri verso l'Italia, famiglie divise tra i due
          fronti, a volte per anni. Chi restò conobbe la fame, i bombardamenti, le case requisite, il
          lavoro imposto. Fu una guerra vissuta due volte, al fronte dagli uomini e nelle case da donne,
          anziani e bambini.
        </p>
        <p>
          Questa sezione raccoglie e custodisce quella memoria: testimonianze, fotografie, cartoline dal
          fronte, lettere, racconti di famiglia. Ogni documento è un frammento di una storia che rischia
          di svanire, la storia delle Valli del Noce nella Grande Guerra, raccontata dal versante da cui
          raramente la si ascolta. Se conservi un ricordo, una foto, una cartolina o un racconto
          tramandato, portalo: entrerà a far parte di questo archivio condiviso.
        </p>
      </div>

      <div class="mt-8 bg-[#F5EEDD] border border-[#C8923E]/40 rounded-md p-5" style="font-family: 'Inter', sans-serif;">
        <p class="m-0 text-sm text-[#1E2E26]/80"><strong>Referente</strong>: Michele Corradini · <strong>Supervisione</strong>: Cristian Bresadola</p>
      </div>

      <section class="mt-10">
        <h2 class="text-[13px] tracking-[0.2em] uppercase text-[#8a6215] font-medium mb-5 pb-2 border-b border-[#C8923E]/30" style="font-family: 'Inter', sans-serif;">La collezione</h2>

        {pezzi.length === 0 ? (
          <p class="text-[#1E2E26]/70 text-lg py-4" style="font-family: 'Source Serif 4', Georgia, serif;">
            L'archivio sta prendendo forma. I primi pezzi (fotografie, cartoline dal fronte, lettere e
            documenti) saranno presto qui, ciascuno con la sua fonte e la sua storia.
          </p>
        ) : (
          <>
            <div class="flex flex-wrap gap-2 mb-6" style="font-family: 'Inter', sans-serif;">
              {tipiPresenti.length > 1 && (
                <select id="museo-f-tipo" class="text-sm border border-[#C8923E]/40 bg-white text-[#1E2E26] px-3 py-1.5 rounded">
                  <option value="">Tutti i tipi</option>
                  {tipiPresenti.map((t) => <option value={t}>{etichettaTipo(t)}</option>)}
                </select>
              )}
              {valliPresenti.length > 1 && (
                <select id="museo-f-valle" class="text-sm border border-[#C8923E]/40 bg-white text-[#1E2E26] px-3 py-1.5 rounded">
                  <option value="">Tutte le valli</option>
                  {valliPresenti.map((v) => <option value={v}>{etichettaValle(v)}</option>)}
                </select>
              )}
            </div>

            <div id="museo-griglia" class="grid grid-cols-2 md:grid-cols-3 gap-3">
              {pezzi.map((p) => (
                <button
                  type="button"
                  class="museo-tile group text-left m-0 p-0 border border-[#C8923E]/25 bg-[#F5EEDD] overflow-hidden cursor-pointer"
                  data-tipo={p.tipo}
                  data-valle={p.valle ?? ''}
                  data-pezzo={JSON.stringify(p)}
                >
                  <span class="block aspect-[4/3] overflow-hidden bg-[#e8dcc4]">
                    {p.immagini_urls[0] && (
                      <img src={p.immagini_urls[0]} alt={p.titolo} loading="lazy" decoding="async"
                        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300" />
                    )}
                  </span>
                  <span class="block p-2.5">
                    <span class="block text-[13px] leading-snug text-[#1E2E26]" style="font-family: 'Playfair Display', serif;">{p.titolo}</span>
                    <span class="block text-[10px] tracking-[0.12em] uppercase text-[#8a6215] mt-1" style="font-family: 'Inter', sans-serif;">
                      {etichettaTipo(p.tipo)}{p.periodo ? ` · ${p.periodo}` : (p.anno ? ` · ${p.anno}` : '')}
                    </span>
                  </span>
                </button>
              ))}
            </div>
            <p id="museo-vuoto" class="hidden text-[#1E2E26]/60 text-sm py-4" style="font-family: 'Inter', sans-serif;">Nessun pezzo per questo filtro.</p>
          </>
        )}

        <p class="mt-8 text-sm text-[#1E2E26]/70" style="font-family: 'Inter', sans-serif;">
          Hai una fotografia, una cartolina, una lettera o un documento della Grande Guerra?
          <a href="/contatti" class="text-[#8a6215] underline">Scrivici</a>: può entrare a far parte di questo archivio.
        </p>
      </section>
    </div>

    {/* Cartellino del pezzo (overlay), popolato lato client */}
    <div id="museo-overlay" class="fixed inset-0 z-50 hidden items-start justify-center overflow-y-auto bg-[#1E2E26]/80 p-4" style="font-family: 'Inter', sans-serif;">
      <div class="relative bg-[#F8F1E4] max-w-2xl w-full my-6 rounded-md shadow-xl">
        <button id="museo-chiudi" type="button" aria-label="Chiudi" class="absolute top-2 right-3 text-2xl leading-none text-[#1E2E26]/60 hover:text-[#1E2E26]">×</button>
        <div id="museo-immagini" class="p-4 pt-10 space-y-3"></div>
        <div class="px-6 pb-6">
          <h3 id="museo-titolo" class="text-xl text-[#1E2E26] m-0 mb-2" style="font-family: 'Playfair Display', serif; font-weight: 500;"></h3>
          <p id="museo-descrizione" class="text-[#1E2E26]/85 leading-relaxed m-0 mb-4" style="font-family: 'Source Serif 4', Georgia, serif;"></p>
          <dl id="museo-cartellino" class="text-sm text-[#1E2E26]/80 space-y-1.5 border-t border-[#C8923E]/30 pt-4"></dl>
        </div>
      </div>
    </div>
  </main>

  <script>
    const overlay = document.getElementById('museo-overlay');
    const griglia = document.getElementById('museo-griglia');
    if (overlay && griglia) {
      const elImg = document.getElementById('museo-immagini')!;
      const elTit = document.getElementById('museo-titolo')!;
      const elDes = document.getElementById('museo-descrizione')!;
      const elCar = document.getElementById('museo-cartellino')!;
      const VALLE_L: Record<string, string> = {
        val_di_non: 'Val di Non', val_di_sole: 'Val di Sole', val_di_rabbi: 'Val di Rabbi',
        val_di_pejo: 'Val di Pejo', piu_valli: 'Più valli',
      };
      const TIPO_L: Record<string, string> = {
        foto: 'Fotografia', fotografia: 'Fotografia', cartolina: 'Cartolina',
        lettera: 'Lettera', documento: 'Documento', oggetto: 'Oggetto',
      };
      const riga = (k: string, v: string | null) =>
        v ? `<div><dt class="inline font-semibold text-[#8a6215]">${k}:</dt> <dd class="inline m-0">${v}</dd></div>` : '';

      function apri(p: any) {
        elImg.innerHTML = (p.immagini_urls || [])
          .map((u: string) => `<img src="${u}" alt="${(p.titolo || '').replace(/"/g, '&quot;')}" class="w-full h-auto rounded" loading="lazy" />`)
          .join('');
        elTit.textContent = p.titolo || '';
        elDes.textContent = p.descrizione || '';
        elCar.innerHTML = [
          riga('Tipo', TIPO_L[p.tipo] || p.tipo),
          riga('Anno', p.anno ? String(p.anno) : (p.periodo || null)),
          riga('Luogo', p.luogo),
          riga('Valle', p.valle ? (VALLE_L[p.valle] || p.valle) : null),
          riga('Fonte', p.fonte),
          riga('Elaborazione', p.elaborazione),
          riga('Donatore', p.donatore),
        ].join('');
        overlay!.classList.remove('hidden');
        overlay!.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
      function chiudi() {
        overlay!.classList.add('hidden');
        overlay!.classList.remove('flex');
        document.body.style.overflow = '';
      }

      griglia.querySelectorAll<HTMLButtonElement>('.museo-tile').forEach((btn) => {
        btn.addEventListener('click', () => {
          try { apri(JSON.parse(btn.dataset.pezzo || '{}')); } catch {}
        });
      });
      document.getElementById('museo-chiudi')?.addEventListener('click', chiudi);
      overlay.addEventListener('click', (e) => { if (e.target === overlay) chiudi(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') chiudi(); });

      // Filtri
      const fTipo = document.getElementById('museo-f-tipo') as HTMLSelectElement | null;
      const fValle = document.getElementById('museo-f-valle') as HTMLSelectElement | null;
      const vuoto = document.getElementById('museo-vuoto');
      function filtra() {
        const t = fTipo?.value || '';
        const v = fValle?.value || '';
        let visibili = 0;
        griglia!.querySelectorAll<HTMLElement>('.museo-tile').forEach((tile) => {
          const ok = (!t || tile.dataset.tipo === t) && (!v || tile.dataset.valle === v);
          tile.style.display = ok ? '' : 'none';
          if (ok) visibili++;
        });
        if (vuoto) vuoto.classList.toggle('hidden', visibili > 0);
      }
      fTipo?.addEventListener('change', filtra);
      fValle?.addEventListener('change', filtra);
    }
  </script>
</Layout>
