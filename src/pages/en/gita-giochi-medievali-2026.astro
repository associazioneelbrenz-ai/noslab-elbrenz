---
/* /en/gita-giochi-medievali-2026 — English translation (Phase 1b). Review in progress. */

import Layout from '../../layouts/Layout.astro';

const CTA = 'inline-block bg-[#C8923E] text-[#1E2E26] px-8 py-4 text-base font-semibold tracking-wide uppercase no-underline rounded hover:bg-[#D9A94E] transition-colors focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#F5EEDD]';
---

<Layout
  lang="en"
  title="A Day in the Middle Ages · Trip to the Südtiroler Ritterspiele, 22 August 2026"
  description="El Brenz group trip to the Südtiroler Ritterspiele (South Tyrolean Medieval Games), 22 August 2026. Limited places, reduced rate for members."
  ogImage="/og/og-gita-giochi-medievali.jpg"
>
  {/* ===================== HERO ===================== */}
  <section class="relative bg-[#1E2E26] text-[#F5EEDD] overflow-hidden">
    <div class="absolute inset-0 opacity-[0.06] pointer-events-none" aria-hidden="true"
      style="background-image:url('/decoro/aquila-oro-filigrana.png');background-repeat:no-repeat;background-position:right -80px center;background-size:520px auto;"></div>
    <div class="relative max-w-4xl mx-auto px-6 py-20 md:py-28 text-center">
      <p class="text-xs md:text-sm tracking-[0.24em] uppercase text-[#D9A94E] font-semibold m-0 mb-5" style="font-family: 'Inter', sans-serif;">Group trip · 22 August 2026</p>
      <h1 class="text-4xl md:text-6xl leading-[1.05] m-0 mb-6" style="font-family: 'Playfair Display', serif; font-weight: 500;">
        A day in the <em class="text-[#C8923E]" style="font-style: italic;">Middle Ages</em>, together.
      </h1>
      <p class="text-lg md:text-xl text-[#F5EEDD]/85 max-w-2xl mx-auto m-0 mb-8" style="font-family: 'Source Serif 4', Georgia, serif;">
        At the foot of Churburg castle (Castel Coira), in Val Venosta (Vinschgau), the Alpine region's largest historical
        reenactment comes to life. El Brenz takes you where historical Tyrol lives again.
      </p>
      <a href="/en/gita-giochi-medievali-2026/iscrizione" class={CTA}>Sign up and secure your place →</a>
      <p class="text-sm text-[#F5EEDD]/60 mt-5 m-0" style="font-family: 'Inter', sans-serif;">Only 54 places · reduced rate for members · early-bird bonus until 31 July</p>
    </div>
  </section>

  {/* Miniatura medievale (Codex Manesse, pubblico dominio): dà subito il tono
      senza usare foto protette di Ritterspiele/Churburg. */}
  <section class="bg-[#1E2E26]">
    <div class="max-w-4xl mx-auto px-6 pb-12 md:pb-16 -mt-2">
      <figure class="m-0">
        <picture>
          <source srcset="/eventi/giochi-medievali-manesse.webp" type="image/webp" />
          <img src="/eventi/giochi-medievali-manesse.jpg" alt="Jousting tournament: two knights charge with lowered lances in a Codex Manesse miniature" width="1040" height="696" class="w-full rounded-xl border-2 border-[#C8923E]/50 shadow-2xl" loading="lazy" decoding="async" />
        </picture>
        <figcaption class="text-center text-xs text-[#F5EEDD]/55 mt-3" style="font-family: 'Inter', sans-serif;">
          Miniature from the Codex Manesse (c. 1300–1340), Heidelberg University Library, public domain.
        </figcaption>
      </figure>
    </div>
  </section>

  {/* ===================== SEZIONE 1 — VIDEO ===================== */}
  <section class="bg-[#F5EEDD] py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl text-[#1E2E26] m-0 mb-2" style="font-family: 'Playfair Display', serif; font-weight: 500;">A taste in one minute</h2>
      <div class="w-16 h-[2px] bg-[#C8923E] mx-auto mb-8" aria-hidden="true"></div>
      <div id="video-facade" class="relative rounded-xl overflow-hidden shadow-lg cursor-pointer group" style="aspect-ratio:16/9;" role="button" tabindex="0" aria-label="Watch the Ritterspiele video">
        <div class="absolute inset-0 bg-[#1E2E26]" aria-hidden="true"></div>
        <div class="absolute inset-0 opacity-[0.12] pointer-events-none" aria-hidden="true"
          style="background-image:url('/decoro/aquila-oro-filigrana.png');background-repeat:no-repeat;background-position:center;background-size:340px auto;"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center text-[#F5EEDD]">
          <span class="flex items-center justify-center w-20 h-20 md:w-24 md:h-24 rounded-full bg-[#C8923E] text-[#1E2E26] shadow-xl group-hover:scale-105 transition-transform" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </span>
          <span class="mt-4 text-lg md:text-xl" style="font-family: 'Playfair Display', serif;">Watch the Ritterspiele</span>
        </div>
      </div>
      <p class="text-xs text-[#1E2E26]/55 mt-3" style="font-family: 'Inter', sans-serif;">
        Video © <a href="https://www.ritterspiele.it" target="_blank" rel="noopener" class="text-[#8a6215] underline">Südtiroler Ritterspiele</a> · it loads only when you press play (no data sent to YouTube before your click).
      </p>
    </div>
  </section>

  {/* ===================== SEZIONE 2 — COSA VIVRAI ===================== */}
  <section class="bg-[#F8F1E4] py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl text-[#1E2E26] m-0 mb-3" style="font-family: 'Playfair Display', serif; font-weight: 500;">Two thousand knights, a leap across eight centuries</h2>
        <p class="text-lg text-[#1E2E26]/80 max-w-2xl mx-auto m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
          For one day the plain of Sluderno travels back in time: <strong>2,000 reenactors from 11 nations</strong>,
          chivalric tournaments with caparisoned horses and shattering lances, parades and combats, a great medieval market
          and encampments where people truly live and cook.
        </p>
      </div>
      <ul class="grid sm:grid-cols-2 gap-4 list-none p-0 m-0" style="font-family: 'Source Serif 4', Georgia, serif;">
        {[
          ['⚔️', 'Tournaments and jousting'],
          ['🏰', 'Great medieval market'],
          ['🔥', 'Encampments and craftsmen at work'],
          ['🎯', 'Archery and activities for children'],
          ['🎶', 'Music, jugglers, shows'],
          ['🎪', 'Most attractions free within the grounds'],
        ].map(([icona, testo]) => (
          <li class="flex items-start gap-3 bg-[#F5EEDD] border border-[#C8923E]/40 rounded-md px-5 py-4">
            <span class="text-2xl leading-none" aria-hidden="true">{icona}</span>
            <span class="text-[#1E2E26]/90">{testo}</span>
          </li>
        ))}
      </ul>
      <div class="text-center mt-10">
        <a href="/en/gita-giochi-medievali-2026/iscrizione" class={CTA}>Secure your place →</a>
      </div>
    </div>
  </section>

  {/* ===================== SEZIONE 3 — CASTEL COIRA ===================== */}
  <section class="bg-[#1E2E26] text-[#F5EEDD] py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium m-0 mb-4 text-center" style="font-family: 'Inter', sans-serif;">The setting</p>
      <h2 class="text-3xl md:text-4xl m-0 mb-6 text-center" style="font-family: 'Playfair Display', serif; font-weight: 500;">In the shadow of Tyrol's armoury</h2>
      <p class="text-lg text-[#F5EEDD]/85 leading-relaxed" style="font-family: 'Source Serif 4', Georgia, serif;">
        Watching over the event stands one of South Tyrol's best-preserved castles. <strong>Churburg</strong>
        (<em>Castel Coira</em>), built in the mid-<strong>13th century</strong> by the prince-bishop of Chur Henry of
        Montfort, later held by the lords of Matsch and then, from the 16th century, by the <strong>counts of
        Trapp</strong>, who still own it today. Never destroyed in eight centuries, it holds the <strong>world's
        largest private armoury</strong>: some fifty complete suits of armour from the workshops of Milan and Innsbruck.
      </p>
      <p class="text-[#D9A94E] italic font-serif text-lg mt-6 text-center">
        For us it is no ordinary backdrop: it is historical Tyrol returning, the same history that also runs through the <span class="not-italic">nose</span> valli (our valleys).
      </p>
    </div>
  </section>

  {/* ===================== SEZIONE 4 — PERCHÉ CON NOI ===================== */}
  <section class="bg-[#F8F1E4] py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl text-[#1E2E26] m-0 mb-6" style="font-family: 'Playfair Display', serif; font-weight: 500;">Not just any trip</h2>
      <p class="text-lg text-[#1E2E26]/85 leading-relaxed max-w-2xl mx-auto" style="font-family: 'Source Serif 4', Georgia, serif;">
        A group trip means living history side by side, recognising ourselves in a shared heritage, helping our
        community grow. By becoming a member you don't just book a seat: you support the culture, the language and the memory of the Valli del Noce.
      </p>
    </div>
  </section>

  {/* ===================== SEZIONE 5 — INFO PRATICHE ===================== */}
  <section class="bg-[#F5EEDD] py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl md:text-4xl text-[#1E2E26] m-0 mb-8 text-center" style="font-family: 'Playfair Display', serif; font-weight: 500;">Practical information</h2>
      <dl class="grid gap-4" style="font-family: 'Source Serif 4', Georgia, serif;">
        <div class="flex gap-4 bg-white border-l-4 border-[#C8923E] px-5 py-4 rounded">
          <dt class="text-[#8a6215] font-semibold w-24 shrink-0" style="font-family: 'Inter', sans-serif;">When</dt>
          <dd class="m-0 text-[#1E2E26]/90">Saturday, 22 August 2026 · Sluderno and Churburg, Val Venosta <span class="text-[#1E2E26]/60">(event open 10.00–24.00)</span></dd>
        </div>
        <div class="flex gap-4 bg-white border-l-4 border-[#C8923E] px-5 py-4 rounded">
          <dt class="text-[#8a6215] font-semibold w-24 shrink-0" style="font-family: 'Inter', sans-serif;">Programme</dt>
          <dd class="m-0 text-[#1E2E26]/90">Departure from Malè at 7:30 · Grand historical parade at 10:30 · Return in the evening, arrival expected around midnight. Packed lunch.</dd>
        </div>
        <div class="flex gap-4 bg-white border-l-4 border-[#C8923E] px-5 py-4 rounded">
          <dt class="text-[#8a6215] font-semibold w-24 shrink-0" style="font-family: 'Inter', sans-serif;">Fee</dt>
          <dd class="m-0 text-[#1E2E26]/90">Participation fee: no more than 60 € per person (coach travel and entry to the Ritterspiele). 30 € deposit at sign-up. The balance, never above the stated fee, will be communicated before departure.</dd>
        </div>
        <div class="flex gap-4 bg-white border-l-4 border-[#C8923E] px-5 py-4 rounded">
          <dt class="text-[#8a6215] font-semibold w-24 shrink-0" style="font-family: 'Inter', sans-serif;">Sign-up</dt>
          <dd class="m-0 text-[#1E2E26]/90">Open until Friday 14 August 2026. Limited places: coach with 54 seats.</dd>
        </div>
      </dl>
    </div>
  </section>

  {/* ===================== SEZIONE 6 — CTA FINALE ===================== */}
  <section class="bg-[#1E2E26] text-[#F5EEDD] py-20 md:py-24">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-sm tracking-[0.2em] uppercase text-[#D9A94E] font-semibold m-0 mb-4" style="font-family: 'Inter', sans-serif;">54 places. Don't wait.</p>
      <h2 class="text-3xl md:text-5xl m-0 mb-6" style="font-family: 'Playfair Display', serif; font-weight: 500;">Secure your place</h2>
      <p class="text-lg text-[#F5EEDD]/85 max-w-2xl mx-auto m-0 mb-9" style="font-family: 'Source Serif 4', Georgia, serif;">
        El Brenz members travel at a <strong>reduced rate</strong>; non-members pay the full price.
        During sign-up you can check your rate and, if you like, join on the spot.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/en/gita-giochi-medievali-2026/iscrizione" class={CTA}>Sign up for the trip →</a>
        <a href="mailto:info@elbrenz.eu" class="inline-block border-2 border-[#C8923E] text-[#F5EEDD] px-7 py-4 text-base font-semibold tracking-wide uppercase no-underline rounded hover:bg-[#C8923E] hover:text-[#1E2E26] transition-colors" style="font-family: 'Inter', sans-serif;">Questions? Write to us</a>
      </div>
      <p class="text-sm text-[#F5EEDD]/60 mt-5 m-0" style="font-family: 'Inter', sans-serif;">
        <a href="mailto:info@elbrenz.eu" class="text-[#D9A94E] no-underline hover:underline">info@elbrenz.eu</a> · <a href="tel:+393471077636" class="text-[#D9A94E] no-underline hover:underline">+39 347 107 7636</a>
      </p>
      <p class="text-[#D9A94E] italic font-serif mt-10 m-0" lang="lld-anau">Raìs fonde no le 'nglacia</p>
      <p class="text-xs tracking-[0.15em] uppercase text-[#F5EEDD]/55 mt-2 m-0" style="font-family: 'Inter', sans-serif;">(Deep roots do not freeze)</p>
    </div>
  </section>

  {/* CTA sticky su mobile */}
  <div class="md:hidden fixed inset-x-0 bottom-0 z-30 bg-[#1E2E26]/95 backdrop-blur border-t border-[#C8923E]/40 px-4 py-3" style="padding-bottom:max(0.75rem,env(safe-area-inset-bottom));">
    <a href="/en/gita-giochi-medievali-2026/iscrizione" class="block text-center bg-[#C8923E] text-[#1E2E26] py-3 rounded font-semibold uppercase tracking-wide text-sm no-underline" style="font-family: 'Inter', sans-serif;">Sign up for the trip →</a>
  </div>
</Layout>

<script>
  // Video facade click-to-load: nessuna richiesta a YouTube prima del gesto.
  const facade = document.getElementById('video-facade');
  function caricaVideo() {
    if (!facade) return;
    const iframe = document.createElement('iframe');
    iframe.src = 'https://www.youtube-nocookie.com/embed/J9hMH4Cadoo?autoplay=1&rel=0';
    iframe.title = "Südtiroler Ritterspiele";
    iframe.loading = 'lazy';
    iframe.allow = 'accelerated-motion; autoplay; encrypted-media; picture-in-picture';
    iframe.allowFullscreen = true;
    iframe.style.cssText = 'width:100%;height:100%;border:0;border-radius:12px;position:absolute;inset:0;';
    facade.innerHTML = '';
    facade.appendChild(iframe);
  }
  facade?.addEventListener('click', caricaVideo);
  facade?.addEventListener('keydown', (e) => {
    if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') { e.preventDefault(); caricaVideo(); }
  });
</script>
