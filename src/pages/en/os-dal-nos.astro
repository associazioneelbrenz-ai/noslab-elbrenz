---
/* /en/os-dal-nos — traduzione EN (Fase 1b). Revisione Brunella Bonapace in corso. */

import PaginaIstituzionale from '../../components/PaginaIstituzionale.astro';
import LightboxEmbed from '../../components/LightboxEmbed.astro';
import { OS_DAL_NOS, miniatura, embed } from '../../data/video';

const edizioni = [2014, 2015, 2016, 2017, 2018, 2019];
---
<PaginaIstituzionale
  lang="en"
  ogImage="/og/og-os-dal-nos.jpg"
  occhiello="Projects"
  titolo="Os dal Nos"
  intro="The poetry and music competition that gives voice to the Rhaeto-Romance vernaculars of the Valli del Noce: compositions in Nones, Solander, Rabies and Pegaes."
  metaTitle="Os dal Nos, the competition in Anaunian Ladin | El Brenz"
  metaDescription="The videos of every edition of Os dal Nos, El Brenz's poetry and music competition in the language of the Valli del Noce (2014-2019)."
>
  <div class="prosa-istituzionale">
    <h2>The Voice of the Noce</h2>
    <p>
      <strong>Os dal Nos</strong> (<em>Voice of the Noce</em>) is the poetry
      and music competition with which, ever since the first edition in 2014,
      we have encouraged artists and poets to create works in <em>Anaunian
      Ladin</em>, bringing together the different linguistic varieties of our
      valleys: <em>Nones</em>, <em>Solander</em>, <em>Rabies</em> and
      <em>Pegaes</em>. A true hymn to the beauty and the identity of our words.
    </p>
    <p>
      The works that took part in the competition's editions do not stay locked
      in a drawer: they have become the soul of the
      <a href="/en/lunari-dal-nos">Lunari dal Nos</a>, the association's
      calendar that carries them each year into the homes and schools of the
      valleys.
    </p>

    <h2>The Editions</h2>
    <p>
      The competition ran across six editions, from 2014 to 2019:
    </p>
  </div>

  {/* Video per edizione. Accordion nativo <details>: nessun JavaScript per
      aprire e chiudere, funziona anche se lo script non parte. Le miniature
      sono immagini statiche di YouTube: NESSUN iframe finche' non si apre il
      lightbox, quindi la pagina resta leggera con oltre quaranta video. */}
  <div class="mt-8 flex flex-col gap-4">
    {OS_DAL_NOS.edizioni.map((ed) => (
      ed.stato === 'pubblicata' ? (
        <details class="bg-white border border-[#E5DFCF] group" open={ed.n === 5}>
          <summary class="cursor-pointer list-none p-6 md:p-8 flex items-center gap-4">
            <span class="text-2xl text-[#1E2E26] font-medium m-0" style="font-family: 'Playfair Display', serif;">
              {ed.titolo}
            </span>
            <span class="text-sm text-[#0F0F0F]/55" style="font-family: 'Inter', sans-serif;">
              {ed.anno} · {ed.video.length} videos
            </span>
            <span class="ml-auto text-[#C8923E] text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <div class="px-6 md:px-8 pb-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {ed.video.map((v) => (
                <LightboxEmbed
                  url={`https://www.youtube.com/watch?v=${v.id_youtube}`}
                  embedSrcDiretto={embed(v.id_youtube)}
                  cover={miniatura(v.id_youtube)}
                  titolo={v.titolo}
                  etichetta={v.titolo}
                  aspetto="16/9"
                />
              ))}
            </div>
            {ed.articolo && (
              <p class="mt-5 m-0">
                <a href={`/en/articoli/${ed.articolo}`} class="text-sm text-[#8a6215] underline" style="font-family: 'Inter', sans-serif;">
                  Read the edition's article →
                </a>
              </p>
            )}
          </div>
        </details>
      ) : (
        <div class="bg-white border border-[#E5DFCF] p-6 md:p-8 flex items-center gap-4">
          <span class="text-2xl text-[#1E2E26]/55 font-medium m-0" style="font-family: 'Playfair Display', serif;">
            {ed.titolo}
          </span>
          <span class="text-sm text-[#0F0F0F]/45" style="font-family: 'Inter', sans-serif;">{ed.anno}</span>
          {ed.articolo && (
            <a href={`/en/articoli/${ed.articolo}`} class="text-sm text-[#8a6215] underline" style="font-family: 'Inter', sans-serif;">
              Read the article →
            </a>
          )}
          <span
            class="ml-auto inline-block text-[11px] tracking-[0.18em] uppercase text-[#C8923E] border border-[#C8923E] px-3 py-1.5"
            style="font-family: 'Inter', sans-serif;"
          >
            Coming soon
          </span>
        </div>
      )
    ))}
  </div>

  <p class="text-sm text-[#0F0F0F]/55 mt-6 m-0" style="font-family: 'Inter', sans-serif;">
    The missing editions will be added as the videos become available again.
  </p>
  <p class="text-sm text-[#0F0F0F]/55 mt-2 m-0" style="font-family: 'Inter', sans-serif;">
    The videos open in a window on the site, from YouTube in a mode without profiling cookies.
  </p>

  <div class="bg-white border border-[#E5DFCF] p-8 md:p-10 mt-10">
    <span
      class="inline-block text-[11px] tracking-[0.18em] uppercase text-[#C8923E] border border-[#C8923E] px-3 py-1.5 mb-5"
      style="font-family: 'Inter', sans-serif;"
    >
      Coming soon
    </span>
    <p
      class="text-[#0F0F0F]/75 leading-relaxed m-0"
      style="font-family: 'Source Serif 4', Georgia, serif;"
    >
      We are digitising the materials of the six editions: photos of the award
      ceremonies, prize-winning works, posters, which will come together here
      and in the site's photo gallery. One piece at a time, with the care these
      memories deserve.
    </p>
  </div>
</PaginaIstituzionale>
