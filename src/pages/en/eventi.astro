---
/* /en/eventi — English translation (Phase 1b). Review by Brunella Bonapace in progress. */
import Layout from '../../layouts/Layout.astro';
---
<Layout lang="en" ogImage="/og/og-eventi.jpg" title="Events · El Brenz" description="The events, gatherings and cultural initiatives of the El Brenz association in the Valli del Noce: Val di Non, Val di Sole, Val di Rabbi and Val di Pejo.">
  <section class="bg-gradient-to-b from-amber-50 to-white py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-amber-700 uppercase tracking-widest text-sm mb-4">Calendar · Events</p>
      <h1 class="font-serif text-4xl md:text-5xl text-stone-900 mb-6">Events</h1>
      <p class="text-lg text-stone-700">
        The next occasions to come together: book presentations, outings, lectures,
        historical evenings, Tyrolean commemorations.
      </p>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto bg-white rounded-2xl border border-amber-200 shadow-sm p-8 md:p-12">
      <div class="text-center">
        <span class="inline-block bg-amber-100 text-amber-800 text-xs uppercase tracking-wider px-3 py-1 rounded-full mb-6">
          Section under construction
        </span>
        <h2 class="font-serif text-2xl text-stone-900 mb-4">We are building the calendar</h2>
        <p class="text-stone-600 mb-8">
          The new events calendar is coming soon, with dates, posters, partners and a registration
          form. In the meantime, follow us on our channels to stay up to date.
        </p>
      </div>
      <div class="border-t border-stone-200 pt-8">
        <p class="text-sm uppercase tracking-wider text-stone-500 mb-4">What you will find here:</p>
        <ul class="space-y-2 text-stone-700">
          <li>· Dates and places of upcoming events</li>
          <li>· Posters and communication materials</li>
          <li>· Online registrations for outings and activities</li>
          <li>· Partners and institutional collaborations</li>
          <li>· Tyrolean and civic commemorations</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-12 px-6 bg-stone-50">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm uppercase tracking-wider text-stone-500 mb-4 text-center">Follow us in the meantime</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="https://facebook.com/ASSOCIAZIONELBRENZ" target="_blank" rel="noopener noreferrer"
           class="inline-block bg-stone-800 text-white px-6 py-3 rounded-lg hover:bg-stone-900 transition">
          Facebook
        </a>
        <a href="https://www.instagram.com/elbrenzass" target="_blank" rel="noopener noreferrer"
           class="inline-block bg-stone-800 text-white px-6 py-3 rounded-lg hover:bg-stone-900 transition">
          Instagram
        </a>
        <a href="/en/rievocazioni" class="inline-block border-2 border-stone-800 text-stone-800 px-6 py-3 rounded-lg hover:bg-stone-100 transition">
          Past events
        </a>
        <a href="/en/tesseramento" class="inline-block bg-amber-500 text-white px-6 py-3 rounded-lg hover:bg-amber-600 transition">
          Become a member
        </a>
      </div>
    </div>
  </section>

  <section class="py-10 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-serif italic text-stone-500 text-lg" lang="lld-anau">Raìs fonde no le 'nglacia</p>
      <p class="text-stone-400 text-sm mt-1">(Deep roots do not freeze)</p>
    </div>
  </section>
</Layout>
