---
/**
 * /museo-gg-curatela — curatela admin del Museo della Grande Guerra (Fase B).
 * Gemella di /custodi-curatela: isola client-side, auth OTP (riusa
 * otp-request/otp-verify + sessione Supabase), gating ruolo >= 50, poi CRUD su
 * museo_gg_pezzo via RLS (policy museo_gg_admin_write) + upload immagini su
 * Storage assets-pubblici/museo-gg/. La pubblicazione richiede fonte + almeno
 * un'immagine + consenso dichiarato (vincolo anche a DB: trigger di guardia).
 * La galleria pubblica /non-e-sole-grande-guerra resta sola lettura.
 */
import Layout from '../layouts/Layout.astro';

const VALLE: Record<string, string> = {
  val_di_non: 'Val di Non', val_di_sole: 'Val di Sole', val_di_rabbi: 'Val di Rabbi',
  val_di_pejo: 'Val di Pejo', piu_valli: 'Più valli',
};
const TIPO: Record<string, string> = {
  foto: 'Fotografia', cartolina: 'Cartolina', lettera: 'Lettera',
  documento: 'Documento', oggetto: 'Oggetto',
};
const inputCls = 'w-full border-2 border-[#E5DFCF] bg-white px-4 py-2.5 text-[#1E2E26] rounded focus:outline-none focus:border-[#C8923E]';
---

<Layout title="Curatela Museo Grande Guerra · El Brenz" description="Catalogazione riservata del Museo della Grande Guerra." ogImage="/og/og-default.jpg">
  <main class="bg-[#F8F1E4] min-h-screen">
    <div class="max-w-3xl mx-auto px-6 py-12 md:py-16" style="font-family: 'Inter', sans-serif;">
      <p class="text-[11px] tracking-[0.22em] uppercase text-[#8a6215] font-semibold m-0 mb-2">Area riservata · Direttivo</p>
      <h1 class="text-3xl md:text-4xl text-[#1E2E26] m-0 mb-8" style="font-family: 'Playfair Display', serif; font-weight: 500;">Curatela · Museo della Grande Guerra</h1>

      <p id="mu-loading" class="text-[#1E2E26]/60">Carico…</p>

      {/* LOGIN */}
      <section id="mu-login" class="hidden bg-white border border-[#E5DFCF] rounded p-6 md:p-8 max-w-md">
        <div id="mu-login-1">
          <p class="text-sm text-[#1E2E26]/70 m-0 mb-4">Accedi con la tua email: ti invieremo un codice di verifica.</p>
          <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-email">Email</label>
          <input class={inputCls} type="email" id="mu-email" autocomplete="email" placeholder="nome@esempio.it" />
          <button type="button" id="mu-send" class="mt-4 w-full bg-[#1E2E26] text-[#F5EEDD] py-3 rounded font-medium hover:bg-[#2a3f34] transition-colors">Invia codice</button>
        </div>
        <div id="mu-login-2" class="hidden">
          <p class="text-sm text-[#1E2E26]/70 m-0 mb-4">Inserisci il codice a 6 cifre inviato a <strong id="mu-email-echo"></strong>.</p>
          <input class={`${inputCls} tracking-[0.4em] text-center text-xl`} type="text" id="mu-code" inputmode="numeric" maxlength="6" placeholder="000000" />
          <button type="button" id="mu-verify" class="mt-4 w-full bg-[#C8923E] text-[#1E2E26] py-3 rounded font-semibold hover:bg-[#D9A94E] transition-colors">Verifica e accedi</button>
          <button type="button" id="mu-back" class="mt-2 w-full text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Cambia email</button>
        </div>
        <div id="mu-login-err" class="hidden mt-3 text-sm rounded px-3 py-2" style="background:#fbecec;color:#1E2E26;"></div>
      </section>

      {/* NO ACCESS */}
      <section id="mu-noaccess" class="hidden bg-white border border-[#E5DFCF] rounded p-6 max-w-md">
        <p class="m-0 text-[#1E2E26]/80">Questa area è riservata al direttivo (segretario/amministratore). Se pensi di dover avere accesso, chiedi al segretario di abilitarti.</p>
        <button type="button" id="mu-logout-2" class="mt-4 text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Esci</button>
      </section>

      {/* APP */}
      <section id="mu-app" class="hidden">
        <div class="flex items-center justify-between mb-6">
          <p class="text-sm text-[#1E2E26]/70 m-0">Ciao <strong id="mu-utente"></strong> · <span id="mu-ruolo" class="text-[#8a6215]"></span></p>
          <button type="button" id="mu-logout" class="text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Esci</button>
        </div>

        <div class="flex items-center justify-between mb-3">
          <h2 class="text-xl text-[#1E2E26] m-0" style="font-family: 'Playfair Display', serif;">Pezzi dell'archivio</h2>
          <button type="button" id="mu-nuovo" class="bg-[#C8923E] text-[#1E2E26] px-4 py-2 rounded text-sm font-semibold hover:bg-[#D9A94E] transition-colors">+ Nuovo pezzo</button>
        </div>
        <p class="text-[13px] text-[#1E2E26]/55 m-0 mb-4">Un pezzo diventa pubblico solo se <strong>pubblicato</strong>, e solo con <strong>fonte</strong>, almeno <strong>un'immagine</strong> e la <strong>dichiarazione di consenso</strong>.</p>
        <div id="mu-lista" class="space-y-3"></div>

        {/* FORM */}
        <div id="mu-form-wrap" class="hidden mt-8 bg-white border border-[#E5DFCF] rounded p-6 md:p-8">
          <h3 id="mu-form-titolo" class="text-lg text-[#1E2E26] m-0 mb-5" style="font-family: 'Playfair Display', serif;">Nuovo pezzo</h3>
          <div class="grid gap-4">
            <div>
              <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-titolo">Titolo <span class="text-[#a33]">*</span></label>
              <input class={inputCls} type="text" id="mu-f-titolo" placeholder="Cartolina dal fronte della Galizia" />
            </div>
            <div>
              <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-descr">Descrizione</label>
              <textarea class={inputCls} id="mu-f-descr" rows="3" placeholder="Cosa mostra, il contesto, la storia…"></textarea>
            </div>

            {/* Immagini */}
            <div>
              <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-file">Immagini <span class="text-[#1E2E26]/45">(anche più d'una: fronte/retro)</span></label>
              <input type="file" id="mu-f-file" accept="image/*" multiple class="text-sm" />
              <p id="mu-upload-stato" class="hidden text-[13px] mt-1"></p>
              <div id="mu-thumbs" class="flex flex-wrap gap-2 mt-2"></div>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-tipo">Tipo</label>
                <select class={inputCls} id="mu-f-tipo">
                  {Object.entries(TIPO).map(([v, l]) => (<option value={v}>{l}</option>))}
                </select>
              </div>
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-valle">Valle</label>
                <select class={inputCls} id="mu-f-valle">
                  <option value="">—</option>
                  {Object.entries(VALLE).map(([v, l]) => (<option value={v}>{l}</option>))}
                </select>
              </div>
            </div>
            <div class="grid sm:grid-cols-3 gap-4">
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-anno">Anno</label>
                <input class={inputCls} type="number" id="mu-f-anno" placeholder="1916" />
              </div>
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-periodo">Periodo</label>
                <input class={inputCls} type="text" id="mu-f-periodo" placeholder="1914-1918" />
              </div>
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-luogo">Luogo</label>
                <input class={inputCls} type="text" id="mu-f-luogo" placeholder="Passo del Tonale" />
              </div>
            </div>
            <div>
              <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-fonte">Fonte / provenienza <span class="text-[#a33]">*</span> <span class="text-[#1E2E26]/45">(il cartellino)</span></label>
              <input class={inputCls} type="text" id="mu-f-fonte" placeholder="Tiroler Landesarchiv · oppure «collezione famiglia X»" />
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-elab">Elaborazione</label>
                <input class={inputCls} type="text" id="mu-f-elab" placeholder="elaborazione Michele Corradini" />
              </div>
              <div>
                <label class="block text-sm text-[#1E2E26]/75 mb-1" for="mu-f-donatore">Donatore <span class="text-[#1E2E26]/45">(nome pubblico o «Anonimo»)</span></label>
                <input class={inputCls} type="text" id="mu-f-donatore" placeholder="Famiglia Rossi" />
              </div>
            </div>

            <div class="border-t border-[#E5DFCF] pt-4 space-y-3">
              <label class="flex items-start gap-2 text-sm text-[#1E2E26]/85">
                <input type="checkbox" id="mu-f-consenso" class="mt-1" />
                <span>Dichiaro di avere il diritto di pubblicare questo materiale, con la fonte indicata sopra.</span>
              </label>
              <label class="flex items-center gap-2 text-sm text-[#1E2E26]/85">
                <input type="checkbox" id="mu-f-pubblica" /> <strong>Pubblica</strong> nella galleria pubblica
              </label>
            </div>

            <div id="mu-form-esito" class="hidden text-sm rounded px-3 py-2"></div>
            <div class="flex flex-wrap gap-3">
              <button type="button" id="mu-salva" class="bg-[#1E2E26] text-[#F5EEDD] px-5 py-2.5 rounded font-medium hover:bg-[#2a3f34] transition-colors">Salva</button>
              <button type="button" id="mu-elimina" class="hidden text-sm text-[#a33] underline bg-transparent border-0 cursor-pointer">Elimina pezzo</button>
              <button type="button" id="mu-annulla" class="text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Chiudi</button>
            </div>
          </div>
        </div>

        {/* Proposte dal pubblico (segnalazioni dal form della pagina Grande Guerra) */}
        <div class="mt-12 pt-8 border-t border-[#E5DFCF]">
          <h2 class="text-xl text-[#1E2E26] m-0 mb-2" style="font-family: 'Playfair Display', serif;">Proposte dal pubblico</h2>
          <p class="text-[13px] text-[#1E2E26]/55 m-0 mb-4">Segnalazioni di materiale arrivate dal form pubblico. Le «nuove» sono in cima: ricontatta il proponente, poi segna «gestita» (o «archiviata»).</p>
          <div id="mu-prop-lista" class="space-y-3"></div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const TIPO: Record<string, string> = {
    foto: 'Fotografia', cartolina: 'Cartolina', lettera: 'Lettera',
    documento: 'Documento', oggetto: 'Oggetto',
  };
  const esc = (s: unknown) => String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const $ = (id: string) => document.getElementById(id);
  const show = (id: string) => $(id)?.classList.remove('hidden');
  const hide = (id: string) => $(id)?.classList.add('hidden');
  const val = (id: string) => ($(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)?.value ?? '';
  const checked = (id: string) => ($(id) as HTMLInputElement)?.checked ?? false;

  let livello = 0;
  let userId = '';
  let editingId: string | null = null;
  let immagini: string[] = [];

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    hide('mu-loading');
    if (!session) { show('mu-login'); return; }
    userId = session.user.id;
    const { data: ruoli } = await supabase
      .from('utente_ruolo').select('ruolo:ruolo_id ( nome, livello )').eq('utente_id', userId);
    livello = (ruoli ?? []).reduce((m: number, r: any) => Math.max(m, r?.ruolo?.livello ?? 0), 0);
    const nomeRuolo = (ruoli ?? []).map((r: any) => r?.ruolo?.nome).sort().pop() ?? 'ospite';
    if (livello < 50) { show('mu-noaccess'); return; }
    ($('mu-utente') as HTMLElement).textContent = session.user.user_metadata?.nome || session.user.email || '';
    ($('mu-ruolo') as HTMLElement).textContent = nomeRuolo;
    show('mu-app');
    await caricaLista();
    await caricaProposte();
  }

  // ---- LOGIN ----
  const loginErr = (t: string) => { const e = $('mu-login-err')!; e.classList.remove('hidden'); e.textContent = t; };
  $('mu-send')?.addEventListener('click', async () => {
    const email = (val('mu-email')).trim().toLowerCase();
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { loginErr('Email non valida.'); return; }
    $('mu-login-err')?.classList.add('hidden');
    const btn = $('mu-send') as HTMLButtonElement; btn.disabled = true; btn.textContent = 'Invio…';
    const { data, error } = await supabase.functions.invoke('otp-request', { body: { email, scope: 'login' } });
    btn.disabled = false; btn.textContent = 'Invia codice';
    if (error || !data?.ok) { loginErr('Impossibile inviare il codice. Riprova.'); return; }
    (window as any)._muEmail = email;
    ($('mu-email-echo') as HTMLElement).textContent = email;
    hide('mu-login-1'); show('mu-login-2');
    setTimeout(() => ($('mu-code') as HTMLInputElement)?.focus(), 100);
  });
  $('mu-back')?.addEventListener('click', () => { hide('mu-login-2'); show('mu-login-1'); });
  $('mu-verify')?.addEventListener('click', async () => {
    const codice = (val('mu-code')).replace(/\D/g, '');
    if (!/^\d{6}$/.test(codice)) { loginErr('Il codice deve essere di 6 cifre.'); return; }
    $('mu-login-err')?.classList.add('hidden');
    const btn = $('mu-verify') as HTMLButtonElement; btn.disabled = true; btn.textContent = 'Verifica…';
    const { data, error } = await supabase.functions.invoke('otp-verify', { body: { email: (window as any)._muEmail, codice, scope: 'login' } });
    if (error || !data?.ok || !data?.session) { btn.disabled = false; btn.textContent = 'Verifica e accedi'; loginErr('Codice errato o scaduto.'); return; }
    await supabase.auth.setSession({ access_token: data.session.access_token, refresh_token: data.session.refresh_token });
    window.location.reload();
  });
  const logout = async () => { await supabase.auth.signOut(); window.location.reload(); };
  $('mu-logout')?.addEventListener('click', logout);
  $('mu-logout-2')?.addEventListener('click', logout);

  // ---- UPLOAD IMMAGINI (Storage assets-pubblici/museo-gg/) ----
  function renderThumbs() {
    const box = $('mu-thumbs')!;
    box.innerHTML = immagini.map((u, i) => `
      <span class="relative inline-block">
        <img src="${esc(u)}" class="w-20 h-20 object-cover rounded border border-[#E5DFCF]" />
        <button type="button" data-rm="${i}" class="absolute -top-2 -right-2 bg-[#a33] text-white rounded-full w-5 h-5 text-xs leading-none cursor-pointer" aria-label="Rimuovi">×</button>
      </span>`).join('');
    box.querySelectorAll('[data-rm]').forEach((b) => b.addEventListener('click', () => {
      immagini.splice(parseInt((b as HTMLElement).dataset.rm!, 10), 1); renderThumbs();
    }));
  }
  $('mu-f-file')?.addEventListener('change', async (e) => {
    const files = Array.from((e.target as HTMLInputElement).files ?? []);
    if (!files.length) return;
    const stato = $('mu-upload-stato')!; stato.classList.remove('hidden');
    for (const file of files) {
      if (file.size > 5 * 1024 * 1024) { stato.style.color = '#a33'; stato.textContent = `«${file.name}» supera i 5 MB, saltata.`; continue; }
      stato.style.color = '#1E2E26'; stato.textContent = `Carico ${esc(file.name)}…`;
      const ext = (file.name.split('.').pop() || 'jpg').toLowerCase();
      const path = `museo-gg/${userId}/${Date.now()}-${Math.random().toString(36).slice(2, 8)}.${ext}`;
      const { error } = await supabase.storage.from('assets-pubblici').upload(path, file, { upsert: true, contentType: file.type });
      if (error) { stato.style.color = '#a33'; stato.textContent = `Caricamento non riuscito: ${esc(error.message)}`; continue; }
      const { data } = supabase.storage.from('assets-pubblici').getPublicUrl(path);
      immagini.push(data.publicUrl);
      renderThumbs();
    }
    stato.textContent = 'Immagini caricate.'; stato.style.color = '#2d8659';
    (e.target as HTMLInputElement).value = '';
  });

  // ---- LISTA ----
  async function caricaLista() {
    const { data, error } = await supabase.from('museo_gg_pezzo')
      .select('*').order('created_at', { ascending: false });
    const box = $('mu-lista')!;
    if (error) { box.innerHTML = `<p class="text-[#a33] text-sm">Errore di lettura: ${esc(error.message)}</p>`; return; }
    const righe = (data as any[]) ?? [];
    if (righe.length === 0) { box.innerHTML = '<p class="text-[#1E2E26]/55 text-sm">Nessun pezzo. Caricane uno nuovo.</p>'; return; }
    box.innerHTML = righe.map((r) => {
      const pub = r.stato === 'pubblicato'
        ? '<span style="background:#2d86591a;color:#2d8659;padding:2px 10px;border-radius:999px;font-size:12px;">Pubblicato</span>'
        : '<span style="background:#6b5a3a1a;color:#6b5a3a;padding:2px 10px;border-radius:999px;font-size:12px;">In attesa</span>';
      const thumb = (r.immagini_urls && r.immagini_urls[0])
        ? `<img src="${esc(r.immagini_urls[0])}" class="w-12 h-12 object-cover rounded border border-[#E5DFCF] shrink-0" />`
        : '<span class="w-12 h-12 rounded bg-[#eee6d5] shrink-0 inline-block"></span>';
      return `<div class="bg-white border border-[#E5DFCF] rounded p-3 flex items-center gap-3">
        ${thumb}
        <div class="min-w-0 flex-1">
          <p class="m-0 text-[#1E2E26] truncate"><strong>${esc(r.titolo)}</strong></p>
          <p class="m-0 text-[13px] text-[#1E2E26]/60 truncate">${esc(TIPO[r.tipo] || r.tipo)}${r.anno ? ' · ' + esc(r.anno) : (r.periodo ? ' · ' + esc(r.periodo) : '')}${r.fonte ? ' · ' + esc(r.fonte) : ''}</p>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          ${pub}
          <button type="button" data-edit="${r.id}" class="text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Apri</button>
        </div>
      </div>`;
    }).join('');
    box.querySelectorAll('[data-edit]').forEach((b) => b.addEventListener('click', () => apriForm((b as HTMLElement).dataset.edit!, righe)));
  }

  // ---- FORM ----
  function apriForm(id: string | null, righe?: any[]) {
    editingId = id;
    $('mu-form-esito')?.classList.add('hidden');
    const r = id && righe ? righe.find((x) => x.id === id) : null;
    ($('mu-form-titolo') as HTMLElement).textContent = r ? 'Modifica pezzo' : 'Nuovo pezzo';
    ($('mu-f-titolo') as HTMLInputElement).value = r?.titolo ?? '';
    ($('mu-f-descr') as HTMLTextAreaElement).value = r?.descrizione ?? '';
    ($('mu-f-tipo') as HTMLSelectElement).value = r?.tipo ?? 'foto';
    ($('mu-f-valle') as HTMLSelectElement).value = r?.valle ?? '';
    ($('mu-f-anno') as HTMLInputElement).value = r?.anno ?? '';
    ($('mu-f-periodo') as HTMLInputElement).value = r?.periodo ?? '';
    ($('mu-f-luogo') as HTMLInputElement).value = r?.luogo ?? '';
    ($('mu-f-fonte') as HTMLInputElement).value = r?.fonte ?? '';
    ($('mu-f-elab') as HTMLInputElement).value = r?.elaborazione ?? '';
    ($('mu-f-donatore') as HTMLInputElement).value = r?.donatore ?? '';
    ($('mu-f-consenso') as HTMLInputElement).checked = !!r?.consenso_dichiarato;
    ($('mu-f-pubblica') as HTMLInputElement).checked = r?.stato === 'pubblicato';
    immagini = Array.isArray(r?.immagini_urls) ? [...r.immagini_urls] : [];
    renderThumbs();
    ($('mu-upload-stato') as HTMLElement).classList.add('hidden');
    $('mu-elimina')?.classList.toggle('hidden', !id);
    show('mu-form-wrap');
    ($('mu-form-wrap') as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  $('mu-nuovo')?.addEventListener('click', () => apriForm(null));
  $('mu-annulla')?.addEventListener('click', () => hide('mu-form-wrap'));

  const esito = (msg: string, ok: boolean) => {
    const e = $('mu-form-esito')!; e.classList.remove('hidden');
    e.style.background = ok ? '#e9f5ee' : '#fbecec'; e.style.color = '#1E2E26'; e.textContent = msg;
  };

  $('mu-salva')?.addEventListener('click', async () => {
    const titolo = val('mu-f-titolo').trim();
    const fonte = val('mu-f-fonte').trim();
    const pubblica = checked('mu-f-pubblica');
    const consenso = checked('mu-f-consenso');
    if (!titolo) { esito('Il titolo è obbligatorio.', false); return; }
    if (!fonte) { esito('La fonte/provenienza è obbligatoria (il cartellino).', false); return; }
    if (pubblica && immagini.length === 0) { esito('Per pubblicare serve almeno un’immagine.', false); return; }
    if (pubblica && !consenso) { esito('Per pubblicare serve la dichiarazione di consenso.', false); return; }

    const annoRaw = val('mu-f-anno').trim();
    const payload: Record<string, any> = {
      titolo,
      descrizione: val('mu-f-descr').trim() || null,
      tipo: val('mu-f-tipo') || 'foto',
      anno: annoRaw ? parseInt(annoRaw, 10) : null,
      periodo: val('mu-f-periodo').trim() || null,
      luogo: val('mu-f-luogo').trim() || null,
      valle: val('mu-f-valle') || null,
      fonte,
      elaborazione: val('mu-f-elab').trim() || null,
      donatore: val('mu-f-donatore').trim() || null,
      immagini_urls: immagini,
      consenso_dichiarato: consenso,
      stato: pubblica ? 'pubblicato' : 'in_attesa',
    };
    if (pubblica) { payload.validato_da = userId; payload.validato_il = new Date().toISOString(); }
    if (!editingId) payload.caricato_da = userId;

    const btn = $('mu-salva') as HTMLButtonElement; btn.disabled = true; btn.textContent = 'Salvo…';
    const q = editingId
      ? supabase.from('museo_gg_pezzo').update(payload).eq('id', editingId)
      : supabase.from('museo_gg_pezzo').insert(payload);
    const { error } = await q;
    btn.disabled = false; btn.textContent = 'Salva';
    if (error) { esito('Salvataggio fallito: ' + error.message, false); return; }
    esito(pubblica ? 'Salvato e pubblicato.' : 'Salvato (in attesa).', true);
    await caricaLista();
    setTimeout(() => hide('mu-form-wrap'), 800);
  });

  $('mu-elimina')?.addEventListener('click', async () => {
    if (!editingId) return;
    if (!window.confirm('Eliminare definitivamente questo pezzo? L’azione non si può annullare.')) return;
    const { error } = await supabase.from('museo_gg_pezzo').delete().eq('id', editingId);
    if (error) { esito('Eliminazione fallita: ' + error.message, false); return; }
    hide('mu-form-wrap');
    await caricaLista();
  });

  // ---- PROPOSTE DAL PUBBLICO ----
  const STATO_PROP: Record<string, string> = { nuova: 'Nuova', gestita: 'Gestita', archiviata: 'Archiviata' };
  async function caricaProposte() {
    const { data, error } = await supabase.from('museo_gg_proposta')
      .select('*')
      // le "nuove" in cima, poi per data discendente
      .order('stato', { ascending: true }).order('created_at', { ascending: false });
    const box = $('mu-prop-lista')!;
    if (error) { box.innerHTML = `<p class="text-[#a33] text-sm">Errore di lettura: ${esc(error.message)}</p>`; return; }
    const righe = ((data as any[]) ?? []).sort((a, b) => (a.stato === 'nuova' ? -1 : 0) - (b.stato === 'nuova' ? -1 : 0));
    if (righe.length === 0) { box.innerHTML = '<p class="text-[#1E2E26]/55 text-sm">Nessuna proposta, per ora.</p>'; return; }
    box.innerHTML = righe.map((r) => {
      const nuova = r.stato === 'nuova';
      const badge = nuova
        ? '<span style="background:#c8923e1a;color:#8a6215;padding:2px 10px;border-radius:999px;font-size:12px;">Nuova</span>'
        : `<span style="background:#6b5a3a1a;color:#6b5a3a;padding:2px 10px;border-radius:999px;font-size:12px;">${esc(STATO_PROP[r.stato] || r.stato)}</span>`;
      const data = new Date(r.created_at).toLocaleDateString('it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
      return `<div class="bg-white border ${nuova ? 'border-[#C8923E]/60' : 'border-[#E5DFCF]'} rounded p-4">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <p class="m-0 text-[#1E2E26]"><strong>${esc(r.nome)}</strong>${r.tipo ? ` · ${esc(r.tipo)}` : ''} <span class="text-[13px] text-[#1E2E26]/50">· ${esc(data)}</span></p>
            <p class="m-0 mt-1 text-sm text-[#1E2E26]/80" style="white-space:pre-wrap;">${esc(r.descrizione)}</p>
            <p class="m-0 mt-2 text-[13px] text-[#1E2E26]/70">Contatto: <strong>${esc(r.contatto)}</strong></p>
          </div>
          ${badge}
        </div>
        <div class="mt-3">
          <input type="text" data-nota="${r.id}" value="${esc(r.note_interne ?? '')}" placeholder="Nota interna (facoltativa)" class="w-full border border-[#E5DFCF] rounded px-3 py-1.5 text-sm text-[#1E2E26] focus:outline-none focus:border-[#C8923E]" />
        </div>
        <div class="mt-2 flex flex-wrap gap-3">
          ${r.stato !== 'gestita' ? `<button type="button" data-prop-azione="gestita" data-id="${r.id}" class="text-sm text-[#2d8659] underline bg-transparent border-0 cursor-pointer">Segna gestita</button>` : ''}
          ${r.stato !== 'archiviata' ? `<button type="button" data-prop-azione="archiviata" data-id="${r.id}" class="text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Archivia</button>` : ''}
          ${r.stato !== 'nuova' ? `<button type="button" data-prop-azione="nuova" data-id="${r.id}" class="text-sm text-[#1E2E26]/50 underline bg-transparent border-0 cursor-pointer">Riporta a nuova</button>` : ''}
          <button type="button" data-prop-nota="${r.id}" class="text-sm text-[#8a6215] underline bg-transparent border-0 cursor-pointer">Salva nota</button>
        </div>
      </div>`;
    }).join('');

    const getNota = (id: string) => (box.querySelector(`[data-nota="${id}"]`) as HTMLInputElement)?.value ?? null;
    async function aggiorna(id: string, patch: Record<string, any>) {
      const { error } = await supabase.from('museo_gg_proposta').update(patch).eq('id', id);
      if (error) { alert('Aggiornamento non riuscito: ' + error.message); return; }
      await caricaProposte();
    }
    box.querySelectorAll('[data-prop-azione]').forEach((b) => b.addEventListener('click', () => {
      const el = b as HTMLElement; const id = el.dataset.id!;
      const nuovoStato = el.dataset.propAzione!;
      const patch: Record<string, any> = { stato: nuovoStato, note_interne: getNota(id) };
      if (nuovoStato !== 'nuova') patch.gestita_da = userId;
      aggiorna(id, patch);
    }));
    box.querySelectorAll('[data-prop-nota]').forEach((b) => b.addEventListener('click', () => {
      const id = (b as HTMLElement).dataset.propNota!;
      aggiorna(id, { note_interne: getNota(id) });
    }));
  }

  init();
</script>
