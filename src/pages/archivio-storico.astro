---
/**
 * /archivio-storico — indice sobrio degli articoli storici/legacy (M2.2).
 *
 * Sorgente: gli articoli con archivio:true && !draft (importati dal vecchio
 * WordPress in M2.3). Sono leggibili come ogni altro articolo — la loro pagina
 * /articoli/{slug} esiste — ma vivono qui invece che nelle liste-pilastro di
 * produzione: una sala di lettura ordinata per anno, in sordina, senza enfasi.
 *
 * Da NON confondere con /archivio ("Archivio digitale"): quella è un'altra cosa
 * (documenti, foto, audio, pubblicazioni) e NON va toccata. Qui ci sono solo gli
 * articoli testuali archiviati.
 *
 * Rendering: ElencoArticoliPerAnno con sobrio=true (compatto, muted, niente
 * excerpt). Palette brand coerente col resto del display layer.
 */

import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ElencoArticoliPerAnno from '../components/ElencoArticoliPerAnno.astro';

// Solo articoli archiviati e pubblicabili (!draft).
const articoli = await getCollection(
  'articoli',
  ({ data }) => data.archivio && !data.draft,
);
const totale = articoli.length;
---
<Layout
  title="Archivio storico — El Brenz"
  description="L'archivio storico degli articoli dell'Associazione El Brenz: oltre cinquant'anni di ricerche e racconti sulle Valli del Noce, ordinati per anno."
>
  <header class="bg-[#1E2E26] text-[#F5EEDD]">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-24">
      <p
        class="text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium m-0 mb-5"
        style="font-family: 'Inter', sans-serif;"
      >
        Patrimonio · Archivio storico
      </p>
      <h1
        class="text-4xl md:text-6xl leading-[1.08] tracking-tight m-0 mb-6"
        style="font-family: 'Playfair Display', serif; font-weight: 500;"
      >
        Archivio storico
      </h1>
      <p
        class="text-lg md:text-xl leading-relaxed text-[#F5EEDD]/85 m-0 max-w-2xl"
        style="font-family: 'Source Serif 4', Georgia, serif;"
      >
        Gli articoli e le ricerche pubblicati negli anni dall’Associazione, raccolti
        e ordinati per anno. Una sala di lettura della nosa storia: scritti d’altri
        tempi, custoditi e di nuovo consultabili.
      </p>
    </div>
  </header>

  <section class="bg-[#FDF9F0]">
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-20">
      {totale > 0 ? (
        <ElencoArticoliPerAnno articoli={articoli} sobrio={true} />
      ) : (
        <p
          class="text-[#0F0F0F]/70 leading-relaxed m-0"
          style="font-family: 'Source Serif 4', Georgia, serif;"
        >
          L’archivio storico è in fase di popolamento: torna presto.
        </p>
      )}
    </div>
  </section>
</Layout>
