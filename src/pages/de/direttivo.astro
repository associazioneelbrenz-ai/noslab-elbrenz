---
/* /de/direttivo — traduzione DE (Fase 1b). Revisione Brunella Bonapace in corso. */

import PaginaIstituzionale from '../../components/PaginaIstituzionale.astro';

const direttivo = [
  { nome: 'Diego Magnoni', carica: 'Presidente' },
  { nome: 'Simone Pangrazzi', carica: 'Vice Presidente' },
  { nome: 'Milena Comini', carica: 'Vice Presidente' },
  { nome: 'Cristian Bresadola', carica: 'Segretario-Tesoriere' },
  { nome: 'Monica Valentinotti', carica: 'Consigliere' },
  { nome: 'Michele Gentilini', carica: 'Consigliere' },
  { nome: 'Andrea Daprà', carica: 'Consigliere' },
  { nome: 'Michele Corradini', carica: 'Consigliere' },
];
---
<PaginaIstituzionale lang="de" ogImage="/og/og-direttivo.jpg"
  occhiello="Der Verein"
  titolo="Der Vorstand"
  intro="Die Menschen, die El Brenz führen, gewählt von der Mitgliederversammlung."
  metaDescription="Der Vorstand des Vereins El Brenz: Präsident, Vizepräsidenten, Schriftführer und Beiräte, gewählt von der Mitgliederversammlung."
>
  <h2
    class="text-2xl md:text-3xl text-[#1E2E26] font-medium leading-tight m-0 mb-8"
    style="font-family: 'Playfair Display', serif;"
  >
    Der amtierende Vorstand
  </h2>

  <ul class="list-none m-0 mb-6 p-0 grid grid-cols-1 sm:grid-cols-2 gap-4">
    {direttivo.map((m) => (
      <li class="bg-white border border-[#E5DFCF] px-6 py-5">
        <p
          class="text-[11px] tracking-[0.18em] uppercase text-[#C8923E] m-0 mb-1.5"
          style="font-family: 'Inter', sans-serif;"
        >
          {m.carica}
        </p>
        <p
          class="text-xl text-[#1E2E26] font-medium leading-tight m-0"
          style="font-family: 'Playfair Display', serif;"
        >
          {m.nome}
        </p>
      </li>
    ))}
  </ul>

  <p
    class="text-sm text-[#0F0F0F]/60 leading-relaxed m-0 mb-12"
    style="font-family: 'Source Serif 4', Georgia, serif;"
  >
    Die Vorstellungen der Mitglieder, die Gesichter und Geschichten der Menschen,
    die den Verein tragen, folgen in Kürze.
  </p>

  <div class="prosa-istituzionale">
    <h2>Die Organe des Vereins</h2>
    <p>
      Wie die Satzung (Art. 8) vorsieht, sind die Organe des Vereins die
      <strong>Mitgliederversammlung</strong> (das oberste Organ), der
      <strong>Vorstand</strong>, der <strong>Präsident</strong> und zwei
      <strong>Rechnungsprüfer</strong>.
    </p>
    <p>
      Der Vorstand (Art. 13) besteht aus mindestens vier Beiräten, zu denen der
      Präsident, zwei Vizepräsidenten als Vertretung der verschiedenen Täler und
      der Schriftführer/Kassier hinzukommen, gewählt von der ordentlichen
      Mitgliederversammlung. Er bleibt drei Jahre im Amt und ist wiederwählbar.
    </p>
    <p>
      Der Vorstand wird von der Jugendgruppe unterstützt, dem
      <strong>Gruppo Giovani</strong> (den <em>Joveni</em>, den Jungen), die alle
      Mitglieder unter dreißig Jahren umfasst und aus ihren Reihen einen
      Ansprechpartner wählt.
    </p>
  </div>
</PaginaIstituzionale>
