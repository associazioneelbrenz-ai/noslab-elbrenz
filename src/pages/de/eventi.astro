---
/* /de/eventi — traduzione DE (Fase 1b). Revisione Brunella Bonapace in corso. */
import Layout from '../../layouts/Layout.astro';
---
<Layout lang="de" ogImage="/og/og-eventi.jpg" title="Veranstaltungen · El Brenz" description="Die Veranstaltungen, Begegnungen und kulturellen Initiativen des Vereins El Brenz in den Tälern des Noce: Nonsberg, Sulzberg, Rabbital und Pejotal.">
  <section class="bg-gradient-to-b from-amber-50 to-white py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-amber-700 uppercase tracking-widest text-sm mb-4">Kalender · Veranstaltungen</p>
      <h1 class="font-serif text-4xl md:text-5xl text-stone-900 mb-6">Veranstaltungen</h1>
      <p class="text-lg text-stone-700">
        Die nächsten Gelegenheiten, um zusammenzukommen: Buchvorstellungen, Ausflüge, Vorträge,
        historische Abende, Tiroler Gedenktage.
      </p>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto bg-white rounded-2xl border border-amber-200 shadow-sm p-8 md:p-12">
      <div class="text-center">
        <span class="inline-block bg-amber-100 text-amber-800 text-xs uppercase tracking-wider px-3 py-1 rounded-full mb-6">
          Bereich in Arbeit
        </span>
        <h2 class="font-serif text-2xl text-stone-900 mb-4">Wir bauen gerade den Kalender auf</h2>
        <p class="text-stone-600 mb-8">
          Der neue Veranstaltungskalender kommt bald, mit Terminen, Plakaten, Partnern und
          Anmeldeformular. Bis dahin folgt uns auf unseren Kanälen, um auf dem Laufenden zu bleiben.
        </p>
      </div>
      <div class="border-t border-stone-200 pt-8">
        <p class="text-sm uppercase tracking-wider text-stone-500 mb-4">Was ihr hier finden werdet:</p>
        <ul class="space-y-2 text-stone-700">
          <li>· Termine und Orte der nächsten Veranstaltungen</li>
          <li>· Plakate und Kommunikationsmaterial</li>
          <li>· Online-Anmeldungen zu Ausflügen und Aktivitäten</li>
          <li>· Partner und institutionelle Kooperationen</li>
          <li>· Tiroler und bürgerliche Gedenktage</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-12 px-6 bg-stone-50">
    <div class="max-w-3xl mx-auto">
      <p class="text-sm uppercase tracking-wider text-stone-500 mb-4 text-center">Folgt uns in der Zwischenzeit</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="https://facebook.com/ASSOCIAZIONELBRENZ" target="_blank" rel="noopener noreferrer"
           class="inline-block bg-stone-800 text-white px-6 py-3 rounded-lg hover:bg-stone-900 transition">
          Facebook
        </a>
        <a href="https://www.instagram.com/elbrenzass" target="_blank" rel="noopener noreferrer"
           class="inline-block bg-stone-800 text-white px-6 py-3 rounded-lg hover:bg-stone-900 transition">
          Instagram
        </a>
        <a href="/de/rievocazioni" class="inline-block border-2 border-stone-800 text-stone-800 px-6 py-3 rounded-lg hover:bg-stone-100 transition">
          Vergangene Veranstaltungen
        </a>
        <a href="/de/tesseramento" class="inline-block bg-amber-500 text-white px-6 py-3 rounded-lg hover:bg-amber-600 transition">
          Mitglied werden
        </a>
      </div>
    </div>
  </section>

  <section class="py-10 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-serif italic text-stone-500 text-lg" lang="lld-anau">Raìs fonde no le 'nglacia</p>
      <p class="text-stone-400 text-sm mt-1">(Tiefe Wurzeln erfrieren nicht)</p>
    </div>
  </section>
</Layout>
