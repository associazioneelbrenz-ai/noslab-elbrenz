---
/* /de/a-proposito-di-tirolo — traduzione DE (Fase 1b). Revisione Brunella Bonapace in corso. */

import Layout from '../../layouts/Layout.astro';

const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'https://wacknihvdjxltiqvxtqr.supabase.co';
// L'URL del PDF NON è nel sorgente: lo restituisce l'edge download-lead dopo
// un submit valido del modulo (lead-gen), così il modulo non è aggirabile.
const LEAD_URL = `${SUPABASE_URL}/functions/v1/download-lead`;
const CTA = 'inline-block bg-[#C8923E] text-[#1E2E26] px-7 py-3 text-sm font-semibold tracking-wider uppercase no-underline rounded hover:bg-[#D9A94E] transition-colors cursor-pointer border-0 focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#C8923E]';
---

<Layout
  lang="de"
  title="Über Tirol bis zum Gardasee: das Buch von Everton Altmayer"
  description="Ein Geschenk aus Treze Tílias, Brasilien: das Buch von Everton Altmayer über das historische Tirol, von den Tälern des Noce bis zum Gardasee. Über 300 Seiten, kostenlos für alle."
  ogImage="/og/og-a-proposito-di-tirolo.jpg"
>
  <header class="bg-[#1E2E26] text-[#F5EEDD]">
    <div class="max-w-4xl mx-auto px-6 py-14 md:py-20">
      <div class="grid md:grid-cols-[220px_1fr] gap-8 items-center">
        <picture>
          <source srcset="/biblioteca/altmayer-copertina.webp" type="image/webp" />
          <img src="/biblioteca/altmayer-copertina.jpg" alt="Buchcover von «Über Tirol bis zum Gardasee» von Everton Altmayer" width="220" height="311" class="w-full max-w-[220px] mx-auto rounded shadow-2xl border border-[#C8923E]/30" loading="eager" decoding="async" />
        </picture>
        <div>
          <p class="text-[11px] tracking-[0.22em] uppercase text-[#D9A94E] font-medium m-0 mb-4" style="font-family: 'Inter', sans-serif;">Identität und Zugehörigkeit</p>
          <h1 class="text-3xl md:text-4xl leading-tight m-0 mb-3" style="font-family: 'Playfair Display', serif; font-weight: 500;">
            Über <em class="text-[#C8923E]" style="font-style: italic;">Tirol</em> bis zum Gardasee
          </h1>
          <p class="text-lg text-[#F5EEDD]/85 m-0 mb-6" style="font-family: 'Source Serif 4', Georgia, serif;">
            Ein Geschenk von Prof. Everton Altmayer, einer Stimme des brasilianischen Tirol von Treze Tílias.
          </p>
          <button type="button" class={CTA} data-apri-download>Das Buch herunterladen (PDF) →</button>
        </div>
      </div>
    </div>
  </header>

  <article class="bg-[#F8F1E4]">
    <div class="max-w-3xl mx-auto px-6 py-12 text-[#1E2E26]/90 leading-relaxed" style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1.05rem;">
      <p>Ein Faden verbindet unsere Täler mit einer kleinen Stadt jenseits des Ozeans: <strong>Treze Tílias</strong> (<em>Dreizehnlinden</em>) im brasilianischen Bundesstaat Santa Catarina, 1933 von Tiroler Familien gegründet. Von dort erreicht uns dieses Geschenk.</p>
      <p class="mt-5">Everton Altmayer, brasilianischer Universitätsdozent mit Studienabschluss, Master und Promotion an der Universität São Paulo, mit der er regelmäßig als Forscher zusammenarbeitet, ist ein Kenner der Trentiner Sprache, die in zahlreichen Gemeinschaften Brasiliens noch lebendig ist und dort weiterhin <em>dialèt tirolés</em> genannt wird. Seit über zwanzig Jahren widmet er sich diesem sprachlichen und kulturellen Erbe und ist Autor des Bandes <em>O dialeto trentino no Brasil</em> (Der Trentiner Dialekt in Brasilien) sowie zahlreicher Studien über die Sprache und die Identität der Tiroler Auswanderung nach Brasilien, einem Land, in dem die Erinnerung an ein Tirol, das hier bei uns Gefahr läuft, vergessen zu werden, unter den Nachkommen der Ausgewanderten noch bewahrt wird. Er ist Präsident des Centro Culturale Dona Leopoldina in Treze Tílias, einer 1969 in Zusammenarbeit mit der Universität Innsbruck gegründeten Einrichtung, Autor des bekannten Blogs «Tirolesi in Brasile» (Tiroler in Brasilien), einer Anlaufstelle für die historische und kulturelle Erforschung der Auswanderung, sowie Ideengeber und Organisator des Nationalen Symposiums zum 160. Jahrestag der Tiroler Einwanderung in Brasilien (1858–2018), das Vertreter aller brasilianischen Gemeinschaften zusammenführte, die von Auswanderern aus dem historischen Tirol gegründet wurden.</p>
      <p class="mt-5">Sein jüngstes Werk, <em>Über Tirol bis zum Gardasee: eine ausgelöschte Geschichte?</em> (Treze Tílias, 2024), zeichnet auf über dreihundert Seiten und mit mehr als 600 Abbildungen historischer Karten und Dokumente die Ursprünge Tirols und seine Ausdehnung nach Süden nach: Dieses Tirol entstand in den Ländern des Trientiner Fürstbistums, zu dem die Täler des Noce gehörten, bis zu den Ufern des Gardasees, und war von 1363 bis 1919 mit dem alten Herzogtum Österreich verbunden. Der Untertitel ist eine Frage, die uns unmittelbar angeht (<em>eine ausgelöschte Geschichte?</em>) und dieselbe, die sich El Brenz seit jeher stellt.</p>
      <p class="mt-5">Prof. Altmayer, ein Freund des Vereins, hat uns gestattet, sein Werk allen kostenlos zur Verfügung zu stellen: eine Geste der Freundschaft zwischen den beiden Ufern derselben Tiroler Erinnerung. Ihm gilt die <em>nosa gratitudine</em> (unser Dank).</p>

      <div class="mt-10 text-center">
        <button type="button" class={CTA} data-apri-download>Das Buch herunterladen (PDF)</button>
        <p class="text-xs text-[#1E2E26]/55 mt-4" style="font-family: 'Inter', sans-serif;">
          Werk von Everton Altmayer · Treze Tílias, 2024 · veröffentlicht mit freundlicher Genehmigung des Autors. Alle Rechte verbleiben beim Autor.
        </p>
      </div>
    </div>
  </article>

  {/* MODAL lead-gen download */}
  <div id="dl-overlay" class="hidden fixed inset-0 z-50 bg-[#1E2E26]/70 backdrop-blur-sm items-center justify-center px-4 py-8 overflow-y-auto" role="dialog" aria-modal="true" aria-labelledby="dl-title">
    <div id="dl-modal" class="bg-[#F5EEDD] rounded-lg shadow-2xl w-full max-w-md mx-auto my-auto p-6 md:p-8 relative" data-lead-url={LEAD_URL}>
      <button type="button" id="dl-close" aria-label="Schließen" class="absolute top-3 right-3 w-9 h-9 flex items-center justify-center text-[#1E2E26]/50 hover:text-[#1E2E26] text-2xl leading-none rounded focus:outline-none focus-visible:outline focus-visible:outline-2 focus-visible:outline-[#C8923E]">×</button>
      <h2 id="dl-title" class="text-2xl text-[#1E2E26] leading-tight m-0 mb-2" style="font-family: 'Playfair Display', serif; font-weight: 500;">Das Buch herunterladen</h2>
      <p class="text-sm text-[#1E2E26]/70 m-0 mb-5" style="font-family: 'Inter', sans-serif;">Hinterlasse deine Daten, um das Buch herunterzuladen, das der Autor Everton Altmayer kostenlos zur Verfügung stellt.</p>
      <form id="dl-form" novalidate style="font-family: 'Inter', sans-serif;">
        <div class="mb-3">
          <label for="dl-nome" class="block text-sm text-[#1E2E26]/75 mb-1">Name <span class="text-[#a33]">*</span></label>
          <input type="text" id="dl-nome" required autocomplete="name" class="w-full border-2 border-[#E5DFCF] bg-white px-4 py-2.5 text-[#1E2E26] rounded focus:outline-none focus:border-[#C8923E]" />
        </div>
        <div class="mb-3">
          <label for="dl-email" class="block text-sm text-[#1E2E26]/75 mb-1">E-Mail <span class="text-[#a33]">*</span></label>
          <input type="email" id="dl-email" required autocomplete="email" class="w-full border-2 border-[#E5DFCF] bg-white px-4 py-2.5 text-[#1E2E26] rounded focus:outline-none focus:border-[#C8923E]" />
        </div>
        <div class="mb-4">
          <label for="dl-tel" class="block text-sm text-[#1E2E26]/75 mb-1">Telefon <span class="text-[#1E2E26]/45">(optional)</span></label>
          <input type="tel" id="dl-tel" autocomplete="tel" class="w-full border-2 border-[#E5DFCF] bg-white px-4 py-2.5 text-[#1E2E26] rounded focus:outline-none focus:border-[#C8923E]" />
        </div>
        {/* honeypot */}
        <div class="hidden" aria-hidden="true"><label>Nicht ausfüllen<input type="text" id="dl-website" tabindex="-1" autocomplete="off" /></label></div>
        <label class="flex items-start gap-2.5 mb-2.5 text-sm text-[#1E2E26]/80 cursor-pointer">
          <input type="checkbox" id="dl-privacy" class="mt-0.5 w-4 h-4 accent-[#C8923E]" />
          <span>Ich habe die <a href="/privacy" target="_blank" class="text-[#8a6215] underline">Datenschutzerklärung</a> gelesen und akzeptiere sie. <span class="text-[#a33]">*</span></span>
        </label>
        <label class="flex items-start gap-2.5 mb-5 text-sm text-[#1E2E26]/80 cursor-pointer">
          <input type="checkbox" id="dl-news" class="mt-0.5 w-4 h-4 accent-[#C8923E]" />
          <span>Ich möchte die Neuigkeiten von El Brenz erhalten.</span>
        </label>
        <button type="submit" id="dl-submit" class="w-full bg-[#C8923E] text-[#1E2E26] py-3 rounded font-semibold hover:bg-[#D9A94E] transition-colors">Das Buch herunterladen (PDF)</button>
        <div id="dl-esito" class="hidden mt-3 text-sm rounded px-3 py-2"></div>
      </form>
    </div>
  </div>
</Layout>

<script>
  // Modal lead-gen: raccoglie nome+email, poi l'edge download-lead restituisce
  // l'URL del PDF e facciamo partire il download. Focus trap minimale + ESC.
  (function () {
    const overlay = document.getElementById('dl-overlay');
    const modal = document.getElementById('dl-modal');
    const form = document.getElementById('dl-form') as HTMLFormElement | null;
    const esito = document.getElementById('dl-esito');
    const submit = document.getElementById('dl-submit') as HTMLButtonElement | null;
    if (!overlay || !modal || !form || !submit) return;
    const leadUrl = modal.getAttribute('data-lead-url')!;
    let openedAt = 0;
    let lastFocus: HTMLElement | null = null;

    const apri = () => {
      lastFocus = document.activeElement as HTMLElement;
      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      openedAt = Date.now();
      (document.getElementById('dl-nome') as HTMLInputElement | null)?.focus();
      document.body.style.overflow = 'hidden';
    };
    const chiudi = () => {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
      document.body.style.overflow = '';
      lastFocus?.focus();
    };
    document.querySelectorAll('[data-apri-download]').forEach((b) => b.addEventListener('click', apri));
    document.getElementById('dl-close')?.addEventListener('click', chiudi);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) chiudi(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !overlay.classList.contains('hidden')) chiudi(); });

    const msg = (t: string, ok: boolean) => {
      if (!esito) return;
      esito.classList.remove('hidden');
      esito.style.background = ok ? '#eaf3ee' : '#fbecec';
      esito.style.color = '#1E2E26';
      esito.textContent = t;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const nome = (document.getElementById('dl-nome') as HTMLInputElement).value.trim();
      const email = (document.getElementById('dl-email') as HTMLInputElement).value.trim();
      const telefono = (document.getElementById('dl-tel') as HTMLInputElement).value.trim();
      const privacy = (document.getElementById('dl-privacy') as HTMLInputElement).checked;
      const news = (document.getElementById('dl-news') as HTMLInputElement).checked;
      const honeypot = (document.getElementById('dl-website') as HTMLInputElement).value;
      if (nome.length < 2) { msg('Bitte gib deinen Namen ein.', false); return; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { msg('Ungültige E-Mail-Adresse.', false); return; }
      if (!privacy) { msg('Für den Download ist die Zustimmung zum Datenschutz erforderlich.', false); return; }
      submit.disabled = true;
      submit.textContent = 'Download wird vorbereitet…';
      try {
        const r = await fetch(leadUrl, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nome, email, telefono, consenso_privacy: privacy, consenso_newsletter: news,
            risorsa: 'libro-altmayer', _honeypot: honeypot, _ts: openedAt,
            sorgente: { ref: document.referrer || null },
          }),
        });
        const out = await r.json();
        if (r.ok && out.url) {
          const a = document.createElement('a');
          a.href = out.url; a.target = '_blank'; a.rel = 'noopener'; a.setAttribute('download', '');
          document.body.appendChild(a); a.click(); a.remove();
          msg('Danke! Der Download wurde gestartet. Falls nicht, sieh in deiner E-Mail nach.', true);
          setTimeout(chiudi, 2200);
        } else {
          msg(out.error || 'Der Download konnte nicht gestartet werden. Bitte versuche es erneut.', false);
        }
      } catch {
        msg('Verbindungsfehler. Bitte versuche es gleich noch einmal.', false);
      } finally {
        submit.disabled = false;
        submit.textContent = 'Das Buch herunterladen (PDF)';
      }
    });
  })();
</script>
