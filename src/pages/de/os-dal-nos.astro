---
/* /de/os-dal-nos — traduzione DE (Fase 1b). Revisione Brunella Bonapace in corso. */

import PaginaIstituzionale from '../../components/PaginaIstituzionale.astro';
import LightboxEmbed from '../../components/LightboxEmbed.astro';
import { OS_DAL_NOS, miniatura, embed } from '../../data/video';

const edizioni = [2014, 2015, 2016, 2017, 2018, 2019];
---
<PaginaIstituzionale
  lang="de"
  ogImage="/og/og-os-dal-nos.jpg"
  occhiello="Projekte"
  titolo="Os dal Nos"
  intro="Der Lyrik- und Musikwettbewerb, der den rätoromanischen Sprachen der Täler des Noce eine Stimme verleiht: Kompositionen auf Nones, Solander, Rabies und Pegaes."
  metaTitle="Os dal Nos, der Wettbewerb auf Anaunischem Ladinisch | El Brenz"
  metaDescription="Die Videos aller Ausgaben von Os dal Nos, dem Lyrik- und Musikwettbewerb von El Brenz in der Sprache der Täler des Noce (2014-2019)."
>
  <div class="prosa-istituzionale">
    <h2>Die Stimme des Noce</h2>
    <p>
      <strong>Os dal Nos</strong> (<em>Stimme des Noce</em>) ist der Lyrik-
      und Musikwettbewerb, mit dem wir seit der ersten Ausgabe 2014
      Künstlerinnen, Künstler und Dichter dazu anregen, Werke auf <em>Anaunischem
      Ladinisch</em> zu schaffen und dabei die verschiedenen Sprachvarianten
      unserer Täler zu vereinen: das <em>Nones</em>, das <em>Solander</em>, das
      <em>Rabies</em> und das <em>Pegaes</em>. Eine wahre Hymne an die Schönheit
      und die Identität unserer Worte.
    </p>
    <p>
      Die Werke, die an den Ausgaben des Wettbewerbs teilgenommen haben,
      verschwinden nicht in der Schublade: Sie sind zur Seele des
      <a href="/de/lunari-dal-nos">Lunari dal Nos</a> geworden, des
      Vereinskalenders, der sie Jahr für Jahr in die Häuser und Schulen der
      Täler trägt.
    </p>

    <h2>Die Ausgaben</h2>
    <p>
      Der Wettbewerb fand in sechs Ausgaben statt, von 2014 bis 2019:
    </p>
  </div>

  {/* Video per edizione. Accordion nativo <details>: nessun JavaScript per
      aprire e chiudere, funziona anche se lo script non parte. Le miniature
      sono immagini statiche di YouTube: NESSUN iframe finche' non si apre il
      lightbox, quindi la pagina resta leggera con oltre quaranta video. */}
  <div class="mt-8 flex flex-col gap-4">
    {OS_DAL_NOS.edizioni.map((ed) => (
      ed.stato === 'pubblicata' ? (
        <details class="bg-white border border-[#E5DFCF] group" open={ed.n === 5}>
          <summary class="cursor-pointer list-none p-6 md:p-8 flex items-center gap-4">
            <span class="text-2xl text-[#1E2E26] font-medium m-0" style="font-family: 'Playfair Display', serif;">
              {ed.titolo}
            </span>
            <span class="text-sm text-[#0F0F0F]/55" style="font-family: 'Inter', sans-serif;">
              {ed.anno} · {ed.video.length} Videos
            </span>
            <span class="ml-auto text-[#C8923E] text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <div class="px-6 md:px-8 pb-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {ed.video.map((v) => (
                <LightboxEmbed
                  url={`https://www.youtube.com/watch?v=${v.id_youtube}`}
                  embedSrcDiretto={embed(v.id_youtube)}
                  cover={miniatura(v.id_youtube)}
                  titolo={v.titolo}
                  etichetta={v.titolo}
                  aspetto="16/9"
                />
              ))}
            </div>
            {ed.articolo && (
              <p class="mt-5 m-0">
                <a href={`/de/articoli/${ed.articolo}`} class="text-sm text-[#8a6215] underline" style="font-family: 'Inter', sans-serif;">
                  Zum Artikel der Ausgabe →
                </a>
              </p>
            )}
          </div>
        </details>
      ) : (
        <div class="bg-white border border-[#E5DFCF] p-6 md:p-8 flex items-center gap-4">
          <span class="text-2xl text-[#1E2E26]/55 font-medium m-0" style="font-family: 'Playfair Display', serif;">
            {ed.titolo}
          </span>
          <span class="text-sm text-[#0F0F0F]/45" style="font-family: 'Inter', sans-serif;">{ed.anno}</span>
          {ed.articolo && (
            <a href={`/de/articoli/${ed.articolo}`} class="text-sm text-[#8a6215] underline" style="font-family: 'Inter', sans-serif;">
              Zum Artikel →
            </a>
          )}
          <span
            class="ml-auto inline-block text-[11px] tracking-[0.18em] uppercase text-[#C8923E] border border-[#C8923E] px-3 py-1.5"
            style="font-family: 'Inter', sans-serif;"
          >
            In Kürze
          </span>
        </div>
      )
    ))}
  </div>

  <p class="text-sm text-[#0F0F0F]/55 mt-6 m-0" style="font-family: 'Inter', sans-serif;">
    Die fehlenden Ausgaben werden nach und nach ergänzt, sobald die Videos wieder verfügbar sind.
  </p>
  <p class="text-sm text-[#0F0F0F]/55 mt-2 m-0" style="font-family: 'Inter', sans-serif;">
    Die Videos öffnen sich in einem Fenster auf der Website, von YouTube im Modus ohne Profiling-Cookies.
  </p>

  <div class="bg-white border border-[#E5DFCF] p-8 md:p-10 mt-10">
    <span
      class="inline-block text-[11px] tracking-[0.18em] uppercase text-[#C8923E] border border-[#C8923E] px-3 py-1.5 mb-5"
      style="font-family: 'Inter', sans-serif;"
    >
      In Kürze
    </span>
    <p
      class="text-[#0F0F0F]/75 leading-relaxed m-0"
      style="font-family: 'Source Serif 4', Georgia, serif;"
    >
      Wir digitalisieren die Materialien der sechs Ausgaben: Fotos der
      Preisverleihungen, prämierte Werke, Plakate, die hier und in der
      Fotogalerie der Website zusammenfließen werden. Ein Stück nach dem
      anderen, mit der Sorgfalt, die diese Erinnerungen verdienen.
    </p>
  </div>
</PaginaIstituzionale>
