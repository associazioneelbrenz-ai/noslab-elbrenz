---
/**
 * Layout — Shell HTML principale di El Brenz
 *
 * Usato da tutte le pagine pubbliche del sito.
 * Include:
 *   - <head> con meta SEO base e import di global.css
 *   - <Header /> con wordmark + navigazione
 *   - <slot /> per il contenuto della pagina
 *   - <footer> con firma istituzionale + bandiera ladina + credit NosLab
 *   - <FabAndreas /> bottone galleggiante (nascosto su /andreas)
 *
 * M.A.2.5: aggiunti BannerAndreas e FabAndreas come entry point globali ad Andreas.
 * M3.0 (8/7/2026): BannerAndreas RIMOSSO su decisione Cristian — ridondante
 * col widget flottante con badge; il componente resta in src/components/.
 */

import '../styles/global.css';
import '../styles/fonts.css';
import Wordmark from '../components/Wordmark.astro';
import FirmaIstituzionale from '../components/FirmaIstituzionale.astro';
import BandieraLadina from '../components/BandieraLadina.astro';
import Header from '../components/Header.astro';
import FabAndreas from '../components/FabAndreas.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'El Brenz dle Val del Nos',
  description = 'Associazione Storico Culturale Linguistica El Brenz delle Valli del Noce. Storia, lingua ladino-anaunica, cultura di Val di Non, Val di Sole, Val di Rabbi e Val di Pejo.',
  ogImage = '/og-image.png',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const fullTitle = title === 'El Brenz dle Val del Nos'
  ? `${title} — Associazione Storico Culturale Linguistica`
  : `${title} — El Brenz dle Val del Nos`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1E2E26" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="El Brenz" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="El Brenz — Associazione Storico Culturale" />
    <meta property="og:locale" content="it_IT" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    {/* AUD-E3 (10/7/2026): font self-hosted in /fonts/ via src/styles/fonts.css
        — rimossi i link a fonts.googleapis.com/gstatic.com (privacy + TBT).
        Preload dei due font critici above-the-fold. */}
    <link rel="preload" href="/fonts/playfair-display.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-[#F8F1E4] text-[#0F0F0F] min-h-screen flex flex-col">

    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-[#1E2E26] text-[#F5EEDD] mt-20 pt-16 pb-7">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-14">

        <div class="flex items-start gap-5">
          <img
            src="/logo-eb-footer.png"
            srcset="/logo-eb-footer.png 1x, /logo-eb-footer@2x.png 2x"
            alt="Timbro Associazione El Brenz"
            width="80"
            height="80"
            class="flex-shrink-0 mt-1"
            loading="lazy"
          />
          <div>
            <FirmaIstituzionale theme="dark" size="md" class="items-start text-left" />
            <BandieraLadina width={72} class="mt-6" />
            {/* Social (addendum 8/7/2026): icone SVG inline monocrome,
                fill=currentColor per ereditare avorio/hover oro da Tailwind. */}
            <div class="flex items-center gap-4 mt-6">
              <a href="https://www.facebook.com/ASSOCIAZIONELBRENZ" target="_blank" rel="noopener" aria-label="Seguici su Facebook" class="text-[#F5EEDD] hover:text-[#C8923E] transition-colors">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href="https://www.instagram.com/elbrenzass" target="_blank" rel="noopener" aria-label="Seguici su Instagram" class="text-[#F5EEDD] hover:text-[#C8923E] transition-colors">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="https://www.youtube.com/channel/UCX5cNGUEYPDrzC_G9hxKOzA" target="_blank" rel="noopener" aria-label="Seguici su YouTube" class="text-[#F5EEDD] hover:text-[#C8923E] transition-colors">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
              <a href="https://music.youtube.com/@elbrenz" target="_blank" rel="noopener" aria-label="Ascoltaci su YouTube Music" class="text-[#F5EEDD] hover:text-[#C8923E] transition-colors">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.376 0 0 5.376 0 12s5.376 12 12 12 12-5.376 12-12S18.624 0 12 0zm0 19.104c-3.924 0-7.104-3.18-7.104-7.104S8.076 4.896 12 4.896s7.104 3.18 7.104 7.104-3.18 7.104-7.104 7.104zm-2.316-3.564L15.816 12 9.684 8.46v7.08z"/></svg>
              </a>
              <!-- TODO: link gruppo Telegram quando creato
              <a href="TELEGRAM_URL" target="_blank" rel="noopener" aria-label="Unisciti al gruppo Telegram" class="text-[#F5EEDD] hover:text-[#C8923E] transition-colors">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              </a>
              -->
            </div>
          </div>
        </div>

        <div style="font-family: 'Inter', sans-serif;">
          <h2 class="text-[11px] tracking-[0.2em] uppercase text-[#D9A94E] font-medium mb-4">Associazione</h2>
          <p class="text-sm text-[#F5EEDD]/85 leading-relaxed mb-2">Via Trento 40, II piano<br/>38027 Malè (TN)</p>
          <p class="text-sm text-[#F5EEDD]/85 mb-2">C.F. 92019480224</p>
          <a href="mailto:info@elbrenz.eu" class="text-sm text-[#F5EEDD]/85 no-underline hover:text-[#D9A94E] block mb-1">info@elbrenz.eu</a>
          <a href="tel:+393471077636" class="text-sm text-[#F5EEDD]/85 no-underline hover:text-[#D9A94E] block">+39 347 107 7636</a>
          <a href="/custodi-della-memoria" class="text-sm text-[#D9A94E] no-underline hover:underline block mt-3">I Custodi della Memoria →</a>
        </div>

        <div style="font-family: 'Inter', sans-serif;">
          <h2 class="text-[11px] tracking-[0.2em] uppercase text-[#D9A94E] font-medium mb-4">Sostienici</h2>
          <p class="text-sm text-[#F5EEDD]/85 mb-2">Cassa Rurale Val di Sole<br/>filiale Mezzana</p>
          <p class="text-xs font-mono text-[#F5EEDD]/75 tracking-wider mb-3">IT84U0816335010000190116255</p>
          <a href="/tesseramento" class="text-sm text-[#D9A94E] no-underline hover:underline">Diventa socio →</a>
        </div>

      </div>

      <div class="max-w-7xl mx-auto px-6 mt-14 pt-6 border-t border-[#F5EEDD]/15 flex flex-wrap items-center justify-between gap-4" style="font-family: 'Inter', sans-serif;">
        <p class="text-xs text-[#F5EEDD]/55 m-0">
          © 2026 Associazione Storico Culturale Linguistica El Brenz · Tutti i diritti riservati
          <br class="hidden sm:block" /><span class="text-[#F5EEDD]/40">Decorazione: <em>Aquila Tirolensis</em> di Matthias Burgklechner (XVII sec.), opera in pubblico dominio.</span>
        </p>
        {/* AGGIORNAMENTO 8/7/2026 sera (decisione Cristian): credit NosLab
            col logo ufficiale (bianco su trasparente, ok sul verde scuro
            del footer) al posto del solo testo. */}
        <a
          href="https://noslab.it"
          target="_blank"
          rel="noopener"
          aria-label="NosLab — sviluppo del sito"
          class="inline-flex items-center gap-2 flex-wrap opacity-80 hover:opacity-100 transition-opacity no-underline mr-20 md:mr-24"
        >
          <span class="text-xs text-[#F5EEDD]/70">Sviluppato da</span>
          <img src="/partner/noslab-logo-footer.png" alt="NosLab" width="110" height="28" loading="lazy" decoding="async" class="h-6 md:h-7 w-auto" />
          <span class="text-xs text-[#F5EEDD]/70">un contributo <em>pro bono</em> alla comunità delle valli</span>
        </a>
      </div>
    </footer>

    <FabAndreas pathname={currentPath} />

    <CookieConsent />

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').then(
            (registration) => {
              console.log('ServiceWorker registrato:', registration.scope);
            },
            (error) => {
              console.warn('ServiceWorker registrazione fallita:', error);
            }
          );
        });
      }
    </script>

  </body>
</html>
