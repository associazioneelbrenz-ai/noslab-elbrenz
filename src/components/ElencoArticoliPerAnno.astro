---
/**
 * ElencoArticoliPerAnno — lista di articoli raggruppata per anno (M2.2).
 *
 * Usato da:
 *   - PaginaPilastro.astro  (variante normale, sobrio=false)
 *   - archivio-storico.astro (variante sobria/in sordina, sobrio=true)
 *
 * Ogni articolo è linkato a /articoli/{id}. Anni in ordine DESC (recente in alto),
 * articoli dentro l'anno in ordine DESC. Lo styling segue la palette brand
 * (verde #1E2E26, oro #C8923E, crema #FDF9F0) coerente con index/ArticleLayout.
 */

import { raggruppaPerAnno, formatDataIT } from '../lib/articoli';
import type { Articolo } from '../lib/articoli';

interface Props {
  articoli: Articolo[];
  /** true = stile in sordina per l'archivio storico (compatto, muted, senza excerpt). */
  sobrio?: boolean;
}

const { articoli, sobrio = false } = Astro.props;
const gruppi = raggruppaPerAnno(articoli);
---

<div class={sobrio ? 'space-y-10' : 'space-y-16'}>
  {gruppi.map((gruppo) => (
    <section>
      {sobrio ? (
        <h2
          class="text-sm tracking-[0.2em] uppercase text-[#1E2E26]/50 font-medium mb-5 pb-2 border-b border-[#E5DFCF]"
          style="font-family: 'Inter', sans-serif;"
        >
          {gruppo.anno}
        </h2>
      ) : (
        <h2
          class="text-3xl md:text-4xl text-[#C8923E] font-medium mb-7 pb-3 border-b border-[#E5DFCF]"
          style="font-family: 'Playfair Display', serif;"
        >
          {gruppo.anno}
        </h2>
      )}

      <ul class={`list-none m-0 p-0 ${sobrio ? 'divide-y divide-[#E5DFCF]' : 'space-y-3'}`}>
        {gruppo.articoli.map((a) => (
          <li>
            {sobrio ? (
              <a
                href={`/articoli/${a.id}`}
                class="group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 py-3 no-underline"
              >
                <time
                  datetime={a.data.data_pubblicazione.toISOString()}
                  class="text-xs text-[#1E2E26]/45 tracking-wide flex-shrink-0 sm:w-44"
                  style="font-family: 'Inter', sans-serif;"
                >
                  {formatDataIT(a.data.data_pubblicazione)}
                </time>
                <span
                  class="text-lg text-[#1E2E26]/80 leading-snug group-hover:text-[#C8923E] transition-colors"
                  style="font-family: 'Source Serif 4', Georgia, serif;"
                >
                  {a.data.title}
                </span>
              </a>
            ) : (
              <a
                href={`/articoli/${a.id}`}
                class="group block bg-white border border-[#E5DFCF] hover:border-[#C8923E] transition-colors p-6 no-underline"
              >
                <p
                  class="text-[11px] tracking-[0.18em] uppercase text-[#C8923E] m-0 mb-2"
                  style="font-family: 'Inter', sans-serif;"
                >
                  <time datetime={a.data.data_pubblicazione.toISOString()}>
                    {formatDataIT(a.data.data_pubblicazione)}
                  </time>
                </p>
                <h3
                  class="text-2xl text-[#1E2E26] font-medium leading-tight m-0 group-hover:text-[#C8923E] transition-colors"
                  style="font-family: 'Playfair Display', serif;"
                >
                  {a.data.title}
                </h3>
                {a.data.excerpt && (
                  <p
                    class="text-[#0F0F0F]/70 leading-relaxed m-0 mt-3 line-clamp-2"
                    style="font-family: 'Source Serif 4', Georgia, serif;"
                  >
                    {a.data.excerpt}
                  </p>
                )}
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>
  ))}
</div>
