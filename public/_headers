# Security headers (AUD-A1, Ondata 1 — 10/7/2026).
# CSP ENFORCED dal 16/7/2026: dopo il periodo di osservazione in Report-Only e la
# verifica console (nessuna violazione sulle pagine chiave), passata da
# Content-Security-Policy-Report-Only a Content-Security-Policy. Se emergono
# blocchi, tornare a Report-Only e aggiungere l'host mancante alla policy.
# HSTS senza `preload` (scelta prudente: preload è semi-permanente).

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  # DENY globale (era SAMEORIGIN): nessuna pagina del sito ha iframe same-origin,
  # verificato 20/7. L'UNICA pagina embeddata legittimamente e' /andreas/embed
  # (dall'app community), che mantiene il suo override piu' sotto.
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  # Host mappa (tile OSM + WMS SIAT PAT) in img-src; SIAT anche in connect-src
  # (GetCapabilities); www.facebook.com in frame-src (Page Plugin embed consent-gated).
  # 16/7: enforced (era Report-Only dal 14/7) dopo verifica console senza violazioni.
  # 17/7: cdn.jsdelivr.net in script-src — la chat Andreas (andreas-chat.js) carica
  # marked+DOMPurify da lì per il markdown; senza, ensureLibs() falliva e la chat
  # non si inizializzava («Andreas non interrogabile»).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.paypalobjects.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://wacknihvdjxltiqvxtqr.supabase.co https://www.paypalobjects.com https://tile.openstreetmap.org https://siat.provincia.tn.it; font-src 'self'; connect-src 'self' https://wacknihvdjxltiqvxtqr.supabase.co https://www.paypal.com https://siat.provincia.tn.it; frame-src https://www.paypal.com https://www.instagram.com https://www.youtube-nocookie.com https://www.facebook.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://wacknihvdjxltiqvxtqr.supabase.co

# La chat Andreas minimale (/andreas/embed) è pensata per essere inglobata via
# iframe dall'app della community: qui allentiamo SOLO il framing (frame-ancestors
# + X-Frame-Options) verso le origin dell'app, lasciando invariato il resto della
# policy. La protezione clickjacking del resto del sito NON cambia.
/andreas/embed
  X-Frame-Options: ALLOWALL
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.paypalobjects.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://wacknihvdjxltiqvxtqr.supabase.co https://www.paypalobjects.com; font-src 'self'; connect-src 'self' https://wacknihvdjxltiqvxtqr.supabase.co; frame-ancestors 'self' https://elbrenz-community.netlify.app https://app.elbrenz.eu https://community.elbrenz.eu; base-uri 'self'; form-action 'self' https://wacknihvdjxltiqvxtqr.supabase.co
/andreas/embed/*
  X-Frame-Options: ALLOWALL
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.paypal.com https://www.paypalobjects.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://wacknihvdjxltiqvxtqr.supabase.co https://www.paypalobjects.com; font-src 'self'; connect-src 'self' https://wacknihvdjxltiqvxtqr.supabase.co; frame-ancestors 'self' https://elbrenz-community.netlify.app https://app.elbrenz.eu https://community.elbrenz.eu; base-uri 'self'; form-action 'self' https://wacknihvdjxltiqvxtqr.supabase.co

# B3 (19/7/2026) — Caching. Gli asset con hash in /_astro/ e l'HTML sono gia'
# gestiti bene da Netlify; i file in public/ no: i font venivano rivalidati a
# ogni visita (max-age=0). Sono immutabili di fatto (cambiano solo se cambia il
# nome), quindi anno pieno. Access-Control-Allow-Origin serve se un domani i
# font vengono usati anche da community.elbrenz.eu.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/assets/branding/*
  Cache-Control: public, max-age=31536000, immutable

/decoro/*
  Cache-Control: public, max-age=2592000

/leaflet/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=604800
